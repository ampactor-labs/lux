import types

/// double — the canonical bare-Pure-body function. Mentl's oracle
/// should propose exactly one annotation: `with Pure` (gradient
/// step APure). The unlocks: CMemoize (same input → same output
/// guarantee), CParallelize (no side effects to race),
/// CCompileTimeEval (if input is known).
///
/// The bare signature is the hole — `??` semantically (no annotation
/// committed). Mentl's Synth tentacle proposes APure; Verify
/// discharges (body is provably Pure — `*` is integer multiply,
/// no effects). Survivor: APure(span). Surface as VoiceLine via
/// `mentl teach`.

fn double(x) =
  x * 2

/// triple — same shape, same expected gradient. Two functions in
/// the same crucible exercise that the oracle's per-position state
/// is per-fn-handle, not project-wide noise.

fn triple(x) =
  x * 3

/// quadruple — composes `double`. Mentl should still propose APure
/// at the call site; `double` being inferred Pure transitively
/// implies quadruple is Pure too.

fn quadruple(x) =
  double(double(x))

