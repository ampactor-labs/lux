// Tail call optimization test
// These functions would stack overflow at depth 512 without TCO.

fn count_down(n) = if n <= 0 { 0 } else { count_down(n - 1) }
let result = count_down(10000)
println("count_down(10000) = " ++ to_string(result))

fn sum_to(n, acc) = if n <= 0 { acc } else { sum_to(n - 1, acc + n) }
let total = sum_to(10000, 0)
println("sum_to(10000) = " ++ to_string(total))
