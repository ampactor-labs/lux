// Self-hosted VM comprehensive test suite
// Tests: self-hosted lexer → parser → codegen → Lux VM
//
// Uses raw strings ('...') for source code containing braces,
// because "..." uses {expr} string interpolation.

import compiler/lexer
import compiler/parser
import compiler/codegen
import compiler/pipeline
import vm

fn test(name, source) = {
  print("  " ++ name ++ ": ")
  vm_run(compile(source))
}

println("╔══════════════════════════════════════╗")
println("║  Self-Hosted VM — Full Test Suite    ║")
println("╚══════════════════════════════════════╝")
println("")

println("── Literals ──")
test("int",       "println(42)")
test("zero",      "println(0)")
test("neg",       "println(0 - 7)")
test("bool-T",    "println(true)")
test("bool-F",    "println(false)")

println("── Arithmetic ──")
test("add",       "println(2 + 3)")
test("sub",       "println(10 - 3)")
test("mul",       "println(6 * 7)")
test("div",       "println(20 / 4)")
test("mod",       "println(17 % 5)")
test("complex",   "println((2 + 3) * 4)")
test("nested",    "println(1 + 2 * 3)")

println("── Comparison ──")
test("eq-T",      "println(3 == 3)")
test("eq-F",      "println(3 == 4)")
test("neq",       "println(3 != 4)")
test("lt",        "println(3 < 5)")
test("gt",        "println(5 > 3)")

println("── Let Bindings ──")
test("let",       "let x = 10\nprintln(x + 5)")
test("multi-let", "let a = 3\nlet b = 4\nprintln(a + b)")
test("shadow",    "let x = 1\nlet x = 2\nprintln(x)")

println("── Control Flow ──")
test("if-T",      'println(if true { 1 } else { 2 })')
test("if-F",      'println(if false { 1 } else { 2 })')
test("if-cond",   'let x = 5\nprintln(if x > 3 { 99 } else { 0 })')

println("── Functions ──")
test("fn-call",   "fn double(x) = x * 2\nprintln(double(21))")
test("fn-2arg",   "fn add(a, b) = a + b\nprintln(add(10, 20))")
test("fn-expr",   "fn square(x) = x * x\nprintln(square(5))")
test("fn-if",     'fn sign(x) = if x > 0 { 1 } else { 0 }\nprintln(sign(42))')

println("── Recursion ──")
test("countdown", 'fn countdown(n) = if n == 0 { 0 } else { countdown(n - 1) }\nprintln(countdown(5))')
test("factorial", 'fn fact(n) = if n <= 1 { 1 } else { n * fact(n - 1) }\nprintln(fact(5))')
test("fibonacci", 'fn fib(n) = if n <= 1 { n } else { fib(n - 1) + fib(n - 2) }\nprintln(fib(10))')

println("── Collections ──")
test("list-len",  "println(len([1, 2, 3]))")
test("list-push", "println(len(push([1, 2], 3)))")
test("range",     "println(len(range(0, 5)))")

println("── Strings ──")
test("concat",    "println(to_string(1) ++ to_string(2))")
test("len-str",   "println(len(to_string(123)))")

println("── Builtins ──")
test("abs",       "println(abs(0 - 42))")
test("max",       "println(max(3, 7))")
test("min",       "println(min(3, 7))")

println("── Effects: Handle/Resume ──")
test("simple-handle",
  'effect Fail { fail(msg) -> Int }
let result = handle { fail("oops") } { fail(m) => resume(42) }
println(result)')

test("body-value",
  'effect F { f() -> Int }
let result = handle { 10 + f() } { f() => resume(5) }
println(result)')

test("multi-resume",
  'effect F { f(x) -> Int }
let result = handle { f(1) + f(2) } { f(x) => resume(x * 10) }
println(result)')

test("handler-state",
  'effect S { get() -> Int, set(v) -> () }
let result = handle {
  set(10)
  let x = get()
  set(x + 5)
  get()
} with s = 0 {
  get() => resume(s),
  set(v) => resume(()) with s = v
}
println(result)')

println("── Effects: Advanced ──")
test("nested-handle",
  'effect A { a() -> Int }
effect B { b() -> Int }
let result = handle {
  let x = handle { b() + 1 } { b() => resume(10) }
  x + a()
} { a() => resume(100) }
println(result)')

test("string-effect",
  'effect Name { name() -> String }
let result = handle { "hello " ++ name() } { name() => resume("world") }
println(result)')

test("computed-resume",
  'effect F { f(x) -> Int }
let result = handle { f(3) } { f(x) => resume(x * x + 1) }
println(result)')

test("no-effect-body",
  'effect F { f() -> Int }
let result = handle { 42 } { f() => resume(0) }
println(result)')

test("effect-unit",
  'effect Log { log(msg) -> () }
let result = handle { log("a"); log("b"); 99 } { log(m) => resume(()) }
println(result)')

test("sequential-state",
  'effect C { inc() -> (), count() -> Int }
let result = handle {
  inc()
  inc()
  inc()
  inc()
  inc()
  count()
} with n = 0 {
  inc() => resume(()) with n = n + 1,
  count() => resume(n)
}
println(result)')

println("")
println("═══ All tests passed! ═══")
