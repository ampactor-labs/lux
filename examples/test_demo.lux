// Test demo — the Test effect in action
import test

fn test_math() = {
  check(2 + 2 == 4, "2+2=4")
  check(3 * 7 == 21, "3*7=21")
  expect_eq(42, 42)
  check(1 + 1 == 3, "1+1=3 (should fail)")
}

fn test_strings() = {
  check("hello" ++ " world" == "hello world", "concat")
  check(starts_with("lux", "l"), "starts_with")
  expect_eq("lux", "lux")
}

effect TestFail {
  test_fail(msg: String) -> Never
}

fn test_effects() = {
  let result = handle {
    test_fail("boom")
    99
  } {
    test_fail(msg) => 42
  }
  expect_eq(result, 42)
  check(true, "effects work")
}

println("=== Test Effect Demo ===")
run_suite([
  ("math", test_math),
  ("strings", test_strings),
  ("effects", test_effects),
])
