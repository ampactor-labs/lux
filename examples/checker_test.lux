// Test: Why Engine — every inference explains itself
//
// The teaching compiler doesn't just say WHAT type something is —
// it explains WHY, at any depth you ask.

import compiler/parser
import compiler/check
import compiler/why

println("=== Why Engine ===")

// Test 1: Simple literal — WHY is x Int?
println("--- let x = 42 ---")
println(check_and_explain("let x = 42", "x", 0))
println("")
println(check_and_explain("let x = 42", "x", 1))
println("")

// Test 2: Arithmetic — WHY is y Int?
println("--- let y = 1 + 2 * 3 ---")
println(check_and_explain("let y = 1 + 2 * 3", "y", 0))
println("")
println(check_and_explain("let y = 1 + 2 * 3", "y", 1))
println("")

// Test 3: Function — WHY does add have this type?
println("--- fn add(a, b) = a + b ---")
println(check_and_explain("fn add(a, b) = a + b", "add", 0))
println("")
println(check_and_explain("fn add(a, b) = a + b", "add", 1))
println("")
println(check_and_explain("fn add(a, b) = a + b", "add", 2))
println("")

// Test 4: If expression — WHY do branches agree?
println("--- let r = if true { 1 } else { 2 } ---")
println(check_and_explain("let r = if true { 1 } else { 2 }", "r", 1))
println("")

// Test 5: Full program — show all bindings with reasons
println("--- full program with reasons ---")
println(check_and_show("let x = 42\nfn double(n) = n * 2\nlet y = double(x)", 1))

// ─── Phase 13 Tests: Match, Lambda, Handle/Resume ───────────

// Test 6: Match expression
println("--- match expression ---")
println(check_and_explain('let x = match 42 { n => n + 1 }', "x", 1))
println("")

// Test 7: Lambda expression
println("--- lambda ---")
println(check_and_explain('let f = |x| x + 1', "f", 0))
println("")

// Test 8: Lambda applied
println("--- lambda applied ---")
println(check_and_show('let f = |x| x + 1\nlet y = f(10)', 1))

// Test 9: Match with multiple arms
println("--- match with wildcard ---")
println(check_and_explain('let r = match true { x => 1, _ => 2 }', "r", 1))
println("")

// Test 10: Let destructure
println("--- let destructure ---")
println(check_and_show('let (a, b) = (1, 2)', 0))

// Test 11: Nested lambda
println("--- nested lambda ---")
println(check_and_explain('let add = |a| |b| a + b', "add", 0))
println("")

// Test 12: Effect annotation — Pure function
println("--- pure function ---")
println(check_and_explain('fn pure_add(a, b) with Pure = a + b', "pure_add", 0))
println("")

// Test 13: Effect annotation — !Alloc on pure body (passes)
println("--- negated effect ---")
println(check_and_explain('fn no_alloc(x) with !Alloc = x + 1', "no_alloc", 0))
println("")

// Test 14: Pure VIOLATION — declares Pure but calls an effect operation
println("--- Pure violation ---")
println(check_and_explain('effect Console { say(s) -> () }
fn impure() with Pure = { say("hi"); 42 }', "impure", 0))
println("")

// Test 15: !Alloc VIOLATION — body performs Alloc
println("--- !Alloc violation ---")
println(check_and_explain('effect Alloc { alloc(n) -> Int }
fn bad(x) with !Alloc = { alloc(x); x }', "bad", 0))
println("")

println("=== The Gradient ===")

// Test 16: Pure function gets gradient suggestion
println("--- gradient: pure function ---")
println(check_and_teach('fn double(x) = x * 2', "double"))
println("")

// Test 17: Function with effects — no false suggestion
println("--- gradient: effectful function ---")
println(check_and_teach('effect IO { read() -> String }\nfn reader() = read()', "reader"))
println("")

// Test 18: Already annotated — no suggestion needed
println("--- gradient: already annotated ---")
println(check_and_teach('fn safe(x) with Pure = x + 1', "safe"))
println("")

println("=== The compiler teaches ===")
