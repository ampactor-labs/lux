// Test: Self-hosted codegen
// Parses Lux source, compiles to bytecode, then disassembles.

import compiler/parser
import compiler/codegen

println("=== Self-Hosted Codegen ===")

// Test 1: Simple literal
println("--- let x = 42 ---")
println(compile_and_show("let x = 42"))

// Test 2: Arithmetic
println("--- let y = 1 + 2 * 3 ---")
println(compile_and_show("let y = 1 + 2 * 3"))

// Test 3: Function definition
println("--- fn double(x) = x * 2 ---")
println(compile_and_show("fn double(x) = x * 2"))

// Test 4: Function call
println("--- fn add(a,b) = a + b  /  let r = add(1,2) ---")
println(compile_and_show("fn add(a, b) = a + b\nlet r = add(1, 2)"))

// Test 5: Pipe
println("--- 5 |> double ---")
println(compile_and_show("5 |> double"))

// Test 6: If expression
println("--- if true { 1 } else { 2 } ---")
println(compile_and_show("if true { 1 } else { 2 }"))

// Test 7: List
println("--- [1, 2, 3] ---")
println(compile_and_show("[1, 2, 3]"))

println("=== Lux compiles Lux ===")
