=== Phase 15: Ownership Checking ===

--- own used once (OK) ---
consume: (?6) -> ?6
  WHY: fn consume

--- own used twice (error) ---
double_use: (?10) -> ?10
  WHY: fn double_use

--- ref returned (error) ---
leak: (?1) -> ?1
  WHY: fn leak

--- ref used, not returned (OK) ---
measure: (?1) -> Int
  WHY: fn measure

--- inferred (default ref, no error) ---
double: (Int) -> Int
  WHY: fn double

--- own + !Alloc ---
dsp: (Int) -> Int
  WHY: fn dsp

--- own never used (hint) ---
ignore: (?1) -> Int
  WHY: fn ignore

--- ref in branch return (error) ---
maybe_leak: (Int, Bool) -> Int
  WHY: fn maybe_leak

=== Ownership checking complete ===
