// Test the 8 new prelude functions

// zip
let zipped = zip([1, 2, 3], ["a", "b", "c"])
println("zip: " ++ to_string(zipped))

// find
let found = find(|x| x > 3, [1, 2, 3, 4, 5])
let not_found = find(|x| x > 10, [1, 2, 3])
println("find >3: " ++ to_string(found))
println("find >10: " ++ to_string(not_found))

// partition
let parts = partition(|x| x % 2 == 0, [1, 2, 3, 4, 5, 6])
println("partition evens: " ++ to_string(parts))

// range_inclusive
let ri = range_inclusive(1, 5)
println("range_inclusive(1,5): " ++ to_string(ri))

// intersperse
let inter = intersperse(0, [1, 2, 3, 4])
println("intersperse 0: " ++ to_string(inter))

// scan
let scanned = scan([1, 2, 3, 4], 0, |acc, x| acc + x)
println("scan +: " ++ to_string(scanned))

// compose
let double_then_add1 = compose(|x| x + 1, |x| x * 2)
println("compose (x+1).(x*2) at 5: " ++ to_string(double_then_add1(5)))

// id
println("id(42): " ++ to_string(id(42)))
