// Lexer self-test — through the Test effect
import test
import compiler/lexer

fn test_char_classification() = {
  expect_true(is_digit("0"))
  expect_true(is_digit("9"))
  expect_false(is_digit("a"))
  expect_true(is_alpha("a"))
  expect_true(is_alpha("Z"))
  expect_true(is_alpha("_"))
  expect_false(is_alpha("0"))
}

fn test_keywords() = {
  expect_eq(keyword_type("fn"), "Fn")
  expect_eq(keyword_type("let"), "Let")
  expect_eq(keyword_type("if"), "If")
  expect_eq(keyword_type("else"), "Else")
  expect_eq(keyword_type("match"), "Match")
  expect_eq(keyword_type("true"), "True")
  expect_eq(keyword_type("false"), "False")
  expect_eq(keyword_type("foo"), "Ident")
}

fn test_lex_simple() = {
  let tokens = lex("let x = 42")
  let (t0, _, _, _) = tokens[0]
  let (t1, v1, _, _) = tokens[1]
  let (t2, _, _, _) = tokens[2]
  let (t3, v3, _, _) = tokens[3]
  expect_eq(t0, "Let")
  expect_eq(t1, "Ident")
  expect_eq(v1, "x")
  expect_eq(t2, "Eq")
  expect_eq(t3, "Int")
  expect_eq(v3, "42")
}

fn test_lex_string() = {
  let tokens = lex("\"hello world\"")
  let (typ, val, _, _) = tokens[0]
  expect_eq(typ, "String")
  expect_eq(val, "hello world")
}

fn test_lex_operators() = {
  let tokens = lex("== != <= >= -> => ++ |> && ||")
  let (t0, _, _, _) = tokens[0]
  let (t1, _, _, _) = tokens[1]
  let (t2, _, _, _) = tokens[2]
  let (t3, _, _, _) = tokens[3]
  let (t4, _, _, _) = tokens[4]
  let (t5, _, _, _) = tokens[5]
  expect_eq(t0, "EqEq")
  expect_eq(t1, "BangEq")
  expect_eq(t2, "LtEq")
  expect_eq(t3, "GtEq")
  expect_eq(t4, "Arrow")
  expect_eq(t5, "FatArrow")
}

fn test_lex_function() = {
  let tokens = lex("fn add(x, y) = x + y")
  let (t0, _, _, _) = tokens[0]
  expect_eq(t0, "Fn")
}

fn test_lex_float() = {
  let tokens = lex("3.14")
  let (typ, val, _, _) = tokens[0]
  expect_eq(typ, "Float")
  expect_eq(val, "3.14")
}

fn test_lex_comment() = {
  let tokens = lex("let x = 1 // this is a comment\nlet y = 2")
  let (t0, _, _, _) = tokens[0]
  let (t4, _, _, _) = tokens[4]
  let (t5, _, _, _) = tokens[5]
  expect_eq(t0, "Let")
  expect_eq(t4, "Newline")
  expect_eq(t5, "Let")
}

fn test_line_tracking() = {
  let tokens = lex("a\nb")
  let (_, _, line1, _) = tokens[0]
  let (_, _, line2, _) = tokens[2]
  expect_eq(line1, 1)
  expect_eq(line2, 2)
}

println("=== Lexer Self-Test ===")
run_tests([
  ("char_classification", test_char_classification),
  ("keywords", test_keywords),
  ("lex_simple", test_lex_simple),
  ("lex_string", test_lex_string),
  ("lex_operators", test_lex_operators),
  ("lex_function", test_lex_function),
  ("lex_float", test_lex_float),
  ("lex_comment", test_lex_comment),
  ("line_tracking", test_line_tracking),
])
