// Self-test — exercises core Lux features through the Test effect
import test

fn test_arithmetic() = {
  expect_eq(1 + 2, 3)
  expect_eq(3 * 4, 12)
  expect_eq(1.0 + 2.5, 3.5)
  expect_eq(10 % 3, 1)
}

fn test_strings() = {
  expect_eq("hello" ++ " world", "hello world")
  expect_true(starts_with("hello world", "hello"))
}

fn test_lists() = {
  expect_eq(len([1, 2, 3]), 3)
  expect_eq(map(|x| x * 2, [1, 2, 3]), [2, 4, 6])
  expect_eq(filter(|x| x > 2, [1, 2, 3, 4]), [3, 4])
  expect_eq(fold([1, 2, 3], 0, |a, x| a + x), 6)
  expect_eq(sort([3, 1, 2]), [1, 2, 3])
  expect_eq(reverse([1, 2, 3]), [3, 2, 1])
  expect_eq(head([10, 20, 30]), 10)
  expect_eq(tail([10, 20, 30]), [20, 30])
}

fn test_tuples() = {
  let (a, b) = (1, 2)
  expect_eq(a + b, 3)
}

fn test_booleans() = {
  expect_true(true && true)
  expect_true(false || true)
  expect_false(!true)
}

fn test_pipes() = {
  expect_eq([1, 2, 3] |> len, 3)
}

println("=== Lux Self-Test ===")
run_tests([
  ("arithmetic", test_arithmetic),
  ("strings", test_strings),
  ("lists", test_lists),
  ("tuples", test_tuples),
  ("booleans", test_booleans),
  ("pipes", test_pipes),
])
