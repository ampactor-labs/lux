// Crucible 6: Closures with captures
// Proves: captured variables flow through closure objects on the heap.
// Uniform calling convention: every function gets $__closure param.

fn make_adder(n) = {
  let captured_n = n
  fn add(x) = x + captured_n
  add
}
let add5 = make_adder(5)
println("add5(10) = " ++ to_string(add5(10)))
