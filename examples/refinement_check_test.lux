// Test: refinement type solver — compile-time predicate verification

import compiler/check
import compiler/parser
import compiler/lexer
import compiler/codegen
import compiler/solver

fn run_refinement_test(label, source) = {
  let tokens = lex(source)
  let stmts = parse_program(tokens)
  let _ = check_program_with_source(stmts, source)
  println("--- " ++ label ++ " ---")
}

// Test 1: Byte range — 42 should pass, 300 should fail
let _ = run_refinement_test("byte range", "type Byte = Int where 0 <= self && self <= 255\nlet good = 42\nlet bad = 300")

// Test 2: Port range — 8080 should pass
let _ = run_refinement_test("port range", "type Port = Int where 1 <= self && self <= 65535\nlet http = 8080")

// Test 3: Sample range — 0.0 should pass, 1.5 should fail
let _ = run_refinement_test("sample range", "type Sample = Float where -1.0 <= self && self <= 1.0\nlet silence = 0.0\nlet clipped = 1.5")

// Test 4: Variable (non-literal) — should be Unknown, no output
let _ = run_refinement_test("variable", "type Positive = Int where self > 0\nlet a = 5\nlet b = a")

println("refinement tests complete")
