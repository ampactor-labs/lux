// Ownership Checking — Phase 15 Golden Tests
// Tests own/ref enforcement through the self-hosted checker.

import compiler/check

println("=== Phase 15: Ownership Checking ===")
println("")

// ── Test 1: own param used once — OK ──────────────────────
println("--- own used once (OK) ---")
println(check_and_explain('
fn consume(own data) = push(data, 99)
', "consume", 0))
println("")

// ── Test 2: own param used twice — error ──────────────────
println("--- own used twice (error) ---")
println(check_and_explain('
fn double_use(own data) = push(data, push(data, 1))
', "double_use", 0))
println("")

// ── Test 3: ref param returned — error ────────────────────
println("--- ref returned (error) ---")
println(check_and_explain('
fn leak(ref data) = data
', "leak", 0))
println("")

// ── Test 4: ref param used but not returned — OK ──────────
println("--- ref used, not returned (OK) ---")
println(check_and_explain('
fn measure(ref data) = len(data)
', "measure", 0))
println("")

// ── Test 5: inferred param — no restrictions ──────────────
println("--- inferred (default ref, no error) ---")
println(check_and_explain('
fn double(x) = x + x
', "double", 0))
println("")

// ── Test 6: own + !Alloc together ─────────────────────────
println("--- own + !Alloc ---")
println(check_and_explain('
fn dsp(own sample) with !Alloc = sample * 0.8
', "dsp", 0))
println("")

// ── Test 7: own never used — teaching hint ────────────────
println("--- own never used (hint) ---")
println(check_and_explain('
fn ignore(own data) = 42
', "ignore", 0))
println("")

// ── Test 8: ref in if-branch return — error ───────────────
println("--- ref in branch return (error) ---")
println(check_and_explain('
fn maybe_leak(ref data, flag) = if flag { data } else { 0 }
', "maybe_leak", 0))
println("")

println("=== Ownership checking complete ===")
