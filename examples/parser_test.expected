=== ADT Parser Test ===
let x = 42        => [LetStmt("x", IntLit("42"))]
1 + 2 * 3          => [ExprStmt(BinOp("Add", IntLit("1"), BinOp("Mul", IntLit("2"), IntLit("3"))))]
f(1, 2)            => [ExprStmt(Call(VarRef("f"), [IntLit("1"), IntLit("2")]))]
if x 1 else.. => [ExprStmt(IfExpr(VarRef("x"), IntLit("1"), IntLit("2")))]
fn add(a, b)..     => [FnStmt("add", ["a", "b"], BinOp("Add", VarRef("a"), VarRef("b")), [])]
f(g(1))            => [ExprStmt(Call(VarRef("f"), [Call(VarRef("g"), [IntLit("1")])]))]
[1, 2, 3]          => [ExprStmt(ListExpr([IntLit("1"), IntLit("2"), IntLit("3")]))]
true               => [ExprStmt(BoolLit(true))]
-x                 => [ExprStmt(UnaryOp("Neg", VarRef("x")))]
()                 => [ExprStmt(TupleExpr([]))]

Lux parsing itself. ADTs typing their own AST. One type system.
