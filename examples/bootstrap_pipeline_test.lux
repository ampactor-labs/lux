import compiler/parser
import compiler/codegen

println("=== Full Bootstrap Pipeline ===")
println("Step 1: Compile all modules...")

let lx = load_chunk(compile(read_file("std/compiler/lexer.lux")))
lx()
println("  lexer ok")

let px = load_chunk(compile(read_file("std/compiler/parser.lux")))
px()
println("  parser ok")

let cx = load_chunk(compile(read_file("std/compiler/codegen.lux")))
cx()
println("  codegen ok")

println("")
println("Step 2: Self-hosted pipeline compile + execute...")

let source = "println(2 + 3)"
println("  source: " ++ source)
let chunk = compile(source)
println("  compiled: " ++ to_string(chunk))
let program = load_chunk(chunk)
println("  loaded!")
print("  output: ")
program()

println("")
println("=== LUX COMPILING LUX ===")
