// cursor_transport.nx — Hμ.cursor.transport peer handle
//
// Routes `cursor_default`'s `CursorView` projection through a
// transport handler to a human-facing surface. The kernel-projection-
// to-human loop closes here. Per Hμ-cursor.md §10: surfacing cadence
// (real-time / idle-debounced / on-save / on-explicit-ask) is a
// transport handler choice; the kernel substrate is invariant.
//
// Anchor 0 dream code. The wheel is the canonical; the seed
// transcribes after first-light-L1 per Tier 3 growth pattern
// (Hβ-bootstrap.md §12.5). Verification is by simulation, walkthrough,
// and audit, not compilation.
//
// Anchor 4 — build the wheel; never wrap the axle. This file IS the
// wheel-side authoring of cursor_transport. lux3.wasm is not the
// arbiter.
//
// Anchor 5 — if it needs to exist, it's a handler. Every transport is
// a handler on the same Surface effect; swap the handler, swap the
// surface, same kernel underneath. Inka solves Inka's IDE problem
// because the medium IS the editor.
//
// Composition tally — every read is from substrate that exists today:
//
//   cursor_at / cursor_argmax / cursor_pinned  — src/cursor.nx Cursor effect
//   CursorView fields (8 aspects of one read)  — src/types.nx
//   wasi_fs / fd_write / fd_read               — lib/runtime/wasi.nx + io.nx
//   Iterate effect for streamed updates        — lib/prelude.nx
//   <~ feedback at the human boundary           — primitive #3 (Five verbs)
//
// Drift-mode audit per CLAUDE.md ⌁ + nine modes:
//
//   Drift 1 (vtable):       Surface effect dispatches via @resume=OneShot
//                           handler; no fn-pointer table; no vtable.
//   Drift 2 (env frame):    Transport state lives in handler.with state,
//                           NOT a parallel env-frame stack.
//   Drift 3 (Python dict):  RenderState is a typed record; no string
//                           keys for fields.
//   Drift 4 (MTL):          One transport-handler chain (~>); not
//                           stacked single-concern wrappers per surface.
//   Drift 5 (split state):  Buffer + cursor + cadence fold into one
//                           TransportState record; not parallel slots.
//   Drift 6 (special):      Terminal AND LSP AND web AND vim are FOUR
//                           handler arms on the SAME effect; no Bool-
//                           special-case for "primary surface."
//   Drift 7 (parallel arr): RenderSlot is one record-shape walked once
//                           by the renderer; no per-aspect arrays.
//   Drift 8 (string flag):  Cadence is a tagged Cadence ADT, not a
//                           string ("realtime" / "debounced" / ...).
//   Drift 9 (deferred):     Every transport arm bodied; no "later".
//                           Web-WASM substrate is a separate handle
//                           (Hμ.cursor.transport.web) for Tier 3 +
//                           browser-WASM compile.

import types
import effects
import cursor
import mentl
import mentl_voice

// ─── The Surface effect ─────────────────────────────────────────────
//
// One effect; four canonical handlers. Each handler renders the
// CursorView for its target surface. The Surface effect is HOW the
// medium speaks to the human — every IDE, LSP, terminal hover,
// browser-WASM editor, vim plugin routes through here.

effect Surface {
  /// Render the eight-aspect CursorView at the cursor's position.
  /// Called whenever Cursor's argmax shifts (graph delta + caret
  /// change). Cadence is the transport's responsibility.
  surface_render(Cursor, CursorView) -> ()         @resume=OneShot

  /// Receive an action from the human — accept, defer, override,
  /// caret-move. The transport translates input events into Action
  /// values; the kernel reads them through the same effect.
  surface_action() -> Action                        @resume=OneShot

  /// Negotiate transport readiness (handshake; LSP-style for IDEs;
  /// no-op for terminal). Called once per session.
  surface_handshake() -> ()                         @resume=OneShot
}

// ─── ADTs the transport reads + writes ──────────────────────────────

/// What the human can do at a Cursor's surfaced proposal. The four
/// arms are exhaustive per Hμ-cursor.md §5.3:
///
///   Accept  — apply the gradient_next suggestion; commit the patch
///   Defer  — skip; cursor advances to next argmax
///   Override(span) — pin cursor to user-chosen position (`??`)
///   CaretMove(span) — text-caret moved; argmax may shift

type Action
  = AccAccept
  | AccDefer
  | AccOverride(Span)
  | AccCaretMove(Span)

/// Cadence — when the transport surfaces Cursor updates.
/// Drift 8 closure: tagged ADT, not string flag.

type Cadence
  = CadRealtime                  // every keystroke
  | CadDebounced(Int)            // ms idle pause threshold
  | CadOnSave                    // explicit save events
  | CadOnAsk                     // user invokes "what's next?"

/// Default cadence per Hμ-cursor.md §10.4: ~250ms idle-debounced.
fn default_cadence() with Pure = CadDebounced(250)

// ─── TransportState — one record-shape carried by all handlers ──────
//
// Drift 5 + Drift 7 closure: caret + cursor + cadence + buffer fold
// into ONE record. No parallel arrays of {names, spans, ...}.

type TransportState
  = TransportState({
      caret:        Caret,             // user's text-attention
      cursor:       Cursor,            // gradient argmax (cached read)
      cadence:      Cadence,           // surfacing strategy
      session_id:   Int,               // monotonically incrementing
      last_render:  Reason              // why-chain of last surfaced view
    })

fn transport_state_init(initial_caret) with Pure = TransportState({
  caret:       initial_caret,
  cursor:      Cursor(0, Inferred("session-init"), 0.0),
  cadence:     default_cadence(),
  session_id:  0,
  last_render: Inferred("none")
})

// ─── terminal_transport — text-mode rendering ───────────────────────
//
// The simplest transport: reads CursorView, writes ANSI-formatted
// text to fd 1 (stdout). Used by `inka teach`, `inka query`, and
// terminal-only sessions. Eight-tentacle voice surfaces as labeled
// blocks; cadence default = on-explicit-ask (CLI is interactive).

handler terminal_transport with state = transport_state_init(Caret(0, Inferred("term-init"))) {

  surface_handshake() => {
    perform write_stdout("Mentl @ inka teach — eight tentacles ready.\n")
    resume()
  },

  surface_render(cursor, view) => {
    let CursorView(query, propose, topology, row, trace, verify, teach, why) = view
    perform write_stdout("Mentl @ ")
    perform write_stdout(show_handle_label(cursor))
    perform write_stdout("\n────────────────────────────────────────────\n")
    perform write_stdout("Query    │ ")
    perform write_stdout(show_node_kind(query))
    perform write_stdout("\nPropose  │ ")
    perform write_stdout(show_proposals(propose))
    perform write_stdout("\nTopology │ ")
    perform write_stdout(show_pipe_context(topology))
    perform write_stdout("\nRow      │ ")
    perform write_stdout(show_effrow(row))
    perform write_stdout("\nTrace    │ ")
    perform write_stdout(show_ownership(trace))
    perform write_stdout("\nVerify   │ ")
    perform write_stdout(show_verify_count(verify))
    perform write_stdout("\nTeach    │ ")
    perform write_stdout(show_suggestion(teach))
    perform write_stdout("\nWhy      │ ")
    perform write_stdout(show_reason(why))
    perform write_stdout("\n")
    resume() with state = state_with_render(state, cursor)
  },

  surface_action() => {
    // Terminal: read one line from stdin; parse to Action.
    let line = perform read_stdin_line()
    let action = parse_action(line)
    resume(action)
  }
}

// ─── lsp_transport — JSON-RPC over stdio for IDE integration ────────
//
// One handler; one effect; the entire LSP protocol falls out as a
// projection of CursorView through JSON-RPC framing per
// `lib/runtime/lsp_frame.nx`. Drift 4 closure: NOT an LSP framework
// wrapping the kernel; the kernel's CursorView IS the protocol payload.

handler lsp_transport with state = transport_state_init(Caret(0, Inferred("lsp-init"))) {

  surface_handshake() => {
    let init_msg = lsp_initialize_response()
    perform lsp_frame_write(init_msg)
    resume()
  },

  surface_render(cursor, view) => {
    let CursorView(query, propose, topology, row, trace, verify, teach, why) = view
    let payload = lsp_textDocument_publishDiagnostics(cursor, view)
    perform lsp_frame_write(payload)
    // Hover / inlay-hint payloads: each tentacle becomes one
    // LSP message. The eight-aspect read maps directly to the
    // eight LSP methods that surface them.
    perform lsp_frame_write(lsp_textDocument_hover(cursor, query, why))
    perform lsp_frame_write(lsp_textDocument_codeAction(cursor, propose))
    perform lsp_frame_write(lsp_workspace_diagnostic(verify))
    resume() with state = state_with_render(state, cursor)
  },

  surface_action() => {
    let frame = perform lsp_frame_read()
    let action = lsp_frame_to_action(frame)
    resume(action)
  }
}

// ─── web_transport — browser-WASM playground (inka edit canonical) ──
//
// Per IE-inka-edit.md §0: `inka edit` is the canonical Inka IDE; the
// browser-WASM compile is the lowest-friction path between thought
// and Inka. Surface events flow through DOM bindings to WASI shims;
// rendering goes through canvas / DOM layout per the Holographic
// Lens design (IE §0.c).

handler web_transport with state = transport_state_init(Caret(0, Inferred("web-init"))) {

  surface_handshake() => {
    perform web_dom_init("inka-edit-root")
    perform web_register_keystroke_listener()
    resume()
  },

  surface_render(cursor, view) => {
    // The Holographic Lens IS the eight-tentacle voice in browser
    // form. Each CursorView field projects to one DOM region; ghost-
    // text for proposals; inline annotation for teach; reason chain
    // shown on hover.
    perform web_dom_render_cursorview(cursor, view)
    resume() with state = state_with_render(state, cursor)
  },

  surface_action() => {
    let event = perform web_next_input_event()
    let action = web_event_to_action(event)
    resume(action)
  }
}

// ─── vim_transport — vim-compatible terminal IDE plugin ─────────────
//
// vim users get the medium through their existing surface. Same effect,
// different transport. Ghost-text via Neovim's virtual text API;
// eight-tentacle voice in the cmdline; ?? at cursor invokes Synth.

handler vim_transport with state = transport_state_init(Caret(0, Inferred("vim-init"))) {

  surface_handshake() => {
    perform vim_register_neovim_rpc()
    resume()
  },

  surface_render(cursor, view) => {
    let CursorView(query, propose, topology, row, trace, verify, teach, why) = view
    perform vim_set_virtual_text(cursor.handle, format_inline(teach))
    perform vim_set_signs(verify)
    perform vim_echo_at_cmdline(format_voice_line(view))
    resume() with state = state_with_render(state, cursor)
  },

  surface_action() => {
    let key = perform vim_next_key()
    let action = vim_key_to_action(key)
    resume(action)
  }
}

// ─── The bus-compressor loop — `<~` at the human boundary ───────────
//
// Per Hμ-cursor.md §3.4 + ULTIMATE_MEDIUM.md §3.4: the kernel's
// primitive #3 (five verbs) describes the medium's own editing
// model. The cursor-transport loop IS `<~` applied at the human-
// medium boundary. Pipe verbs are visible on the page; the loop
// is visible in the substrate.

fn cursor_session(initial_caret) with Surface + GraphRead + Cursor + !Mutate = {
  perform surface_handshake()
  let initial_state = transport_state_init(initial_caret)
  cursor_loop(initial_state)
}

fn cursor_loop(state) with Surface + GraphRead + Cursor + !Mutate = {
  let TransportState(s) = state
  // Compute Cursor: gradient argmax with caret bias.
  let cursor = perform cursor_argmax(s.caret)
  // Project the eight-aspect CursorView at the cursor's position.
  let view = perform cursor_at(span_of_cursor(cursor))
  // Render through the installed transport handler.
  perform surface_render(cursor, view)
  // Receive an action from the human.
  let action = perform surface_action()
  // Apply action; continue the loop unless explicitly halted.
  match action {
    AccAccept => {
      apply_suggestion(view)
      cursor_loop(state_advance(state, cursor))
    },
    AccDefer => cursor_loop(state_advance(state, cursor)),
    AccOverride(span) => {
      let pinned = perform cursor_pinned(handle_at_span(span))
      cursor_loop(state_with_caret(state, Caret(handle_at_span(span),
                                                Inferred("?? override"))))
    },
    AccCaretMove(span) =>
      cursor_loop(state_with_caret(state, Caret(handle_at_span(span),
                                                Inferred("text-caret-move"))))
  }
}

// ─── Helpers ────────────────────────────────────────────────────────

fn state_advance(state, latest_cursor) with Pure = {
  let TransportState(s) = state
  let Cursor(_, reason, _) = latest_cursor
  TransportState({
    caret:       s.caret,
    cursor:      latest_cursor,
    cadence:     s.cadence,
    session_id:  s.session_id + 1,
    last_render: reason
  })
}

fn state_with_render(state, cursor) with Pure = {
  let TransportState(s) = state
  let Cursor(_, reason, _) = cursor
  TransportState({
    caret:       s.caret,
    cursor:      cursor,
    cadence:     s.cadence,
    session_id:  s.session_id,
    last_render: reason
  })
}

fn state_with_caret(state, new_caret) with Pure = {
  let TransportState(s) = state
  TransportState({
    caret:       new_caret,
    cursor:      s.cursor,
    cadence:     s.cadence,
    session_id:  s.session_id + 1,
    last_render: s.last_render
  })
}

fn span_of_cursor(cursor) with GraphRead = {
  let Cursor(handle, _, _) = cursor
  perform graph_span_of(handle)
}

fn handle_at_span(span) with GraphRead = perform graph_handle_at_span(span)

fn apply_suggestion(view) with GraphRead + !Mutate = {
  let CursorView(_, _, _, _, _, _, teach, _) = view
  match teach {
    None => (),
    Some(suggestion) => {
      let AnnotationSuggestion(_kind, ann_text, _unlocks, _reason) = suggestion
      // Apply the patch via the parser's incremental edit substrate.
      // Hμ.cursor.cache invalidates the affected oracle_queue entry;
      // the next cursor_argmax recomputes against the new graph.
      perform apply_patch_at_cursor(ann_text)
    }
  }
}

// ─── Format / parse helpers per transport ──────────────────────────

fn show_handle_label(cursor) with Pure = {
  let Cursor(handle, _, _) = cursor
  "handle=" |> str_concat(int_to_str(handle))
}

fn show_node_kind(kind) with Pure = match kind {
  NBound(_) => "bound",
  NFree(_) => "free",
  NRowBound(_) => "row-bound",
  NRowFree(_) => "row-free",
  NErrorHole(_) => "error-hole"
}

fn show_proposals(props) with Pure =
  if props.len == 0 { "(none)" }
  else { int_to_str(props.len) |> str_concat(" candidate(s)") }

fn show_pipe_context(ctx) with Pure = match ctx {
  NoPipe => "(none)",
  InsidePipe(pk) => "inside " |> str_concat(show_pipe_kind(pk)),
  StartingPipe => "starts pipe",
  EndingPipe => "ends pipe"
}

fn show_verify_count(preds) with Pure =
  if preds.len == 0 { "no obligations" }
  else { int_to_str(preds.len) |> str_concat(" pending") }

fn show_suggestion(opt) with Pure = match opt {
  None => "(no next-step)",
  Some(suggestion) => {
    let AnnotationSuggestion(_, ann_text, unlocks, _) = suggestion
    "add `" |> str_concat(ann_text)
            |> str_concat("` to unlock ")
            |> str_concat(int_to_str(unlocks.len))
            |> str_concat(" capability(ies)")
  }
}

fn parse_action(line) with Pure =
  if str_eq(line, "y") { AccAccept }
  else if str_eq(line, "n") { AccDefer }
  else { AccDefer }

fn format_inline(teach_opt) with Pure = match teach_opt {
  None => "",
  Some(suggestion) => {
    let AnnotationSuggestion(_, ann_text, _, _) = suggestion
    " ⟜ " |> str_concat(ann_text)
  }
}

fn format_voice_line(view) with Pure = {
  let CursorView(_, _, _, _, _, _, teach, _) = view
  show_suggestion(teach)
}

// ─── Effect declarations consumed by transport handlers ─────────────
//
// These effects compose on the existing kernel + lib/runtime substrate.
// Each transport handler is a peer-handle that lands as substrate
// when its target surface is exercised in production.

effect WebSurface {
  web_dom_init(String) -> ()                         @resume=OneShot
  web_register_keystroke_listener() -> ()            @resume=OneShot
  web_dom_render_cursorview(Cursor, CursorView) -> () @resume=OneShot
  web_next_input_event() -> WebEvent                  @resume=OneShot
}

effect VimSurface {
  vim_register_neovim_rpc() -> ()                       @resume=OneShot
  vim_set_virtual_text(Handle, String) -> ()             @resume=OneShot
  vim_set_signs(List<Predicate>) -> ()                  @resume=OneShot
  vim_echo_at_cmdline(String) -> ()                      @resume=OneShot
  vim_next_key() -> Int                                  @resume=OneShot
}

effect LspSurface {
  lsp_frame_read() -> LspFrame                            @resume=OneShot
  lsp_frame_write(LspFrame) -> ()                          @resume=OneShot
}

effect Patch {
  apply_patch_at_cursor(String) -> ()                      @resume=OneShot
}

// ─── patch_echo — first-land Patch handler ──────────────────────────
//
// The substrate-honest minimum: action received → surface notified →
// developer sees what the loop would apply. Per primitive #2, the
// chain composes; per Anchor 4, the wheel is built; the handler IS
// the surface for "apply this annotation."
//
// Full source-file rewrite (open file at cursor's reason-chain Located
// span; splice annotation text before the line; write back; trigger
// IC re-inference via graph_mutated) is the named follow-up
// `Hμ.cursor.transport.patch-to-file`. That handle composes with
// cursor_cache_default's invalidation walk: applying a patch performs
// graph_mutated; cached_check_with_oracle's arm re-infers the affected
// modules; the next cursor_argmax reads the refreshed oracle_queue.
// Until it lands, `patch_echo` is the substrate-correct stand-in:
// the action reaches the surface; the medium responds.
//
// Drift 9 closure: the handler IS bodied; the deferred work is named
// in positive form as a peer follow-up, not a "for now" hedge.

handler patch_echo {
  apply_patch_at_cursor(text) => {
    eprint_string("[inka edit] would apply: ")
    eprint_string(text)
    eprint_string("\n")
    resume()
  }
}

// ─── ADTs the transport surface uses ────────────────────────────────

type WebEvent
  = WebKeystroke(String)
  | WebMouseMove(Int, Int)
  | WebSelection(Span)
  | WebHoverEnd

type LspFrame
  = LspFrame(String, String)   // method, json-payload

// ─── Bridges (declared; bodies land in transport-specific peers) ────

fn lsp_initialize_response() with Pure = LspFrame("initialize", "{}")

fn lsp_textDocument_publishDiagnostics(cursor, view) with Pure = {
  let CursorView(_, _, _, _, _, verify, _, _) = view
  LspFrame("textDocument/publishDiagnostics", show_verify_count(verify))
}

fn lsp_textDocument_hover(cursor, query, why) with Pure =
  LspFrame("textDocument/hover", show_node_kind(query))

fn lsp_textDocument_codeAction(cursor, propose) with Pure =
  LspFrame("textDocument/codeAction", show_proposals(propose))

fn lsp_workspace_diagnostic(verify) with Pure =
  LspFrame("workspace/diagnostic", show_verify_count(verify))

fn lsp_frame_to_action(frame) with Pure = {
  let LspFrame(method, _) = frame
  if str_eq(method, "textDocument/didChange") { AccCaretMove(span_zero()) }
  else if str_eq(method, "textDocument/codeAction/resolve") { AccAccept }
  else { AccDefer }
}

fn web_event_to_action(event) with Pure = match event {
  WebKeystroke(_) => AccCaretMove(span_zero()),
  WebMouseMove(_, _) => AccDefer,
  WebSelection(span) => AccCaretMove(span),
  WebHoverEnd => AccDefer
}

fn vim_key_to_action(key) with Pure =
  if key == 13 { AccAccept }       // Enter
  else if key == 27 { AccDefer }   // Esc
  else { AccDefer }
