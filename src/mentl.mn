// mentl.mn — the teaching substrate · the oracle (spec 09)
//
// Not a feature. The thesis made flesh. Eight tentacles on the
// shared inference substrate, each a handler reading through
// GraphRead + EnvRead. Distributed cognition over one graph;
// the mascot is an octopus because the architecture IS octopus
// neurology — local reasoning, shared nervous system.
//
// The oracle loop (DESIGN.md Ch 8 · spec 09):
//   graph_push_checkpoint()
//     → apply tentative annotation via graph_bind / graph_bind_row
//     → run inference, run Verify
//     → graph_rollback(checkpoint)
//     → return a PROVEN candidate patch (not a guess)
//
// Synth is peer-handler fall-through: enumerative / SMT / LLM / user,
// each a ~> stage. The compiler verifies; proposers merely propose.
// AI obsolescence is mechanism, not rhetoric: proposers are handlers
// on an effect the compiler exposes.

import types
import graph
import effects

// Mentl-owned ADTs

/// Each variant carries an Option(Span) — Some when the candidate
/// originated from a user site (hovered hole, quick-fix request);
/// None for fully-internal speculation. narrow_row threads this into
/// the Located reason so the Why chain reads at the user's
/// coordinates, not 0:0-0:0.
type Annotation
  = APure(Option)
  | ANotAlloc(Option)
  | ANotIO(Option)
  | ANotNetwork(Option)
  | ARefined(String, Predicate, Option)
  | AOwn(String, Option)
  | ARef(String, Option)
  | AWrapHandler(String, Int, Option)
                              // handler_name, target_fn_handle, span;
                              // proposes wrapping the target's body in a
                              // handler that absorbs an offending effect

type Capability
  = CMemoize
  | CParallelize
  | CCompileTimeEval
  | CRealTime
  | CSandbox
  | CEliminateBoundsCheck
  | CZeroCopy
  | CDeterministicDrop

type Patch
  = Patch(Span, String)     // span to replace, new text

type Explanation
  = Explanation(
      String,     // code: E_MissingVariable, V_Pending, W_Suggestion, …
      String,     // canonical_md: docs/errors/<code>.md
      String,     // summary: one-line human-readable
      Option,     // fix: Option(Patch) when MachineApplicable
      Reason      // reason_chain: the Why chain
    )

type Context
  = Context(List, List)   // scope bindings, active effects

type Candidate
  = Candidate(Node, Reason)  // AST fragment + why it was proposed

/// Teach effect — the five tentacle entry points (DESIGN.md Ch 8). `mentl_default`
/// projects the substrate for the developer: hover, gradient, why-chain, error catalog,
/// unlock preview.
effect Teach {
  teach_here(String, Span, Ty) -> ()                @resume=OneShot
  teach_gradient(Int) -> Option                     @resume=OneShot
  teach_why(Int) -> Reason                          @resume=OneShot
  teach_error(String, Span, Reason) -> Explanation  @resume=OneShot
  teach_unlock(Annotation) -> Capability            @resume=OneShot
}

// ═══ Synth effect — proposers as handlers ══════════════════════════  // drift-audit: ignore — D.1.R reserved block; decoration removal is a separate sub-handle
// Three ops: propose (main), verify_candidate (Mentl-internal),
// enumerate_inhabitants (multi-shot raw). Any proposer — enumerative,
// SMT, LLM, user — plugs in as a handler. The compiler verifies.

effect Synth {
  propose(Ty, EffRow, Context) -> List               @resume=OneShot
  verify_candidate(Node) -> Bool                     @resume=OneShot
  enumerate_inhabitants(Ty, EffRow, Context) -> List @resume=MultiShot
}

/// Default Teach handler — the substrate's self-projection. Reads the graph through
/// GraphRead. Accumulates `teach_here` entries so the driver renders them as hover info.
/// Gradient and why use the speculative oracle and reason DAG respectively.
handler mentl_default with annotations = [] {

  teach_here(name, span, ty) =>
    resume()
      with annotations = [(name, span, ty)] ++ annotations,

  teach_gradient(handle) =>
    resume(gradient_next(handle)),

  teach_why(handle) =>
    resume(why_from_handle(handle)),

  teach_error(code, span, reason) =>
    resume(Explanation(
      code,
      "docs/errors/" |> str_concat(code) |> str_concat(".md"),
      catalog_summary(code),
      None,
      reason
    )),

  teach_unlock(annotation) =>
    resume(unlock_capability(annotation))
}

/// Speculative oracle: for each candidate annotation, checkpoint → tentative apply →
/// run unification → record → rollback. Only PROVEN annotations reach the user.
/// The trail (graph.mn) makes the run O(M) where M = mutations recorded.
///
/// Returns Option<AnnotationSuggestion> per Hμ.cursor §2 + GR §3.2 (live).
/// Internally pick_highest_leverage produces Option<(Annotation, Capability)>;
/// `to_annotation_suggestion` wraps at the boundary with kind / annotation
/// text / unlocked-capability labels / Reason — the public shape Cursor
/// reads off CursorView.teach.
fn gradient_next(handle) = {
  let node = perform graph_chase(handle)
  let GNode(_, anchor_reason) = node
  let GNode(kind, _) = node
  match kind {
    NBound(ty) => match ty {
      TFun(params, _ret, _row) => {
        let base_candidates = [APure(None), ANotAlloc(None), ANotIO(None), ANotNetwork(None)]
        let param_candidates = ownership_candidates(params)
        let all = base_candidates ++ param_candidates
        let proven = try_each_annotation(handle, all, ty)
        match pick_highest_leverage(proven) {
          None => None,
          Some(pair) => {
            let (ann, _cap) = pair
            Some(to_annotation_suggestion(ann, anchor_reason))
          }
        }
      },
      _ => None
    },
    _ => None
  }
}

/// Boundary wrap — (Annotation, Capability) inside the speculative
/// loop becomes the public AnnotationSuggestion shape Cursor reads.
/// Per Hμ.cursor §2.1: kind comes from the Annotation tag (drift 8 —
/// SuggestionKind ADT, never a string flag); annotation text is
/// `show_annotation`'s residue; unlocks is `capabilities_for_annotation`'s
/// list (multiple capabilities per annotation, not the lossy single
/// `unlock_capability`); reason wraps the anchor with Located.
fn to_annotation_suggestion(ann, anchor_reason) = {
  AnnotationSuggestion(
    suggestion_kind_of(ann),
    show_annotation(ann),
    capability_labels(capabilities_for_annotation(ann)),
    suggestion_reason(ann, anchor_reason)
  )
}

/// Map an Annotation variant to its SuggestionKind axis. Drift 8
/// closure: SuggestionKind is the tagged dispatch surface; the
/// match below is the only place the mapping lives.
fn suggestion_kind_of(ann) with Pure = match ann {
  APure(_)              => SuggestEffectRow,
  ANotAlloc(_)          => SuggestEffectRow,
  ANotIO(_)             => SuggestEffectRow,
  ANotNetwork(_)        => SuggestEffectRow,
  ARefined(_, _, _)     => SuggestRefinement,
  AOwn(_, _)            => SuggestOwnership,
  ARef(_, _)            => SuggestOwnership,
  AWrapHandler(_, _, _) => SuggestEffectRow
}

/// Capability ADT to display label list. Used by AnnotationSuggestion.unlocks.
/// Composition over `show_capability` (already in mentl.mn).
fn capability_labels(caps) with Pure = {
  capability_labels_loop(caps, 0, caps.len, make_list(caps.len), 0)
}

fn capability_labels_loop(caps, i, n, buf, buf_len) with Pure = {
  if i >= n { slice(buf, 0, buf_len) }
  else {
    list_set(buf, buf_len, show_capability(list_index(caps, i)))
    capability_labels_loop(caps, i + 1, n, buf, buf_len + 1)
  }
}

/// Suggestion's Reason edge. Wraps the candidate's anchor reason in a
/// Located/Inferred chain that the Why-tentacle walks. Span comes from
/// the annotation's source-span field when present (user-originated
/// candidate), span_zero otherwise (fully internal speculation).
fn suggestion_reason(ann, anchor) = {
  let span = unwrap_source_span(annotation_source_span(ann))
  Located(span, Inferred(suggestion_kind_label(suggestion_kind_of(ann))))
}

fn annotation_source_span(ann) with Pure = match ann {
  APure(sp)             => sp,
  ANotAlloc(sp)         => sp,
  ANotIO(sp)            => sp,
  ANotNetwork(sp)       => sp,
  ARefined(_, _, sp)    => sp,
  AOwn(_, sp)           => sp,
  ARef(_, sp)           => sp,
  AWrapHandler(_, _, sp) => sp
}

fn suggestion_kind_label(k) with Pure = match k {
  SuggestEffectRow   => "gradient: effect-row tightening",
  SuggestOwnership   => "gradient: ownership marker",
  SuggestRefinement  => "gradient: refinement predicate",
  SuggestReturnType  => "gradient: result-type annotation"
}

/// Try each candidate: checkpoint → tentative apply → verify → rollback.
/// Returns [(Annotation, Capability)] for annotations that passed.
fn try_each_annotation(handle, candidates, base_ty) = {
  let n = candidates.len
  let buf = make_list(n)
  let proven_len = try_each_annotation_loop(handle, candidates, base_ty, 0, n, buf, 0)
  slice(buf, 0, proven_len)
}

fn try_each_annotation_loop(handle, candidates, base_ty, i, n, buf, buf_len) = {
  if i >= n { buf_len }
  else {
    let ann = list_index(candidates, i)
    let cp = perform graph_push_checkpoint()
    apply_annotation_tentatively(handle, ann, base_ty)
    let ok = verify_after_apply(handle)
    perform graph_rollback(cp)
    if ok {
      list_set(buf, buf_len, (ann, unlock_capability(ann)))
      try_each_annotation_loop(handle, candidates, base_ty, i + 1, n, buf, buf_len + 1)
    } else {
      try_each_annotation_loop(handle, candidates, base_ty, i + 1, n, buf, buf_len)
    }
  }
}

/// Speculative apply: compute the narrowed type/row and graph_bind it.
/// graph_bind is one-write; within a checkpoint, the narrowed bind is
/// recorded in the trail and reverted on rollback.
fn apply_annotation_tentatively(handle, ann, base_ty) = match ann {
  APure(sp)          => narrow_row(handle, base_ty, EfPure, sp),
  ANotAlloc(sp)      => narrow_row(handle, base_ty, EfNeg(mk_ef_closed([ENamed("Alloc")])), sp),    // drift-audit: ignore — real drift 8 (EffName should have EAlloc variant); tracked for item 11.B EffName refactor
  ANotIO(sp)         => narrow_row(handle, base_ty, EfNeg(mk_ef_closed([ENamed("IO")])), sp),       // drift-audit: ignore — real drift 8 (EffName should have EIO variant); tracked for item 11.B EffName refactor
  ANotNetwork(sp)    => narrow_row(handle, base_ty, EfNeg(mk_ef_closed([ENamed("Network")])), sp),  // drift-audit: ignore — real drift 8 (EffName should have ENetwork variant); tracked for item 11.B EffName refactor
  ARefined(_, pred, sp) => {
    // Narrowing the type via refinement — perform verify against the
    // narrowed predicate. Ledger captures; rollback removes.
    let span = unwrap_source_span(sp)
    perform verify(span, pred, Refinement(pred, PTrue))
  },
  AOwn(_, _) => (),    // parameter-level marker; type narrowing at call sites
  ARef(_, _) => (),

  AWrapHandler(handler_name, _target, sp) => {
    // H5: speculatively narrow the row by subtracting the named
    // handler's absorbed effects. The catalog lookup tells us what
    // the handler handles; row arithmetic does the rest. The actual
    // wrap (splice `handle ... with handler_name` around body) is
    // a TEXT patch — out of substrate, into the patcher's surface.
    let absorbed = catalog_handled_effects(handler_name)
    if absorbed.len == 0 { () }
    else {
      let absorbed_row = mk_ef_closed(absorbed)
      // The narrowed row is base_row - absorbed_row.
      match base_ty {
        TFun(_params, _ret, base_row) => {
          let narrowed = diff_row(base_row, absorbed_row)
          narrow_row(handle, base_ty, narrowed, sp)
        },
        _ => ()
      }
    }
  }
}

fn unwrap_source_span(opt) with Pure = match opt {
  Some(s) => s,
  None    => span_zero()
}

/// H5: HandlerCatalog — registry of which compiler-built-in handlers
/// absorb which effects. Today a static table; the full effect-based
/// handler_catalog (with runtime registration) lands when user-level
/// handler discovery is exercised. The catalog enables AWrapHandler
/// proposal: when a body row has an effect E, look up handlers that
/// absorb E, propose the closest match.
fn catalog_handled_effects(handler_name) = {
  if str_eq(handler_name, "mem_bump")    { [ENamed("Alloc")] }         // drift-audit: ignore — static HandlerCatalog table pending substrate replacement; real drift 8 on EffName+handler-name; both tracked for item 11.B EffName refactor + HandlerCatalog runtime registration
  else if str_eq(handler_name, "temp_arena") { [ENamed("Alloc")] }     // drift-audit: ignore — same as above
  else if str_eq(handler_name, "stdout_handler") { [ENamed("IO")] }    // drift-audit: ignore — same as above
  else if str_eq(handler_name, "sandbox_io")    { [ENamed("IO")] }     // drift-audit: ignore — same as above
  else if str_eq(handler_name, "sandbox_net")   { [ENamed("Network")] }
  else { [] }
}

/// H5: capability unlocks for an annotation. !Alloc unlocks
/// CRealTime; !IO + Pure unlock CCompileTimeEval; etc. The list is
/// returned by render_audit's severance section.
fn capabilities_for_annotation(ann) with Pure = match ann {
  APure(_)        => [CMemoize, CCompileTimeEval, CParallelize],
  ANotAlloc(_)    => [CRealTime],
  ANotIO(_)       => [CCompileTimeEval, CSandbox],
  ANotNetwork(_)  => [CSandbox],
  ARefined(_, _, _) => [],
  AOwn(_, _)      => [CDeterministicDrop, CZeroCopy],
  ARef(_, _)      => [],
  AWrapHandler(_, _, _) => []     // unlocks depend on what's wrapped
}

/// H5: capability unlocks for a SEVERANCE — adding `!E` to an fn
/// that doesn't perform E. Mirrors capabilities_for_annotation but
/// keyed by EffName (severance candidate's name).
fn capabilities_for_severance(name) = match name {
  ENamed(n) =>
    if str_eq(n, "Alloc")   { [CRealTime] }                          // drift-audit: ignore — capability-for-severance table; real drift 8 (should match on EAlloc/EIO variants); tracked for item 11.B EffName refactor
    else if str_eq(n, "IO") { [CCompileTimeEval, CSandbox] }          // drift-audit: ignore — same as above
    else if str_eq(n, "Network") { [CSandbox] }
    else { [] },
  EParameterized(_, _) => []
}

fn narrow_row(handle, base_ty, narrow, source_span) = match base_ty {
  TFun(params, ret, _) => {
    let narrowed = TFun(params, ret, narrow)
    // The trail reverts this bind on rollback. source_span is Some(s)
    // when the candidate originated at a user site (hovered hole,
    // quick-fix request); None for fully-internal speculation, in
    // which case we fall back to span_zero(). The Located wrapper
    // gives the Why Engine coordinates to render.
    perform graph_bind(handle, narrowed,
      Located(unwrap_source_span(source_span),
              Inferred("mentl speculative narrow")))
  },
  _ => ()
}

/// Verify after tentative apply: read the target handle's state.
/// A candidate is "proven" if the post-apply handle is NBound (the
/// tentative narrowing stuck cleanly). Failure modes:
///   NErrorHole — occurs check or a structural conflict caused
///                inference to record failure on the handle.
///   NFree     — the apply didn't bind (shouldn't happen for a
///                well-formed apply_annotation_tentatively).
///   row-kind  — handle was a row variable; not a narrow target.
/// The trail-based rollback restores whatever state the handle held
/// before the tentative apply, so this check is non-destructive.
fn verify_after_apply(handle) = {
  let GNode(kind, _) = perform graph_chase(handle)
  match kind {
    NBound(_)     => true,
    NErrorHole(_) => false,
    NFree(_)      => false,
    NRowBound(_)  => false,
    NRowFree(_)   => false
  }
}

fn ownership_candidates(params) = {
  let flat = list_to_flat(params)
  let n = flat.len
  // Each Inferred param yields 2 candidates (AOwn + ARef); buffer
  // sized for the maximum (2n); slice trims to the actual count.
  let buf = make_list(n * 2)
  let filled = ownership_candidates_loop(flat, 0, n, buf, 0)
  slice(buf, 0, filled)
}

fn ownership_candidates_loop(params, i, n, buf, buf_len) = {
  if i >= n { buf_len }
  else {
    let TParam(name, _, _, res) = list_index(params, i)
    match res {
      Inferred => {
        list_set(buf, buf_len, AOwn(name, None))
        list_set(buf, buf_len + 1, ARef(name, None))
        ownership_candidates_loop(params, i + 1, n, buf, buf_len + 2)
      },
      _ => ownership_candidates_loop(params, i + 1, n, buf, buf_len)
    }
  }
}

fn pick_highest_leverage(proven) = {
  if proven.len == 0 { None }
  else {
    let best = find_by_priority(proven,
      [ANotAlloc(None), ANotIO(None), ANotNetwork(None), APure(None)])
    match best {
      Some(_) => best,
      None    => Some(list_index(proven, 0))
    }
  }
}

fn find_by_priority(proven, priorities) = {
  find_by_priority_loop(proven, priorities, 0, priorities.len)
}

fn find_by_priority_loop(proven, priorities, i, n) = {
  if i >= n { None }
  else {
    let target = list_index(priorities, i)
    match find_annotation(proven, target) {
      Some(pair) => Some(pair),
      None       => find_by_priority_loop(proven, priorities, i + 1, n)
    }
  }
}

fn find_annotation(proven, target) = {
  find_annotation_loop(proven, target, 0, proven.len)
}

fn find_annotation_loop(proven, target, i, n) = {
  if i >= n { None }
  else {
    let (ann, cap) = list_index(proven, i)
    if annotation_eq(ann, target) { Some((ann, cap)) }
    else { find_annotation_loop(proven, target, i + 1, n) }
  }
}

/// Span-insensitive: two APure(_) compare equal regardless of source
/// span. Priority comparison classifies by discriminator, not origin.
fn annotation_eq(a, b) with Pure = match a {
  APure(_)       => match b { APure(_)       => true, _ => false },
  ANotAlloc(_)   => match b { ANotAlloc(_)   => true, _ => false },
  ANotIO(_)      => match b { ANotIO(_)      => true, _ => false },
  ANotNetwork(_) => match b { ANotNetwork(_) => true, _ => false },
  ARefined(_, _, _) => match b { ARefined(_, _, _) => true, _ => false },
  AOwn(_, _)     => match b { AOwn(_, _)     => true, _ => false },
  ARef(_, _)     => match b { ARef(_, _)     => true, _ => false }
}

/// Walk the reason DAG from a graph handle. Every unification, instantiation, and
/// subsumption wrote a Reason edge into the graph; `why_expand` recurses through the chain
/// until leaf reasons (Declared, Inferred, MissingVar) terminate. Depth-limited at 20.    // drift-audit: ignore — "cycles" referencing graph cycle detection, not deferred work
fn why_from_handle(handle) = {
  let GNode(_, reason) = perform graph_chase(handle)
  why_expand(reason, 0)
}

fn why_expand(reason, depth) = {
  if depth > 20 { reason }
  else match reason {
    Located(span, inner) =>
      Located(span, why_expand(inner, depth + 1)),
    Unified(a, b) =>
      Unified(why_expand(a, depth + 1), why_expand(b, depth + 1)),
    OpConstraint(op, l, r) =>
      OpConstraint(op, why_expand(l, depth + 1), why_expand(r, depth + 1)),
    VarLookup(name, inner) =>
      VarLookup(name, why_expand(inner, depth + 1)),
    FnReturn(name, inner) =>
      FnReturn(name, why_expand(inner, depth + 1)),
    FnParam(name, idx, inner) =>
      FnParam(name, idx, why_expand(inner, depth + 1)),
    MatchBranch(a, b) =>
      MatchBranch(why_expand(a, depth + 1), why_expand(b, depth + 1)),
    ListElement(inner) =>
      ListElement(why_expand(inner, depth + 1)),
    IfBranch(inner) =>
      IfBranch(why_expand(inner, depth + 1)),
    LetBinding(name, inner) =>
      LetBinding(name, why_expand(inner, depth + 1)),
    Instantiation(name, inner) =>
      Instantiation(name, why_expand(inner, depth + 1)),
    Fresh(id) => {
      let GNode(_, resolved) = perform graph_chase(id)
      match resolved {
        Fresh(_) => reason,
        _        => why_expand(resolved, depth + 1)
      }
    },
    _ => reason
  }
}

/// Default Synth handler: enumerates candidates and verifies each via checkpoint/rollback.
/// Handler fall-through: install `~> synth_llm` inside `~> synth_enumerative` to prepend
/// alternative proposer candidates before enumeration.
handler synth_enumerative {

  propose(target_ty, allowed_effects, context) => {
    let raw = perform enumerate_inhabitants(target_ty, allowed_effects, context)
    let verified = verify_each(raw)
    resume(verified)
  },

  verify_candidate(candidate) => {
    // A candidate's node was typed when it was proposed; its handle
    // sits in the graph in some state. The candidate is valid iff
    // chasing the handle lands on NBound — i.e., the type it carries
    // holds in the current graph without conflict. No injection is
    // needed because the candidate's type is already materialized;
    // we just confirm the graph still accepts it.
    let Candidate(node, _) = candidate
    let N(_, _, h) = node
    let GNode(kind, _) = perform graph_chase(h)
    match kind {
      NBound(_)     => resume(true),
      NErrorHole(_) => resume(false),
      _             => resume(false)
    }
  },

  // Substrate-level enumerator: the surface is here and callable. The
  // empty result means propose's verify_each immediately yields [], so
  // teach_synthesize returns None — the compiler says "no proven
  // candidate" rather than hallucinating. Real search (enumerative /
  // SMT / LLM proposers) is a sibling Synth handler installed in front
  // of this one by the post-cascade Arc F.1 surface; the swap surface
  // IS the thesis. Without that swap installed, returning [] is the
  // honest substrate behavior.
  enumerate_inhabitants(_ty, _eff, _ctx) => resume([])
}

fn verify_each(candidates) = {
  let n = candidates.len
  let buf = make_list(n)
  let kept = verify_each_loop(candidates, 0, n, buf, 0)
  slice(buf, 0, kept)
}

fn verify_each_loop(candidates, i, n, buf, buf_len) = {
  if i >= n { buf_len }
  else {
    let c = list_index(candidates, i)
    if perform verify_candidate(c) {
      list_set(buf, buf_len, c)
      verify_each_loop(candidates, i + 1, n, buf, buf_len + 1)
    } else {
      verify_each_loop(candidates, i + 1, n, buf, buf_len)
    }
  }
}

/// Fill a typed hole with the first proven candidate from the Synth proposer chain.
fn teach_synthesize(hole_handle, context) = {
  let GNode(kind, _) = perform graph_chase(hole_handle)
  match kind {
    NBound(ty) => {
      let row = extract_row(ty)
      let candidates = perform propose(ty, row, context)
      if candidates.len == 0 { None }
      else { Some(list_index(candidates, 0)) }
    },
    _ => None
  }
}

// H6: exhaustive Ty enumeration. Only TFun carries an explicit
// row; every other Ty is treated as EfPure (it has no effect
// behavior by itself). Named explicitly so a future Ty whose row
// semantics aren't pure surfaces as a compile error.
fn extract_row(ty) with Pure = match ty {
  TFun(_, _, row)   => row,
  TInt              => EfPure,
  TFloat            => EfPure,
  TString           => EfPure,
  TUnit             => EfPure,
  TList(_)          => EfPure,
  TTuple(_)         => EfPure,
  TVar(_)           => EfPure,
  TName(_, _)       => EfPure,
  TRecord(_)        => EfPure,
  TRecordOpen(_, _) => EfPure,
  TRefined(_, _)    => EfPure,
  TCont(_, _)       => EfPure,
  TAlias(_, inner)  => extract_row(inner)
}

/// Map an annotation to the capability it unlocks: add this annotation, get this capability.
fn unlock_capability(annotation) with Pure = match annotation {
  APure(_)          => CMemoize,
  ANotAlloc(_)      => CRealTime,
  ANotIO(_)         => CCompileTimeEval,
  ANotNetwork(_)    => CSandbox,
  ARefined(_, _, _) => CEliminateBoundsCheck,
  AOwn(_, _)        => CDeterministicDrop,
  ARef(_, _)        => CZeroCopy
}

/// One-line summary for an error code. Every code has a full entry at
/// `docs/errors/<code>.md`; `teach_error` returns the full Explanation with that path.
fn catalog_summary(code) = match code {
  "E_MissingVariable"     => "Variable not found in scope",
  "E_TypeMismatch"        => "Type mismatch",
  "E_PatternInexhaustive" => "Match does not cover every variant",
  "E_OwnershipViolation"  => "Double consume or ref escape",
  "E_OccursCheck"         => "Circular type (infinite type)",
  "E_UnresolvedType"      => "Type handle unresolved at codegen",
  "E_RefinementRejected"  => "Refinement obligation rejected by solver",
  "E_PurityViolated"      => "Function performs effects that violate declared purity",
  "E_EffectMismatch"      => "Effect row mismatch",
  "E_HandlerUninstallable" => "Handler arms require effects not admitted by the enclosing declaration",
  "E_FeedbackNoContext"   => "<~ requires an iterative context (Clock, Sample, or Tick handler)",
  "E_ReplayExhausted"     => "Replay trace exhausted — recording too short or divergent run",
  "P_ExpectedToken"       => "Parser expected a specific token",
  "P_UnexpectedToken"     => "Parser hit a token that admits no production",
  "V_Pending"             => "Verification obligation recorded, solver not yet installed",
  "W_Suggestion"          => "Probable fix available (did-you-mean, synth)",
  "T_Gradient"            => "Annotation would unlock a capability",
  "T_OverDeclared"        => "Function declares a wider effect row than its body uses — tighten to unlock capabilities",
  "T_ContinuationEscapes" => "Multi-shot continuation captured inside arena",
  _ => "Unknown error code: " |> str_concat(code)
}

// Display — for driver rendering

fn render_explanation(exp) = {
  let Explanation(code, _md, summary, _fix, reason) = exp
  code
    |> str_concat(": ")
    |> str_concat(summary)
}

fn show_annotation(ann) = match ann {
  APure(_)             => "with Pure",
  ANotAlloc(_)         => "with !Alloc",
  ANotIO(_)            => "with !IO",
  ANotNetwork(_)       => "with !Network",
  ARefined(name, _, _) => "refined " |> str_concat(name),
  AOwn(name, _)        => "own " |> str_concat(name),
  ARef(name, _)        => "ref " |> str_concat(name)
}

fn show_capability(cap) with Pure = match cap {
  CMemoize             => "Memoization (pure function caching)",
  CParallelize         => "Automatic parallelization",
  CCompileTimeEval     => "Compile-time evaluation",
  CRealTime            => "Real-time safe (proven zero allocation)",
  CSandbox             => "Sandbox (proven no network access)",
  CEliminateBoundsCheck => "Bounds check elimination",
  CZeroCopy            => "Zero-copy (proven no ownership transfer)",
  CDeterministicDrop   => "Deterministic drop (proven single use)"
}

// render_why — Located-aware Why Engine renderer (I18)
// teach_why returns a Reason DAG. render_why walks it, emitting
// one indented line per structural frame. Located(span, inner)
// produces `<line:col-line:col>` at its depth; structured variants
// produce a short human label then recurse on inner reasons; leaf
// variants terminate via show_reason.
//
// This is the user-visible payoff of I13/I13.1: every unification,
// instantiation, subsumption wrote a Located edge into the graph;
// render_why chases them into readable coordinate trails. IDEs/LSP
// consume this output as hover text; `mentl explain <handle>` dumps
// it to stdout.

fn indent_for(depth) = indent_for_loop(depth, "")

fn indent_for_loop(n, acc) = {
  if n <= 0 { acc }
  else { indent_for_loop(n - 1, str_concat(acc, "  ")) }
}

fn render_why(reason) = render_why_at(reason, 0)

fn render_why_at(reason, depth) = {
  if depth > 20 { indent_for(depth) |> str_concat("[depth limit reached]\n") }
  else match reason {
    Located(span, inner) =>
      indent_for(depth)
        |> str_concat(show_span(span))
        |> str_concat("\n")
        |> str_concat(render_why_at(inner, depth + 1)),

    Unified(a, b) =>
      indent_for(depth)
        |> str_concat("unified:\n")
        |> str_concat(render_why_at(a, depth + 1))
        |> str_concat(indent_for(depth))
        |> str_concat("with:\n")
        |> str_concat(render_why_at(b, depth + 1)),

    OpConstraint(op, l, r) =>
      indent_for(depth)
        |> str_concat("op '")
        |> str_concat(op)
        |> str_concat("' constraint:\n")
        |> str_concat(render_why_at(l, depth + 1))
        |> str_concat(indent_for(depth))
        |> str_concat("versus:\n")
        |> str_concat(render_why_at(r, depth + 1)),

    VarLookup(name, inner) =>
      indent_for(depth)
        |> str_concat("var '")
        |> str_concat(name)
        |> str_concat("' lookup:\n")
        |> str_concat(render_why_at(inner, depth + 1)),

    FnReturn(name, inner) =>
      indent_for(depth)
        |> str_concat("return of '")    // drift-audit: ignore — string literal content, not a control keyword
        |> str_concat(name)
        |> str_concat("':\n")
        |> str_concat(render_why_at(inner, depth + 1)),

    FnParam(name, idx, inner) =>
      indent_for(depth)
        |> str_concat("param '")
        |> str_concat(name)
        |> str_concat("' (#")
        |> str_concat(int_to_str(idx))
        |> str_concat("):\n")
        |> str_concat(render_why_at(inner, depth + 1)),

    MatchBranch(a, b) =>
      indent_for(depth)
        |> str_concat("match branches:\n")
        |> str_concat(render_why_at(a, depth + 1))
        |> str_concat(indent_for(depth))
        |> str_concat("& \n")
        |> str_concat(render_why_at(b, depth + 1)),

    ListElement(inner) =>
      indent_for(depth)
        |> str_concat("list element:\n")
        |> str_concat(render_why_at(inner, depth + 1)),

    IfBranch(inner) =>
      indent_for(depth)
        |> str_concat("if branch:\n")
        |> str_concat(render_why_at(inner, depth + 1)),

    LetBinding(name, inner) =>
      indent_for(depth)
        |> str_concat("let '")
        |> str_concat(name)
        |> str_concat("':\n")
        |> str_concat(render_why_at(inner, depth + 1)),

    Instantiation(name, inner) =>
      indent_for(depth)
        |> str_concat("instantiation of '")
        |> str_concat(name)
        |> str_concat("':\n")
        |> str_concat(render_why_at(inner, depth + 1)),

    // Leaf variants — render via show_reason and terminate.
    Declared(_)          => render_leaf(reason, depth),
    Inferred(_)          => render_leaf(reason, depth),
    Fresh(_)             => render_leaf(reason, depth),
    MissingVar(_)        => render_leaf(reason, depth),
    Placeholder(_)       => render_leaf(reason, depth),
    BinOpPlaceholder(_)  => render_leaf(reason, depth),
    Refinement(_, _)     => render_leaf(reason, depth)
  }
}

fn render_leaf(reason, depth) = {
  indent_for(depth)
    |> str_concat(show_reason(reason))
    |> str_concat("\n")
}

// teach_why_string ties the effect-returning teach_why to the pure
// renderer. Callers (LSP hover, `mentl explain`, Mentl's Quick Fix
// surface) invoke this directly.
fn teach_why_string(handle) with GraphRead = {
  render_why(why_from_handle(handle))
}
