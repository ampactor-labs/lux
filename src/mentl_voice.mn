// mentl_voice.mn — voice substrate (MV §2.7 closure, LOCKED 2026-04-21)
//
// Declares the types Mentl's voice reads and produces. No handlers
// here yet — handlers compose on these types and land in peer
// sub-handles (MV.2.b Interact effect + MV.2.c silence predicate +
// MV.2.d render + modifier bank + MV.2.e mentl_voice_default handler).
//
// Every tentacle reads the graph through the same Situation shape;
// every tentacle produces the same VoiceLine shape. Eight tentacles,
// one kernel, one voice grammar.

import types
import mentl
import graph
import own
import query
import pipeline
import driver
import runtime/strings

/// Topic is the focus of one voice turn. Cursor-of-attention projects
/// onto a Topic; Mentl reads the graph at that topic. Five variants
/// cover the four load-bearing attention surfaces (identifier / graph
/// handle / cursor position / named error) plus the explicit ask path.
/// Primitive: #1 (Query tentacle reads the graph at a Topic).

type Topic
  = TopicIdent(String)                   // hover on identifier
  | TopicHandle(Int)                     // direct graph node
  | TopicSpan(Span)                      // cursor position
  | TopicError(String, Span)             // specific diagnostic (code, span)
  | TopicAsk(Question)                   // user asked explicitly (via query.mn's Question)

/// One tentacle per kernel primitive. Eight primitives · eight
/// tentacles · eight interrogations — the octopus IS the kernel made
/// voice. Never a ninth; never a seventh.

type Tentacle
  = TentQuery       // #1 — graph state at topic
  | TentPropose     // #2 — handler / candidate surfaces
  | TentTopology    // #3 — verb / pipe-shape nudges
  | TentUnlock      // #4 — capability narrowings via row algebra
  | TentTrace       // #5 — ownership / region trails
  | TentVerify      // #6 — refinement obligations + discharges
  | TentTeach       // #7 — gradient's one next step
  | TentWhy         // #8 — Reason chain walks

/// Three registers. V1 default is RPlayful — warm but sparse.
/// RTerse is the keyboard-shortcut register. RExplain opens the
/// Reason chain (multi-sentence, used when user asked QWhy).
/// The register is a rendering input; it does not change what's
/// surfaced, only how densely.

type Register
  = RTerse
  | RPlayful
  | RExplain

/// Every gradient step is a theorem: Mentl has proved (via the
/// speculative oracle at src/mentl.mn:134) that annotating a site
/// with the suggestion's text unlocks the listed capabilities.
/// Reason walks the Why-tentacle chain on demand.
/// Primitive: #7 (annotation gradient), with #8 (Reason) carrying proof.
///
/// Substrate per Hμ.cursor §2 + GR §3.2 (live): the public shape IS
/// `AnnotationSuggestion(SuggestionKind, String, List, Reason)` from
/// types.mn — kind / annotation_text / unlocks_labels / reason. The
/// site span lives inside the Reason's outer Located wrapper.

/// Env-entries reach Mentl as snapshots so a turn is stateless w.r.t.
/// env updates. Name + Scheme + Reason + SchemeKind mirrors Env's
/// existing shape (per types.mn SchemeKind).

type EnvEntry
  = EnvEntry(String, Scheme, Reason, SchemeKind)

/// The ~> chain is a capability stack (SUBSTRATE.md "The Handler Chain
/// Is a Capability Stack"). HandlerEntry captures one position in it:
/// handler name, the effects it absorbs, and the Reason that placed
/// it here. Mentl's Unlock tentacle reads this to surface "this
/// handler is why `Alloc` is absorbed here."
/// Primitive: #2 + #4.

type HandlerEntry
  = HandlerEntry({
      name:              String,
      absorbs:           EffRow,
      install_reason:    Reason,
      install_span:      Span
    })

/// Every speak op receives a Situation. All 13 fields are load-bearing.
/// No external state consulted — stateless-per-turn except
/// prior_turn_topic (silence predicate input) and register (rendering).
/// The Situation IS the graph read: composing it invokes every
/// relevant effect op (graph_chase, env_snapshot, refinement_query,
/// ownership_at, gradient_next) and freezes their results for this
/// turn.
/// Primitives: #1 (graph), #2 (handlers_installed), #4 (rows),
/// #5 (ownership), #6 (refinements), #7 (gradient_next), #8 (reason).

type Situation
  = Situation({
      tentacle:              Tentacle,
      topic:                 Topic,
      handle:                Option,                // Option<Int>
      env_snapshot:          List,                  // List<EnvEntry>
      reason_at_topic:       Option,                // Option<Reason>
      row_at_topic:          Option,                // Option<EffRow>
      row_declared:          Option,                // Option<EffRow> — differs from row_at_topic → subsumption diag
      ownership_at_topic:    Option,                // Option<Ownership>
      refinements:           List,                  // List<Predicate>
      gradient_next:          Option,                // Option<AnnotationSuggestion> per Hμ.cursor §2 + GR §3.2 live
      handlers_installed:    List,                  // List<HandlerEntry>
      prior_turn_topic:      Option,                // Option<Topic> — silence predicate input
      prior_turn_tentacle:   Option,                // Option<Tentacle> — travels with prior_turn_topic for tentacle-different check
      facts:                 TopicFacts,            // pre-computed predicates over topic (§2.7.5 helpers as field reads)
      register:              Register
    })

/// §2.7.5's silence predicate references helpers (handle_is_hole,
/// error_at, nested_calls_at_span, unlocks_capability,
/// ownership_violation_at, row_subsumption_fails_at,
/// refinement_obligation_at) that would each require an effect read
/// on graph / ledger state. TopicFacts hoists those reads into
/// Situation composition: the handler that builds the Situation
/// performs the effect queries once and freezes results here, so
/// silence_predicate itself is pure over (Situation, which contains
/// facts).
///
/// The fields that can be derived from existing Situation fields
/// (reason_at_topic, refinements, gradient_next, row_at_topic vs
/// row_declared) are NOT duplicated here — those stay on Situation
/// and silence_predicate reads them directly. TopicFacts holds only
/// the three truly-new computations.

type TopicFacts
  = TopicFacts({
      is_hole:                Bool,                 // TentPropose → TopicHandle(h): handle_is_hole(h)
      error_code_at:          Option,               // Option<String> — TentPropose → TopicHandle(h): error_at(h)
      nested_call_depth:      Int                   // TentTopology → nested_calls_at_span(topic)
    })

/// Eight shapes, one per default-tentacle. Tone is NOT a separate
/// enum: tentacle + FormKind + Modifier compose the register-shape
/// of each VoiceLine. Tentacle→FormKind is the §2.7.3 mapping;
/// users rarely override.

type FormKind
  = FFactual          // "`x` is Pure." (Query)
  | FOffering         // "Adding `with Pure` unlocks memoization." (Propose / Topology)
  | FRefutation       // "`own x` consumed twice at L40." (Trace)
  | FNavigation       // "`env_lookup` — returns `Option<Entry>`." (Query deep)
  | FCapability       // "`!Alloc` — real-time-safe." (Unlock)
  | FRefinement       // "`99999` violates `self <= 65535`." (Verify)
  | FGradient         // "Next: `with Pure` on line 12." (Teach)
  | FTrace            // "Bound L18; `+` at L42 said `Int`." (Why)

/// Each slot renders through a canonical renderer (show_type,
/// show_row, show_reason). No ad-hoc formatting at the voice layer —
/// the graph's own self-projection is the source of strings.
/// Backtick-wrapping lives in the slot's render, not in handwritten
/// prose.

type Slot
  = SIdent(String)         // backtick-wrapped at render
  | SType(Ty)              // via canonical show_type
  | SRow(EffRow)           // via canonical show_row
  | SSpan(Span)            // rendered "(L{line})" or "(L{line}:{col})"
  | SReason(Reason)        // via show_reason (compressed)
  | SCap(String)           // capability name, plain (e.g., "CRealTime")
  | SAnnot(String)         // annotation, backtick-wrapped
  | SLit(String)           // literal text (for offering closers)

/// RPlayful picks AT MOST ONE modifier per VoiceLine. RTerse → NoMod.
/// RExplain allows one per sentence max. Modifier selection is
/// deterministic — same Situation hash → same modifier — so
/// repeated renders are reproducible (§2.7.4 applicable subsets
/// live in the handler's render path, MV.2.d).

type Modifier
  = NoMod
  | TailConsequence(String)   // " — memoization's on the table."
  | ParenQualifier(String)    // " (L40)"
  | EmphasisClose(String)     // " — can't have it both ways."

/// Silence is the default. When a turn produces nothing proven-worth-
/// surfacing (silence_predicate returns false), the surface handler
/// renders null — hover returns empty, inlayHint is not emitted,
/// status bar stays empty. Mentl does NOT fill space to fill space.
///
/// Non-silence is a four-part composition: which tentacle speaks,
/// what grammar shape, the typed slots it fills, one optional
/// modifier. Every non-Silence VoiceLine carries a Reason edge in
/// the graph that supports its assertion (acceptance criterion #4
/// per MV §2.8).
/// Primitives: #2 (tentacle's resume discipline), #8 (Reason on every
/// non-Silence VoiceLine).

type VoiceLine
  = Silence
  | VoiceLine(Tentacle, FormKind, List, Modifier)   // slots: List<Slot>

/// History feeds the silence predicate's
/// observation_new_since_last_turn check. Bounded ring — the session
/// keeps the last N turns, older entries drop. Ring size is a
/// handler-install parameter, not a substrate constant (configured
/// at handler install per H3.1 parameterized effects).

type TurnRecord
  = TurnRecord({
      tentacle:  Tentacle,
      topic:     Topic,
      line:      VoiceLine,
      span_at:   Span
    })

/// Path wraps a String. Nominal — distinguishes file-system paths from
/// arbitrary strings at the type layer. Construction is explicit:
/// `Path(s)`. Refinement (self has no `..` / resolved / within project
/// root) arrives as a `where` clause when the project-sandbox handler
/// lands (post-first-light territory).
/// Primitive: #6 (Path is a refinement-ready alias — today without
/// predicate; tomorrow with).

type Path
  = Path(String)

/// FileHandle wraps an integer index into the session's open-file
/// table. Opaque at the user surface — the handler that holds the
/// table projects handles back to Path / text on demand via file_text
/// + save_file. The distinction from Path is lifecycle: Path is the
/// addressing scheme; FileHandle is the live resource Mentl holds
/// while editing.

type FileHandle
  = FileHandle(Int)

/// tree_list projects the on-disk tree. Each entry is file or
/// directory; lazy (directories expand on demand).

type TreeEntry
  = TreeFile(Path)
  | TreeDir(Path)                   // expand via another tree_list call

/// Cursor is the human's attention at a moment. Handle + Reason —
/// which graph node, and why Mentl thinks so (last focus op / last
/// edit's mutation site / last ask's target — the Reason traces
/// back).
/// Primitives: #1 (Handle) + #8 (Reason).

type Cursor
  = Cursor(Int, Reason)             // handle, reason

/// CursorTarget is the input to `focus` — the various ways a surface
/// can name what to attend to. Maps to a Cursor by resolving through
/// the graph (span → handle lookup via span_index).

type CursorTarget
  = TargetHandle(Int)
  | TargetSpan(Span)
  | TargetIdent(String)

/// Question (declared in query.mn) is structured: QTypeAt, QWhy,
/// QRefsOf, etc. Answer is the response — always carries the Reason
/// supporting it (acceptance criterion: no Answer without Reason).
/// Silence is a valid Answer when the question is ill-posed or
/// unprovable.

type Answer
  = AnsType(Ty, Reason)
  | AnsRow(EffRow, Reason)
  | AnsReason(Reason)               // full Reason chain for QWhy
  | AnsRefs(List, Reason)           // List<Span> of references
  | AnsSilence

/// Edit is a Patch applied to a FileHandle. Outcome is either
/// accepted (graph re-projected, new handle set) or rejected (the
/// resulting text failed to parse / lower / type-check).
/// Rejection carries the diagnostic so the surface can render it.

type EditOutcome
  = EditAccepted(FileHandle)        // graph re-projected; new live handle
  | EditRejected(String, Span)      // code, span — diagnostic for surface to render

/// run_compile returns a binary's Path (or diagnostic).
/// run_check returns the diagnostic list from inference + verify.
/// run_audit is the drift-audit + plan-audit + effect-registry-audit
/// projection — the substrate that F.1/F.2/F.3 dissolve docs/ into.

type CompileOutcome
  = CompileOk(Path)                 // emitted binary
  | CompileFailed(List)             // List<Diagnostic>

type CheckOutcome
  = CheckOutcome(List, List)        // diagnostics, pending obligations

type AuditReport
  = AuditReport(List)               // List<AuditFinding> — drift + plan + effect-registry surfaces

/// `declare_intent` lets the human say "I'm targeting embedded; keep
/// me honest" — a constraint the silence predicate and Trace
/// tentacle weigh against subsequent edits. IntentId is opaque; the
/// handler that holds the intent table projects it.
/// Primitive: #7 (gradient — intents are user-side gradient
/// declarations).

type Intent
  = IntEmbedded                     // !Alloc + !IO sought on real-time paths
  | IntRealTime                     // !Alloc + deadline-sensitive
  | IntSandbox                      // !Network + !Filesystem sought on plugin paths
  | IntNoPanic                      // avoid Abort effect where possible
  | IntUserDefined({
      name:       String,
      absent:     EffRow,           // effects the user wants negated (!E style)
      present:    EffRow,           // effects the user confirms are OK
      reason:     Reason
    })

type IntentId
  = IntentId(Int)

/// Every surface that Mentl speaks through — LSP adapter, batch CLI,
/// terminal IDE, web playground, desktop client — is a peer handler
/// on Interact. The Interact effect is what the surfaces speak; the
/// surfaces decide transport. LSP is ONE transport, not the paradigm.
///
/// Handlers on Interact compose the Situation from graph reads,
/// apply silence_predicate, render VoiceLine per §2.7.3's
/// Tentacle→FormKind mapping. mentl_voice_default is the canonical
/// implementation (MV.2.e peer sub-handle).
///
/// All ops are OneShot: each Interact op is one human gesture → one
/// handler response. Multi-shot lives deeper, inside Synth and the
/// speculative oracle, not at this surface.
///
/// Primitives: #2 (this effect), #1 (ops read the graph),
/// #4 (handler rows compose with Interact via `~>`),
/// #7 (gradient surfaces through propose + speak).

effect Interact {
  // ─── Project / file ops (8) ─────────────────────────────────────
  // Text-files-first is a hard constraint. These ops are first-class.

  project_root()                 -> Path                       @resume=OneShot
  tree_list(Path)                -> List                       @resume=OneShot   // List<TreeEntry>
  open_file(Path)                -> FileHandle                 @resume=OneShot
  save_file(FileHandle)          -> ()                         @resume=OneShot
  create_file(Path, String)      -> FileHandle                 @resume=OneShot
  rename_path(Path, Path)        -> ()                         @resume=OneShot
  delete_path(Path)              -> ()                         @resume=OneShot
  file_text(FileHandle)          -> String                     @resume=OneShot

  // ─── Edit op (1) ────────────────────────────────────────────────
  // An edit is a Patch against a FileHandle. The handler re-projects
  // the edited text through the full pipeline and reports outcome.
  // Graph is live; the edit either succeeds (graph updates) or is
  // rejected with a diagnostic.

  edit(FileHandle, Patch)        -> EditOutcome                @resume=OneShot

  // ─── Attention ops (2) ──────────────────────────────────────────
  // Cursor-of-attention is (Handle, Reason). focus sets it; cursor
  // reads it.

  focus(CursorTarget)            -> ()                         @resume=OneShot
  cursor()                       -> Cursor                     @resume=OneShot

  // ─── Mentl voice ops (3) ────────────────────────────────────────
  // ask is user-initiated (Question); propose is Mentl-initiated
  // at a target (returns the survivor candidate as VoiceLine);
  // speak surfaces a VoiceLine the surface should render.

  ask(Question)                  -> Answer                     @resume=OneShot
  propose(CursorTarget)          -> VoiceLine                  @resume=OneShot
  speak(VoiceLine)               -> ()                         @resume=OneShot

  // ─── Run ops (4) ────────────────────────────────────────────────
  // Batch-shape operations. Terminal IDE exposes as commands; CLI
  // invokes directly. `run_audit` projects docs/ / PLAN / drift into
  // one report — F.1/F.2/F.3 substrate dissolution lives here.

  run_compile(FileHandle)        -> CompileOutcome             @resume=OneShot
  run_check(FileHandle)          -> CheckOutcome               @resume=OneShot
  run_audit(FileHandle)          -> AuditReport                @resume=OneShot
  run_query(Question)            -> Answer                     @resume=OneShot

  // ─── Session ops (4) ────────────────────────────────────────────
  // Intent shapes the silence predicate and Trace tentacle's weights.
  // History feeds observation_new_since_last_turn. cancel_pending
  // rolls back a tentative application.

  declare_intent(Intent)         -> ()                         @resume=OneShot
  retract_intent(IntentId)       -> ()                         @resume=OneShot
  history(Int)                   -> List                       @resume=OneShot   // List<TurnRecord>
  cancel_pending()               -> ()                         @resume=OneShot
}

/// Mentl does NOT fill space to fill space. A VoiceLine surfaces only
/// when the predicate holds: proof_derivable AND observation-new. Both
/// false → Silence. Silence is the default state; speaking is the
/// exception, earned by proof + novelty. §2.7.5 is the authority.
///
/// Pure over Situation (facts are pre-computed during composition, per
/// §2.7.5 resolution + TopicFacts above). No effects. Same Situation
/// → same verdict, deterministic. This is the substrate on which
/// cursor-moved-turns decide whether to emit anything at all.

/// SUPERSEDED by the oracle-queue-empty semantics per insight #11
/// (CLAUDE.md / INSIGHTS §"The Continuous Oracle IS Incremental
/// Compilation Plus One Cached Value", commit 636c365). The new
/// silence is project-wide: Mentl is silent ONLY when the project
/// queue is empty — the gradient's top, the proven-complete state.
/// Per-Topic + per-tentacle novelty checks were too coarse — they
/// silenced Mentl when she had more to say project-wide.
///
/// silence_predicate performs OracleQuery's query_project_queue and
/// returns true (silence) iff the queue is empty. The
/// proof_derivable / observation_new_since_last_turn helpers below
/// stay available for the per-tentacle render arms (which still need
/// to know "does THIS tentacle have something to render at this
/// position") — but the TOP-LEVEL silence gate now lives at the
/// queue, not per-Topic.

fn silence_predicate(situation) with OracleQuery = {
  let queue = perform query_project_queue()
  match queue {
    []        => true,    // gradient at top — full silence
    [_ | _]   => false    // queue has items — Mentl surfaces something
  }
}

/// Each tentacle asks: "does the graph hold a proven thing I can say
/// about this topic right now?" If yes, proof_derivable true; else
/// false. Exhaustive over the 8 tentacles — no wildcard arm (H6
/// discipline). Every branch is a pure read of Situation's pre-
/// computed state.

fn proof_derivable(situation) with Pure = {
  let Situation(s) = situation
  match s.tentacle {
    TentQuery     => is_some(s.reason_at_topic),
    TentPropose   =>
      match s.topic {
        TopicHandle(_) => {
          let TopicFacts(f) = s.facts
          f.is_hole || is_some(f.error_code_at)
        },
        TopicAsk(_)    => true,
        TopicIdent(_)  => false,
        TopicSpan(_)   => false,
        TopicError(_, _) => true
      },
    TentTopology  => {
      let TopicFacts(f) = s.facts
      f.nested_call_depth >= 3
    },
    TentUnlock    =>
      is_some(s.gradient_next) && suggestion_unlocks_nonempty(s.gradient_next),
    TentTrace     =>
      is_some(s.ownership_at_topic) || row_subsumption_fails(s.row_at_topic, s.row_declared),
    TentVerify    => list_non_empty(s.refinements),
    TentTeach     => is_some(s.gradient_next),
    TentWhy       =>
      match s.topic {
        TopicAsk(q) => question_is_why(q),
        TopicIdent(_) => false,
        TopicHandle(_) => false,
        TopicSpan(_) => false,
        TopicError(_, _) => false
      }
  }
}

/// Mentl does not repeat herself. If the prior turn was at the same
/// topic with the same tentacle, this turn is silent — unless the
/// underlying proof changed materially (which shows up via
/// proof_derivable). Together, the two predicates compose into:
/// "speak when there's proof AND it's new."

fn observation_new_since_last_turn(situation) with Pure = {
  let Situation(s) = situation
  match s.prior_turn_topic {
    None          => true,
    Some(prior)   =>
      !topic_equal(s.topic, prior)
        || match s.prior_turn_tentacle {
             None              => true,
             Some(prior_tent)  => !tentacle_equal(s.tentacle, prior_tent)
           }
  }
}

/// Two Topics match when same variant + same carried values. Span
/// equality is structural; String equality is via str_eq. Match is
/// exhaustive over the 5 variants — no wildcard.

fn topic_equal(a, b) with Pure = {
  match a {
    TopicIdent(n1)        =>
      match b {
        TopicIdent(n2)      => str_eq(n1, n2),
        TopicHandle(_)      => false,
        TopicSpan(_)        => false,
        TopicError(_, _)    => false,
        TopicAsk(_)         => false
      },
    TopicHandle(h1)       =>
      match b {
        TopicHandle(h2)     => h1 == h2,
        TopicIdent(_)       => false,
        TopicSpan(_)        => false,
        TopicError(_, _)    => false,
        TopicAsk(_)         => false
      },
    TopicSpan(s1)         =>
      match b {
        TopicSpan(s2)       => span_equal(s1, s2),
        TopicIdent(_)       => false,
        TopicHandle(_)      => false,
        TopicError(_, _)    => false,
        TopicAsk(_)         => false
      },
    TopicError(c1, s1)    =>
      match b {
        TopicError(c2, s2)  => str_eq(c1, c2) && span_equal(s1, s2),
        TopicIdent(_)       => false,
        TopicHandle(_)      => false,
        TopicSpan(_)        => false,
        TopicAsk(_)         => false
      },
    TopicAsk(_)           =>
      match b {
        TopicAsk(_)         => true,     // same-variant ask; Question equality deferred to Ask handler context
        TopicIdent(_)       => false,
        TopicHandle(_)      => false,
        TopicSpan(_)        => false,
        TopicError(_, _)    => false
      }
  }
}

/// Eight nullary variants. Pair-match exhaustive. No wildcard (H6).

fn tentacle_equal(a, b) with Pure = {
  match a {
    TentQuery     => match b { TentQuery     => true, TentPropose => false, TentTopology => false, TentUnlock => false, TentTrace => false, TentVerify => false, TentTeach => false, TentWhy => false },
    TentPropose   => match b { TentPropose   => true, TentQuery   => false, TentTopology => false, TentUnlock => false, TentTrace => false, TentVerify => false, TentTeach => false, TentWhy => false },
    TentTopology  => match b { TentTopology  => true, TentQuery   => false, TentPropose  => false, TentUnlock => false, TentTrace => false, TentVerify => false, TentTeach => false, TentWhy => false },
    TentUnlock    => match b { TentUnlock    => true, TentQuery   => false, TentPropose  => false, TentTopology => false, TentTrace => false, TentVerify => false, TentTeach => false, TentWhy => false },
    TentTrace     => match b { TentTrace     => true, TentQuery   => false, TentPropose  => false, TentTopology => false, TentUnlock => false, TentVerify => false, TentTeach => false, TentWhy => false },
    TentVerify    => match b { TentVerify    => true, TentQuery   => false, TentPropose  => false, TentTopology => false, TentUnlock => false, TentTrace => false, TentTeach => false, TentWhy => false },
    TentTeach     => match b { TentTeach     => true, TentQuery   => false, TentPropose  => false, TentTopology => false, TentUnlock => false, TentTrace => false, TentVerify => false, TentWhy => false },
    TentWhy       => match b { TentWhy       => true, TentQuery   => false, TentPropose  => false, TentTopology => false, TentUnlock => false, TentTrace => false, TentVerify => false, TentTeach => false }
  }
}

/// tentacle_to_form_kind — per MV §2.7.3, eight-variant exhaustive
/// mapping from Tentacle to its default FormKind. The §2.7.3 table
/// is the authority: Query→FFactual, Propose→FOffering,
/// Topology→FOffering, Unlock→FCapability, Trace→FRefutation,
/// Verify→FRefinement, Teach→FGradient, Why→FTrace. H6 discipline:
/// no wildcard arm; every Tentacle variant's mapping is named.

fn tentacle_to_form_kind(tentacle) with Pure = {
  match tentacle {
    TentQuery     => FFactual,
    TentPropose   => FOffering,
    TentTopology  => FOffering,
    TentUnlock    => FCapability,
    TentTrace     => FRefutation,
    TentVerify    => FRefinement,
    TentTeach     => FGradient,
    TentWhy       => FTrace
  }
}

/// applicable_modifiers_for_tentacle — per MV §2.7.4, the per-tentacle
/// subset of Modifier instances RPlayful selects from. Returns
/// List<Modifier> of concrete TailConsequence / EmphasisClose /
/// ParenQualifier instances with their canonical phrase strings.
/// Keyed on Tentacle (not FormKind — three tentacles share FOffering
/// but have distinct subsets per §2.7.4 lines 559-567). H6 discipline.

fn applicable_modifiers_for_tentacle(tentacle) with Pure = {
  match tentacle {
    TentQuery     => [
      ParenQualifier(" (L{N})"),
      ParenQualifier(" (graph-direct)")
    ],
    TentPropose   => [
      EmphasisClose(" fits here."),
      EmphasisClose(" — try it?")
    ],
    TentTopology  => [
      EmphasisClose(" draws it better."),
      EmphasisClose(" — try it?")
    ],
    TentUnlock    => [
      TailConsequence(" — on the table."),
      TailConsequence(" — memoizable."),
      TailConsequence(" — real-time-safe."),
      TailConsequence(" — no allocation.")
    ],
    TentTrace     => [
      EmphasisClose(" — can't have it both ways."),
      EmphasisClose(" — `ref` if you're reading only."),
      ParenQualifier(" (L{N})")
    ],
    TentVerify    => [
      ParenQualifier(" (L{N})"),
      ParenQualifier(" (proven)"),
      ParenQualifier(" (pending verify)")
    ],
    TentTeach     => [
      TailConsequence(" — on the table."),
      TailConsequence(" — memoizable."),
      TailConsequence(" — real-time-safe."),
      TailConsequence(" — cheaper direct.")
    ],
    TentWhy       => [
      TailConsequence(" — the graph says so."),
      ParenQualifier(" (L{N})")
    ]
  }
}

/// tentacle_tag — pure projection from Tentacle to a small Int. Used
/// by situation_hash; not exposed as dispatch. The integer space is
/// internal to hashing; downstream consumers always use the Tentacle
/// ADT directly. (Structural projection, not drift mode 8 int-coded
/// dispatch.) H6 discipline.

fn tentacle_tag(tentacle) with Pure = {
  match tentacle {
    TentQuery     => 0,
    TentPropose   => 1,
    TentTopology  => 2,
    TentUnlock    => 3,
    TentTrace     => 4,
    TentVerify    => 5,
    TentTeach     => 6,
    TentWhy       => 7
  }
}

/// topic_discriminant — pure projection from Topic to a small Int.
/// Payload values are intentionally NOT folded in; per-tentacle
/// rotation supplies the dominant variation source for modifier
/// selection. H6 discipline.

fn topic_discriminant(topic) with Pure = {
  match topic {
    TopicIdent(_)        => 0,
    TopicHandle(_)       => 1,
    TopicSpan(_)         => 2,
    TopicError(_, _)     => 3,
    TopicAsk(_)          => 4
  }
}

/// situation_hash — pure deterministic Int hash over Situation's
/// load-bearing fields. Same Situation → same hash, reproducible
/// across runs (per MV §2.8 acceptance criterion 6). Pure integer
/// arithmetic over ADT tag projections — no Memory effect, no FNV
/// primitive needed at this scale (modulo'd by applicable-subset
/// length, which is at most 6 per §2.7.4). Prime multipliers
/// minimize collision over the small index space we modulo into.

fn situation_hash(situation) with Pure = {
  let Situation(s) = situation
  tentacle_tag(s.tentacle) * 31 + topic_discriminant(s.topic) * 17
}

/// pick_from_pool — index into the tentacle's applicable-modifier list
/// via hash mod pool length. Empty pool returns NoMod (defensive — no
/// pool is empty per §2.7.4, but the substrate refuses to fabricate
/// when the invariant ever shifts).

fn pick_from_pool(tentacle, hash) with Pure = {
  let pool = applicable_modifiers_for_tentacle(tentacle)
  let n    = pool.len
  if n == 0 { NoMod }
  else      { list_index(pool, hash % n) }
}

/// select_modifier — composes hash + applicable-subset to pick one
/// Modifier deterministically. RTerse always returns NoMod (per MV
/// §2.7.4 line 532). RPlayful and RExplain pick from the per-tentacle
/// applicable subset via hash-mod-len. Same Situation + same Register
/// → same Modifier, every call. H6 discipline on Register match.

fn select_modifier(situation, register) with Pure = {
  let Situation(s) = situation
  match register {
    RTerse    => NoMod,
    RPlayful  => pick_from_pool(s.tentacle, situation_hash(situation)),
    RExplain  => pick_from_pool(s.tentacle, situation_hash(situation))
  }
}

/// with_tentacle — pure update of Situation's tentacle field. Used by
/// voice_queue_walk's fold to retarget the same Situation snapshot
/// at each of the 8 tentacles in turn. All other Situation fields
/// (topic, handle, env_snapshot, reasons, rows, ownership, refinements,
/// gradient_next, handlers_installed, prior_turn_topic, facts,
/// register) survive unchanged — only the tentacle perspective shifts.

fn with_tentacle(situation, tentacle) with Pure = {
  let Situation(s) = situation
  Situation({
    tentacle:              tentacle,
    topic:                 s.topic,
    handle:                s.handle,
    env_snapshot:          s.env_snapshot,
    reason_at_topic:       s.reason_at_topic,
    row_at_topic:          s.row_at_topic,
    row_declared:          s.row_declared,
    ownership_at_topic:    s.ownership_at_topic,
    refinements:           s.refinements,
    gradient_next:         s.gradient_next,
    handlers_installed:    s.handlers_installed,
    prior_turn_topic:      s.prior_turn_topic,
    prior_turn_tentacle:   s.prior_turn_tentacle,
    facts:                 s.facts,
    register:              s.register
  })
}

/// topic_ident_or_empty — pure projection of a Topic to its identifier
/// string when applicable. TopicIdent yields the name; TopicError
/// yields the code; other variants yield empty string. Used by render
/// arms to populate SIdent slots without re-routing through graph.
/// H6 exhaustive over Topic.

fn topic_ident_or_empty(topic) with Pure = {
  match topic {
    TopicIdent(name)        => name,
    TopicHandle(_)          => "",
    TopicSpan(_)            => "",
    TopicError(code, _)     => code,
    TopicAsk(_)             => ""
  }
}

/// topic_span_or_zero — pure projection of a Topic to a Span. Variants
/// without a natural span (TopicIdent / TopicHandle / TopicAsk) yield
/// the zero-Span sentinel. Used for SSpan slot construction at render
/// time. H6 exhaustive over Topic.

fn topic_span_or_zero(topic) with Pure = {
  match topic {
    TopicIdent(_)        => Span(0, 0, 0, 0),
    TopicHandle(_)       => Span(0, 0, 0, 0),
    TopicSpan(span)      => span,
    TopicError(_, span)  => span,
    TopicAsk(_)          => Span(0, 0, 0, 0)
  }
}

/// render_query_arm — TentQuery's render. Per MV §2.7.3 form FFactual,
/// per AT1: `` `name` runs `Type`. Row. ``. Slots compose the
/// identifier from topic, the inferred type from row_at_topic context,
/// and the row itself. silence_predicate gated upstream — fires only
/// when reason_at_topic is Some (per MV §2.7.5 TentQuery arm).

fn render_query_arm(situation) with Pure = {
  let Situation(s) = situation
  let name = topic_ident_or_empty(s.topic)
  let row_slot = match s.row_at_topic {
    None         => SLit(""),
    Some(row)    => SRow(row)
  }
  VoiceLine(TentQuery, FFactual, [
    SIdent(name),
    SLit(" — bound at "),
    SSpan(topic_span_or_zero(s.topic)),
    SLit(". Row: "),
    row_slot,
    SLit(".")
  ], select_modifier(situation, s.register))
}

/// render_propose_arm — TentPropose's render. Per MV §2.7.3 form
/// FOffering, per AT8 + AT10: hole completion / typo codeAction.
/// Topic discriminates: TopicHandle (hole at handle) → "Hole expects
/// `Type`"; TopicError (typo / missing) → "Did you mean ...?";
/// TopicAsk (explicit ask) → echoes ask. silence_predicate gated.

fn render_propose_arm(situation) with Pure = {
  let Situation(s) = situation
  let TopicFacts(f) = s.facts
  let body = match s.topic {
    TopicHandle(_)       => [
      SLit(if f.is_hole { "Hole expects synthesis here." }
           else if is_some(f.error_code_at) { SLit_to_str(f.error_code_at) }
           else { "" })
    ],
    TopicError(code, _)  => [SLit("Diagnostic at "), SIdent(code), SLit(" — codeAction available.")],
    TopicAsk(_)          => [SLit("Ask received — proposing.")],
    TopicIdent(_)        => [SLit("")],
    TopicSpan(_)         => [SLit("")]
  }
  VoiceLine(TentPropose, FOffering, body, select_modifier(situation, s.register))
}

/// render_topology_arm — TentTopology's render. Per MV §2.7.3 form
/// FOffering with STYLE_NUDGE stance. Per AT4: nested-call depth >= 3
/// surfaces a "use |> instead" suggestion. silence_predicate gated on
/// nested_call_depth >= 3 (TopicFacts substrate from D.1.c).

fn render_topology_arm(situation) with Pure = {
  let Situation(s) = situation
  let TopicFacts(f) = s.facts
  VoiceLine(TentTopology, FOffering, [
    SLit("Nested-call depth "),
    SLit(int_to_str_lite(f.nested_call_depth)),
    SLit(" — `|>` would draw the topology")
  ], select_modifier(situation, s.register))
}

/// render_unlock_arm — TentUnlock's render. Per MV §2.7.3 form
/// FCapability with EXCITED stance. Surfaces a capability that the
/// gradient_next would unlock. silence_predicate gated on gradient_next
/// AND gradient_unlocks_capability(gradient_next).

fn render_unlock_arm(situation) with Pure = {
  let Situation(s) = situation
  let body = match s.gradient_next {
    None              => [SLit("")],
    Some(suggestion)  => {
      let AnnotationSuggestion(_kind, ann_text, unlocks, _reason) = suggestion
      [
        SLit("Adding "),
        SAnnot(ann_text),
        SLit(" unlocks "),
        SCap(join_capability_labels(unlocks))
      ]
    }
  }
  VoiceLine(TentUnlock, FCapability, body, select_modifier(situation, s.register))
}

/// render_trace_arm — TentTrace's render. Per MV §2.7.3 form
/// FRefutation with FIRM stance. Per AT3 + AT9 + AT10: ownership
/// violation / dropped capability / missing import — Trace surfaces
/// the violation site. silence_predicate gated on ownership_at_topic
/// being Some OR row_subsumption_fails.

fn render_trace_arm(situation) with Pure = {
  let Situation(s) = situation
  let body = match s.ownership_at_topic {
    Some(_)  => [
      SLit("Ownership at "),
      SSpan(topic_span_or_zero(s.topic)),
      SLit(" — consumed; can't have it both ways")
    ],
    None     => [
      SLit("Row narrowing failed at "),
      SSpan(topic_span_or_zero(s.topic))
    ]
  }
  VoiceLine(TentTrace, FRefutation, body, select_modifier(situation, s.register))
}

/// render_verify_arm — TentVerify's render. Per MV §2.7.3 form
/// FRefinement with THE-MATH-SAYS stance. Per AT2: refinement
/// obligations + discharges. silence_predicate gated on
/// list_non_empty(refinements).

fn render_verify_arm(situation) with Pure = {
  let Situation(s) = situation
  VoiceLine(TentVerify, FRefinement, [
    SLit("Refinements at "),
    SSpan(topic_span_or_zero(s.topic)),
    SLit(": "),
    SLit(int_to_str_lite(s.refinements.len)),
    SLit(" obligations")
  ], select_modifier(situation, s.register))
}

/// render_teach_arm — TentTeach's render. Per MV §2.7.3 form
/// FGradient with PATIENT-BUT-POINTED stance. Per AT1 + AT5 + AT9: the
/// canonical "next step" voice — surface gradient_next as one
/// annotation that unlocks one capability. silence_predicate gated on
/// gradient_next being Some.

fn render_teach_arm(situation) with Pure = {
  let Situation(s) = situation
  let body = match s.gradient_next {
    None              => [SLit("")],
    Some(suggestion)  => {
      let AnnotationSuggestion(_kind, ann_text, _unlocks, reason) = suggestion
      [
        SLit("Next: add "),
        SAnnot(ann_text),
        SLit(" on "),
        SSpan(suggestion_site_from_reason(reason))
      ]
    }
  }
  VoiceLine(TentTeach, FGradient, body, select_modifier(situation, s.register))
}

/// render_why_arm — TentWhy's render. Per MV §2.7.3 form FTrace with
/// REFLECTIVE stance. Per AT6: walks the Reason chain when the user
/// explicitly asked a Why question. silence_predicate gated on
/// TopicAsk(QWhy(_)) — only fires for explicit asks per MV §2.7.5.

fn render_why_arm(situation) with Pure = {
  let Situation(s) = situation
  let body = match s.reason_at_topic {
    None              => [SLit("")],
    Some(reason)      => [
      SLit("Walking provenance: "),
      SReason(reason)
    ]
  }
  VoiceLine(TentWhy, FTrace, body, select_modifier(situation, s.register))
}

/// render_for_tentacle — dispatches to the right per-tentacle render
/// arm. H6 exhaustive 8-arm match. Each arm produces a VoiceLine
/// (assumed silence_predicate has already passed for this tentacle).

fn render_for_tentacle(situation) with Pure = {
  let Situation(s) = situation
  match s.tentacle {
    TentQuery     => render_query_arm(situation),
    TentPropose   => render_propose_arm(situation),
    TentTopology  => render_topology_arm(situation),
    TentUnlock    => render_unlock_arm(situation),
    TentTrace     => render_trace_arm(situation),
    TentVerify    => render_verify_arm(situation),
    TentTeach     => render_teach_arm(situation),
    TentWhy       => render_why_arm(situation)
  }
}

/// fold_tentacles — walks the kernel-ordered tentacle list, retargets
/// the Situation at each, checks silence_predicate, accumulates the
/// VoiceLines that pass. Tail-recursive accumulator pattern; flat-
/// array fold via list_extend_to + counter (Ω.3 substrate).

fn fold_tentacles(situation, tentacles, i, n, acc, count) with Pure = {
  if i >= n { slice(acc, 0, count) }
  else {
    let tentacle = list_index(tentacles, i)
    let situation_for_t = with_tentacle(situation, tentacle)
    if silence_predicate(situation_for_t) {
      let voiceline = render_for_tentacle(situation_for_t)
      let extended  = list_extend_to(acc, count + 1)
      let written   = list_set(extended, count, voiceline)
      fold_tentacles(situation, tentacles, i + 1, n, written, count + 1)
    }
    else {
      fold_tentacles(situation, tentacles, i + 1, n, acc, count)
    }
  }
}

/// voice_lines_for — D.1.e LOWER LAYER per F.1 walkthrough §3.3 (commit
/// 4d0fce1). Tentacle-fold projection: walks the 8 kernel tentacles in
/// canonical order (Query → Propose → Topology → Unlock → Trace →
/// Verify → Teach → Why), composes per-tentacle Situation via
/// with_tentacle, checks proof_derivable (Pure per-tentacle gate),
/// renders surviving tentacles via render_for_tentacle, returns a
/// List<VoiceLine> of length 0 to 8.
///
/// Two-tier silence per insight #11 + MV §2.7.5:
///   - Outer gate: silence_predicate(situation) — project queue empty
///     means full silence; entire fn returns []
///   - Inner gate: proof_derivable(situation_t) per tentacle — even
///     with non-empty queue, only tentacles with proven content fire
///
/// Cursor-time consumers (LSP) call this and filter to the
/// surface-specific tentacle; batch consumers (F.1 mentl doc) render
/// all. Same machinery, different iteration scope. Tier-1 unification
/// per INSIGHTS L509.
///
/// Naming note: F.1 §3.3 specifies `mentl_voice_default(situation)`
/// for this function; the Interact handler at end-of-file took that
/// name first per MV.2.e.scaffold (commit a0f6be6). Resolved here as
/// voice_lines_for — describes input→output shape — to honor both
/// the walkthrough's contract and the handler's canonical-name role.
///
/// Substrate idiom: list_extend_to + counter (Ω.3 substrate). Avoids
/// the O(N squared) loop-accumulator pattern by mutating a sized
/// buffer with explicit length tracking.

fn voice_lines_for(situation) with OracleQuery = {
  if silence_predicate(situation) { [] }
  else {
    let tentacles = [TentQuery, TentPropose, TentTopology, TentUnlock,
                     TentTrace, TentVerify, TentTeach, TentWhy]
    let n = tentacles.len
    let buf = make_list(n)
    let count = fold_tentacles_to_voicelines(situation, tentacles, 0, n, buf, 0)
    slice(buf, 0, count)
  }
}

/// fold_tentacles_to_voicelines — tail-recursive fold helper. For each
/// tentacle: retarget Situation, gate via proof_derivable, render +
/// accumulate via list_extend_to. Pure (silence_predicate's
/// OracleQuery already discharged at the outer gate).

fn fold_tentacles_to_voicelines(situation, tentacles, i, n, buf, count) with Pure = {
  if i >= n { count }
  else {
    let tent = list_index(tentacles, i)
    let situation_t = with_tentacle(situation, tent)
    if proof_derivable(situation_t) {
      let voiceline = render_for_tentacle(situation_t)
      let extended = list_extend_to(buf, count + 1)
      let written = list_set(extended, count, voiceline)
      fold_tentacles_to_voicelines(situation, tentacles, i + 1, n, written, count + 1)
    } else {
      fold_tentacles_to_voicelines(situation, tentacles, i + 1, n, buf, count)
    }
  }
}

/// voice_queue_walk — queue-projection per insight #11. Queries the
/// project queue via OracleQuery (cursor-relevance filtered when the
/// situation has a cursor; project-wide otherwise); for each
/// QueueItem, dispatches to the per-tentacle render arm based on
/// tier_to_tentacle(item.impact.tier); accumulates VoiceLines.
///
/// Same machinery cursor-time MV + batch F.1: LSP picks the first
/// VoiceLine for the cursor surface; F.1 mentl doc renders all.
/// Surface-side cursor-relevance projection (cursor_relevant op) +
/// project-wide fallback (query_project_queue) compose at the
/// surface; voice_queue_walk just projects the queue items it
/// receives.
///
/// Per the realization-loop discipline (insight #12): this fn replaces
/// the prior fold-over-8-tentacles approach (artifact of the per-Topic
/// silence framing that insight #11 superseded). The new fold is over
/// the QUEUE; tentacles are VIEWS on queue items, not separate
/// handlers.
///
/// Renamed from `mentl_voice_default` 2026-04-24 (MV.2.e.scaffold) to
/// free that name for the actual `Interact` handler declared at
/// end-of-file. The handler internally folds the project queue via
/// this projector.

fn voice_queue_walk(situation_seed) with OracleQuery = {
  let Situation(s) = situation_seed
  let queue_items = match s.handle {
    None       => perform query_project_queue(),
    Some(h)    => {
      let local = perform cursor_relevant(h, 200)
      match local {
        []        => perform query_project_queue(),
        [_ | _]   => local
      }
    }
  }
  let n = queue_items.len
  fold_queue_items(situation_seed, queue_items, 0, n, make_list(n), 0)
}

/// fold_queue_items — walk the queue items in priority order; per item,
/// retarget the Situation at the item's tentacle (per tier_to_tentacle
/// mapping) and call the per-tentacle render arm. Tail-recursive
/// accumulator pattern; flat-buffer-plus-counter substrate (Ω.3 —
/// list_extend_to + list_set + counter + slice).

fn fold_queue_items(situation, items, i, n, acc, count) with OracleQuery = {
  if i >= n { slice(acc, 0, count) }
  else {
    let item = list_index(items, i)
    let QueueItem(it) = item
    let OraclePriority(p) = it.impact
    let tentacle = tier_to_tentacle(p.tier)
    let situation_for_t = with_tentacle(situation, tentacle)
    let voiceline = render_for_tentacle(situation_for_t)
    let extended  = list_extend_to(acc, count + 1)
    let written   = list_set(extended, count, voiceline)
    fold_queue_items(situation, items, i + 1, n, written, count + 1)
  }
}

/// tier_to_tentacle — map a PriorityTier (per src/mentl_oracle.mn)
/// to the tentacle that renders it. H6 exhaustive over PriorityTier.
///
/// - TBlocking → TentTrace (compile error; refutation form)
/// - TViolation → TentTrace (declared row contradicted; refutation)
/// - TPending → TentVerify (V_Pending refinement obligation)
/// - TUnlock → TentUnlock (capability available; the gradient surface)
/// - TStyle → TentTopology (topology nudge; FOffering / STYLE_NUDGE)

fn tier_to_tentacle(tier) with Pure = {
  match tier {
    TBlocking   => TentTrace,
    TViolation  => TentTrace,
    TPending    => TentVerify,
    TUnlock     => TentUnlock,
    TStyle      => TentTopology
  }
}

// ─── unimplemented_arm — sentinel for arms not yet in their batch ─────
//
// Per drift mode 9 (deferred-by-omission): every Interact arm in the
// handler below is named — even those whose body lands in a later
// peer sub-handle (MV.2.e.P / .V / .Filesystem / .Run / .Session).
// Stub arms route here so unintended dispatch surfaces immediately
// (Abort) rather than returning a fabricated default. The diagnostic
// string surfaces which op was hit. Returns ! (bottom) — unifies with
// every Interact op's resume value type without fabrication.
//
// The Abort effect installed above this handler is the surface's
// responsibility: lsp_adapter installs catch_abort; CLI installs its
// own. The handler declares its row honestly.

fn unimplemented_arm(op_name) with Abort = {
  perform abort()
}

// ─── MV.2.e.Q — Query tentacle helpers ────────────────────────────────
//
// The 7 helpers below are the substrate the cursor / focus / ask arms
// in mentl_voice_default compose through. Pure or near-Pure; the ask
// arm's row is OracleQuery (silence_predicate) + Pure compose; the
// focus arm's row is GraphRead (TargetSpan path uses graph_snapshot).
//
// Per the eight interrogations applied to MV.2.e.Q (CLAUDE.md anchor):
//   Graph?   — cursor handle indexes graph; reads via graph_snapshot
//   Handler? — Interact's @resume=OneShot satisfied; one resume per arm
//   Verb?    — flat let/match; pipe doesn't draw better topology
//   Row?     — composed at arm site (Pure / GraphRead / OracleQuery)
//   Owner?   — Cursor + VoiceLine own-to-handler; no escape
//   Refine?  — Cursor.handle refinement deferred to MV.2.e.Q.refine
//   Gradient? each arm = one step toward LSP usability
//   Reason?  — every cursor write threads a Reason per CursorTarget

/// resolve_cursor_target — project a CursorTarget into a graph Handle.
/// TargetHandle: identity. TargetSpan: span_index lookup via
/// graph_snapshot (per query.mn find_tightest substrate). TargetIdent:
/// env entries don't carry handles directly per current Env shape (the
/// entry's Scheme's underlying TVar holds the handle, but extracting
/// it isn't yet wired). Fallback for that variant: cursor unchanged.
/// The MV.2.e.Q.ident peer sub-handle wires env→handle resolution.
///
/// H6 exhaustive over CursorTarget — no `_` wildcard.

fn resolve_cursor_target(target, current_handle) with GraphRead = {
  match target {
    TargetHandle(h)    => h,
    TargetSpan(s)      => {
      let g = perform graph_snapshot()
      let Graph(_, _, _, _, span_index, _) = g
      match find_tightest(span_index, s, None, 999999999) {
        None       => current_handle,
        Some(h)    => h
      }
    },
    TargetIdent(_name) => current_handle
  }
}

/// focus_reason — synthesize the Cursor's Reason from the focus
/// gesture. Per MV §2 Q5 + primitive #8: every cursor write threads a
/// Reason so the Why tentacle can later answer "why this cursor?". H6
/// exhaustive over CursorTarget.

fn focus_reason(target) with Pure = {
  match target {
    TargetHandle(_)    => Inferred("explicit handle focus"),
    TargetSpan(s)      => Located(s, Inferred("span focus gesture")),
    TargetIdent(name)  => Inferred("identifier focus: " |> str_concat(name))
  }
}

/// tentacle_for_question — Question variant decides the tentacle that
/// renders the ask. Most Questions are Query-tentacle (read graph
/// state); QWhy / QSubstChain are Why-tentacle (walk reason chain);
/// QOwnership is Trace-tentacle (ownership trail); QVerifyDebt is
/// Verify-tentacle (refinement obligations). H6 exhaustive over
/// Question's 12 variants via pattern alternation per SYNTAX.md L956.

fn tentacle_for_question(question) with Pure = {
  match question {
    QTypeOf(_) | QTypeAt(_) | QIntentOf(_) | QUnresolved
    | QEffects(_) | QRefsOf(_) | QHandlerProvider(_) | QUnknown(_)
                          => TentQuery,
    QOwnership(_)         => TentTrace,
    QWhy(_) | QSubstChain(_)
                          => TentWhy,
    QVerifyDebt           => TentVerify
  }
}

/// question_span — extract Span from Question. Only QTypeAt carries a
/// natural Span; other variants project to span_zero. The TurnRecord's
/// span_at field captures this for next-turn observation deltas. H6
/// exhaustive over Question via pattern alternation.

fn question_span(question) with Pure = {
  match question {
    QTypeAt(s)             => s,
    QTypeOf(_) | QIntentOf(_) | QUnresolved | QSubstChain(_)
    | QEffects(_) | QOwnership(_) | QWhy(_) | QRefsOf(_)
    | QVerifyDebt | QHandlerProvider(_) | QUnknown(_)
                           => span_zero()
  }
}

/// compose_minimal_ask_situation — the sparse Situation an ask
/// composes when graph reads beyond cursor are not yet wired
/// (MV.2.e.Q.compose-ops peer sub-handle adds reason_at_topic /
/// row_at_topic / ownership_at_topic / refinements / gradient_next
/// reads against graph). Render arms gracefully handle None / [] in
/// these fields — sparse Situation produces sparse VoiceLine, which
/// is the honest shape for "user asked but graph hasn't been read yet."
///
/// prior_turn_topic + prior_turn_tentacle project from the handler's
/// prior_turn state — the silence_predicate's observation-delta input.
/// register defaults to RPlayful per MV §2.7.4.

fn compose_minimal_ask_situation(question, cursor_handle, prior_turn) with Pure = {
  let (prior_topic, prior_tent) = match prior_turn {
    None        => (None, None),
    Some(rec)   => {
      let TurnRecord(r) = rec
      (Some(r.topic), Some(r.tentacle))
    }
  }
  Situation({
    tentacle:              tentacle_for_question(question),
    topic:                 TopicAsk(question),
    handle:                Some(cursor_handle),
    env_snapshot:          [],
    reason_at_topic:       None,
    row_at_topic:          None,
    row_declared:          None,
    ownership_at_topic:    None,
    refinements:           [],
    gradient_next:         None,
    handlers_installed:    [],
    prior_turn_topic:      prior_topic,
    prior_turn_tentacle:   prior_tent,
    facts:                 TopicFacts({
      is_hole:           false,
      error_code_at:     None,
      nested_call_depth: 0
    }),
    register:              RPlayful
  })
}

/// compose_propose_situation — sparse Situation for a propose gesture.
/// Parallel to compose_minimal_ask_situation but with TentPropose
/// tentacle and TopicHandle topic. Carries target_reason in
/// reason_at_topic so the Why tentacle can later answer "why this
/// proposal?". The full multi-shot oracle composition (Synth.propose
/// + verify + rank) is the MV.2.e.P.synth peer sub-handle; this sparse
/// form ships the structural composition while that oracle plumbing
/// lands separately.
///
/// Per MV §2.7.3: TentPropose's default FormKind is FOffering;
/// render_propose_arm handles the sparse Situation gracefully when
/// is_hole / error_code_at are absent (returns short-form offering).
///
/// Per Insight #10 ("Row Algebra Is One Mechanism"): this is the
/// second instance of sparse Situation composition; one more (likely
/// run_query for batch path) earns the abstraction. Until then,
/// parallel forms honest about not-yet-generic.

fn compose_propose_situation(target_handle, target_reason, prior_turn) with Pure = {
  let (prior_topic, prior_tent) = match prior_turn {
    None        => (None, None),
    Some(rec)   => {
      let TurnRecord(r) = rec
      (Some(r.topic), Some(r.tentacle))
    }
  }
  Situation({
    tentacle:              TentPropose,
    topic:                 TopicHandle(target_handle),
    handle:                Some(target_handle),
    env_snapshot:          [],
    reason_at_topic:       Some(target_reason),
    row_at_topic:          None,
    row_declared:          None,
    ownership_at_topic:    None,
    refinements:           [],
    gradient_next:         None,
    handlers_installed:    [],
    prior_turn_topic:      prior_topic,
    prior_turn_tentacle:   prior_tent,
    facts:                 TopicFacts({
      is_hole:           false,
      error_code_at:     None,
      nested_call_depth: 0
    }),
    register:              RPlayful
  })
}

/// answer_from_slots — first-projectable-slot wins. SType → AnsType;
/// SRow → AnsRow; SReason → AnsReason. SIdent / SSpan / SCap / SAnnot
/// / SLit are non-Answer-projecting slot kinds; recurse past them to
/// find a projecting head. Empty list → AnsSilence. Tail-recursive
/// scan; H6 exhaustive over Slot's 8 variants.
///
/// Per MV §2.8 acceptance criterion 4: every non-Silence Answer
/// carries a Reason — threaded through `reason` parameter from
/// voiceline_to_answer.

fn answer_from_slots(slots, reason) with Pure = {
  if slots.len == 0 { AnsSilence }
  else {
    let head = list_head(slots)
    let rest = list_tail(slots)
    match head {
      SType(t)         => AnsType(t, reason),
      SRow(r)          => AnsRow(r, reason),
      SReason(r)       => AnsReason(r),
      SIdent(_)        => answer_from_slots(rest, reason),
      SSpan(_)         => answer_from_slots(rest, reason),
      SCap(_)          => answer_from_slots(rest, reason),
      SAnnot(_)        => answer_from_slots(rest, reason),
      SLit(_)          => answer_from_slots(rest, reason)
    }
  }
}

/// voiceline_to_answer — project a VoiceLine into the Answer ADT.
/// Silence → AnsSilence. Non-silence: extract reason from
/// situation.reason_at_topic (Inferred fallback when sparse), then
/// scan slots for the first projectable kind via answer_from_slots.
/// H6 exhaustive over VoiceLine.
///
/// AnsRefs (List<Span>) projection for QRefsOf is MV.2.e.Q.refs
/// peer sub-handle territory; today returns AnsSilence when no
/// projectable head is found rather than fabricating an empty AnsRefs.

fn voiceline_to_answer(voiceline, situation) with Pure = {
  let Situation(s) = situation
  let reason = match s.reason_at_topic {
    None        => Inferred("ask answer with no graph reason"),
    Some(r)     => r
  }
  match voiceline {
    Silence                       => AnsSilence,
    VoiceLine(_, _, slots, _)     => answer_from_slots(slots, reason)
  }
}

// ─── MV.2.e.Session — Session-tentacle helpers ────────────────────────
//
// Two pure helpers for intent management. Per drift mode 7 prevention:
// intents are stored as List<(IntentId, Intent)> tuples on the handler
// state, NOT as parallel List<IntentId> + List<Intent> arrays. Per
// drift mode 8: IntentId is a structured ADT (Int wrapper), not a
// raw integer.

/// intent_id_eq — IntentId equality. IntentId wraps an Int; compare
/// via destructure + integer compare. H6 implicit (single-variant ADT).

fn intent_id_eq(a, b) with Pure = {
  let IntentId(ai) = a
  let IntentId(bi) = b
  ai == bi
}

/// intents_without — return intents list with the entry whose id
/// matches removed. Single-pass recursion; allocates one cons cell
/// per kept entry. Tail-recursive in the keep-and-recurse case;
/// length is bounded by user-declared intent count (small N typical),
/// so the simple form is honest. Substrate idiom (list_extend_to +
/// counter) reserved for genuinely-large N — this is not it.

fn intents_without(intents, id) with Pure = {
  if intents.len == 0 { [] }
  else {
    let head = list_head(intents)
    let rest = list_tail(intents)
    let (head_id, _) = head
    if intent_id_eq(head_id, id) {
      intents_without(rest, id)
    } else {
      [head] ++ intents_without(rest, id)
    }
  }
}

// ─── mentl_voice_default — Interact handler ───────────────────────────
//
// THE handler that every voice surface (LSP adapter, batch CLI,
// terminal IDE, web playground, desktop client) projects through.
// Per MV §1.5: Interact is the stable API boundary; this handler is
// its canonical implementation.
//
// State (per MV §2.7.1 + §2.7.6 turn anatomy + Insight #9 records-as-
// handler-state-shape):
//   cursor          — current cursor-of-attention (Handle + Reason)
//   prior_turn      — last turn record; feeds prior_turn_topic /
//                     prior_turn_tentacle into Situation composition
//                     for cross-turn observation deltas
//   history         — bounded ring of TurnRecords (size is a handler-
//                     install parameter once Session ops land)
//   intents         — declared user Intents (per §2.7.1's gradient /
//                     intent gating); empty until Session ops land
//   next_intent_id  — opaque IntentId minter; same disposition
//
// Resume discipline: every Interact op is @resume=OneShot per the
// effect declaration (mentl_voice.mn:340-396). Arms call resume(value)
// exactly once.
//
// Sub-handle decomposition (each lands in its own commit per Anchor 7
// + drift mode 9 prevention):
//   MV.2.e.scaffold — this commit (handler skeleton, all 22 arms named)
//   MV.2.e.Q        — Query tentacle: cursor / focus / ask
//   MV.2.e.P        — Propose tentacle: propose / edit / speak / cancel_pending
//   MV.2.e.V        — Verify tentacle: run_check
//   MV.2.e.Run      — run_compile / run_audit / run_query
//   MV.2.e.Filesystem — 8 file ops (project_root through file_text)
//   MV.2.e.Session  — declare_intent / retract_intent / history
//   MV.2.e.lsp_adapter — separate handler; the LSP transport surface
//
// Primitives audited: #1 (Graph — cursor handle indexes graph),
// #2 (this handler IS primitive #2 incarnate), #4 (handler row composes
// via ~> with caller rows), #8 (every cursor write threads a Reason).

handler mentl_voice_default
  with cursor              = Cursor(0, Inferred("session start")),
       prior_turn          = None,
       history             = [],
       intents             = [],
       next_intent_id      = 0 {

  // ─── Project / file ops (8) — handled by mentl_voice_filesystem ─
  // Per FX walkthrough §3: file ops migrate to peer handler at
  // end-of-file; mentl_voice_default no longer declares them.
  // Composition via ~> chain: surface ~> mentl_voice_filesystem ~>
  // mentl_voice_default ~> wasi_filesystem.

  // ─── Edit op (1) — handled by mentl_voice_filesystem ─────────────
  // Per FX walkthrough §3 + symmetry with project/file ops: edit
  // lives in mentl_voice_filesystem because it needs handles_table
  // to look up the FileHandle's path + cached text.

  // ─── Attention ops (2) — MV.2.e.Q ─────────────────────────────────

  /// focus — set the cursor-of-attention from a CursorTarget. Per MV
  /// §2 Q5: every focus resets the cursor. The Cursor's Reason traces
  /// back to the focus gesture (per CursorTarget variant via
  /// focus_reason). TargetSpan path performs graph_snapshot for span
  /// resolution; TargetIdent falls back to current handle (MV.2.e.Q.ident
  /// peer sub-handle wires env→handle resolution).
  focus(target)         => {
    let Cursor(current_handle, _) = cursor
    let new_handle = resolve_cursor_target(target, current_handle)
    let new_reason = focus_reason(target)
    let new_cursor = Cursor(new_handle, new_reason)
    let new_turn = TurnRecord({
      tentacle: TentQuery,
      topic:    TopicHandle(new_handle),
      line:     Silence,
      span_at:  span_zero()
    })
    resume()
      with cursor     = new_cursor,
           prior_turn = Some(new_turn),
           history    = [new_turn] ++ history
  },

  /// cursor — read the cursor-of-attention. Pure read of handler
  /// state; per MV §2.7.1 cursor lives in handler state.
  cursor()              => resume(cursor),

  // ─── Mentl voice ops (3) — ask in Q; propose + speak in MV.2.e.P ─

  /// ask — user-initiated graph query. Per MV §2.7.6: each ask is a
  /// turn. Compose Situation → silence_predicate → render → project
  /// VoiceLine → Answer. Update prior_turn for next-turn observation
  /// delta (silence_predicate's input on the subsequent turn).
  ///
  /// Sparse Situation: reason_at_topic / row_at_topic / refinements /
  /// gradient_next / handlers_installed land empty in this commit;
  /// MV.2.e.Q.compose-ops peer sub-handle adds the graph reads. Render
  /// arms gracefully handle the sparse fields — output reflects what
  /// the substrate actually knows.
  ask(question)         => {
    let Cursor(cursor_handle, _) = cursor
    let situation = compose_minimal_ask_situation(question, cursor_handle, prior_turn)
    let voiceline = if silence_predicate(situation) {
      Silence
    } else {
      render_for_tentacle(situation)
    }
    let answer = voiceline_to_answer(voiceline, situation)
    let new_turn = TurnRecord({
      tentacle: tentacle_for_question(question),
      topic:    TopicAsk(question),
      line:     voiceline,
      span_at:  question_span(question)
    })
    resume(answer)
      with prior_turn = Some(new_turn),
           history    = [new_turn] ++ history
  },

  /// propose — Mentl-initiated proposal at a CursorTarget. Compose
  /// Propose-tentacle Situation at the target → silence_predicate →
  /// render_propose_arm → return VoiceLine. Update prior_turn +
  /// history.
  ///
  /// Sparse Situation (env_snapshot / row_at_topic / refinements /
  /// gradient_next empty); the full multi-shot oracle composition
  /// (Synth.propose enumeration + verify + rank) is the MV.2.e.P.synth
  /// peer sub-handle. This sparse form ships the structural composition
  /// while oracle plumbing lands separately.
  propose(target)       => {
    let Cursor(current_handle, _) = cursor
    let target_handle = resolve_cursor_target(target, current_handle)
    let target_reason = focus_reason(target)
    let situation = compose_propose_situation(target_handle, target_reason, prior_turn)
    let voiceline = if silence_predicate(situation) {
      Silence
    } else {
      render_for_tentacle(situation)
    }
    let new_turn = TurnRecord({
      tentacle: TentPropose,
      topic:    TopicHandle(target_handle),
      line:     voiceline,
      span_at:  span_zero()
    })
    resume(voiceline)
      with prior_turn = Some(new_turn),
           history    = [new_turn] ++ history
  },

  /// speak — Mentl-initiated voice surfacing of a pre-composed
  /// VoiceLine. The handler doesn't render; it just records the turn
  /// (so silence_predicate sees this as a turn for next-turn
  /// observation-delta) and projects to the surface. Per MV §1.5: the
  /// per-surface transport handlers (lsp_adapter / cli / web) project
  /// the turn; this handler updates session state.
  ///
  /// Tentacle extracted from VoiceLine; Silence defaults to TentQuery
  /// (sentinel — speak with Silence is a no-op turn but still records).
  /// Topic is TopicHandle(0) since speak isn't tied to a graph topic.
  speak(voiceline)      => {
    let tentacle = match voiceline {
      Silence                       => TentQuery,
      VoiceLine(t, _, _, _)         => t
    }
    let new_turn = TurnRecord({
      tentacle: tentacle,
      topic:    TopicHandle(0),
      line:     voiceline,
      span_at:  span_zero()
    })
    resume()
      with prior_turn = Some(new_turn),
           history    = [new_turn] ++ history
  },

  // ─── Run ops (4) — MV.2.e.V (run_check) + MV.2.e.Run (rest) ──────
  run_compile(fh)       => {
    let text = perform file_text(fh)
    compile_source(text)
    resume(CompileOk(Path("emitted")))
  },

  run_check(fh)         => {
    let text = perform file_text(fh)
    check_source(text)
    resume(CheckOutcome([], []))
  },

  run_audit(fh)         => {
    let text = perform file_text(fh)
    audit(text)
    resume(AuditReport([]))
  },
  /// run_query — batch/CLI version of ask. Same composition path as
  /// the ask arm above (compose_minimal_ask_situation →
  /// silence_predicate → render → voiceline_to_answer); different
  /// invocation surface (CLI invokes directly per Interact §"Run ops"
  /// comment). Per Insight #10: this is the third instance of sparse
  /// Situation composition; the abstraction earns its weight when
  /// run_compile/run_audit add the fourth and fifth instances. Until
  /// then, the parallel form honors the substrate idiom.
  run_query(question)   => {
    let Cursor(cursor_handle, _) = cursor
    let situation = compose_minimal_ask_situation(question, cursor_handle, prior_turn)
    let voiceline = if silence_predicate(situation) {
      Silence
    } else {
      render_for_tentacle(situation)
    }
    let answer = voiceline_to_answer(voiceline, situation)
    let new_turn = TurnRecord({
      tentacle: tentacle_for_question(question),
      topic:    TopicAsk(question),
      line:     voiceline,
      span_at:  question_span(question)
    })
    resume(answer)
      with prior_turn = Some(new_turn),
           history    = [new_turn] ++ history
  },

  // ─── Session ops (4) — MV.2.e.Session ────────────────────────────

  /// declare_intent — append an Intent to the handler's intents list.
  /// Mints a fresh IntentId from next_intent_id counter; the new entry
  /// goes to the head (cons), so most-recent intents are first. The op
  /// returns () per the Interact effect signature; users learn the
  /// minted id via history projection or via Mentl's Teach tentacle
  /// surfacing the gradient/intent gating state.
  ///
  /// Per MV §2.7.1: intents are gradient/intent-gating substrate — the
  /// silence_predicate and Trace tentacle weigh declared intents
  /// against subsequent edits.
  declare_intent(intent) => {
    let new_id      = IntentId(next_intent_id)
    let new_intents = [(new_id, intent)] ++ intents
    resume()
      with intents        = new_intents,
           next_intent_id = next_intent_id + 1
  },

  /// retract_intent — remove the entry whose IntentId matches. If no
  /// entry matches, intents stays unchanged (idempotent retract is the
  /// honest semantics — caller may have already retracted, or used a
  /// stale id from history).
  retract_intent(id) => {
    let new_intents = intents_without(intents, id)
    resume()
      with intents = new_intents
  },

  /// history — return the last n turn records. If n exceeds the actual
  /// history length, return all of history. The list is in
  /// most-recent-first order (cons-pattern; latest TurnRecord at head).
  ///
  /// Per MV §2.7.6: TurnRecord captures one turn's tentacle / topic /
  /// VoiceLine / span; surfaces use this for observation-delta
  /// reasoning (silence_predicate's prior_turn input is the head).
  history(n) => {
    let h_len = history.len
    if n >= h_len { resume(history) }
    else          { resume(slice(history, h_len - n, h_len)) }
  },

  /// cancel_pending — clear prior_turn so the next turn doesn't
  /// observation-delta against the current prior. Per Interact effect
  /// comment: "rolls back a tentative application." Pre-pending-edit
  /// substrate (MV.2.e.P), the only tentative state observable is
  /// prior_turn; resetting it gives surfaces a clean turn boundary
  /// when the user explicitly invalidates a Mentl-initiated proposal.
  cancel_pending() => resume() with prior_turn = None
}

// ─── MV.2.e.Filesystem — mentl_voice_filesystem handler (FX.B) ────────
//
// Peer handler to mentl_voice_default. Holds the FileHandle table as
// state and projects 7 of 8 Interact file ops through the extended
// Filesystem effect (FX.A.basics + future FX.A.dirent for tree_list).
// Composition via ~> chain at the LSP adapter layer per FX walkthrough
// §3.4 + Insight #1 (handler chain IS capability stack):
//   surface ~> mentl_voice_filesystem ~> mentl_voice_default ~> wasi_filesystem
//
// The two Mentl handlers handle disjoint Interact op subsets; row
// subsumption proves disjointness at install time.
//
// State (per FX walkthrough §3.1 + Insight #9 records-as-handler-state):
//   handles_table     — List<(FileHandle, Path, String)> mapping each
//                       open handle to its path + read-time text snapshot
//   next_handle_id    — counter; 0 reserved as invalid-handle sentinel
//   project_root_cache — resolved project root; v1 uses Path("./") since
//                       WASI preopen fd 3 IS the workspace by convention
//
// tree_list arm stubs to unimplemented_arm pending FX.A.dirent (which
// adds fs_list_dir + dirent parsing) + FX.1 (which adds
// fs_filestat_is_dir for TreeFile vs TreeDir projection).

/// handles_table_lookup — find the (FileHandle, Path, String) entry
/// matching a target FileHandle. Returns Option<(FileHandle, Path,
/// String)>. Single-pass cons recursion; small N typical (handles
/// table holds open editor sessions, not arbitrary file enumerations).

fn handles_table_lookup(table, target_handle) with Pure = {
  if table.len == 0 { None }
  else {
    let head = list_head(table)
    let rest = list_tail(table)
    let (entry_handle, _, _) = head
    if file_handle_eq(entry_handle, target_handle) {
      Some(head)
    } else {
      handles_table_lookup(rest, target_handle)
    }
  }
}

/// file_handle_eq — FileHandle equality. Single-variant ADT wrapping Int;
/// destructure + integer compare. H6 implicit (single variant).

fn file_handle_eq(a, b) with Pure = {
  let FileHandle(ai) = a
  let FileHandle(bi) = b
  ai == bi
}

/// suggestion_unlocks_nonempty — silence-predicate input for TentUnlock.
/// Per Hμ.cursor §2: AnnotationSuggestion's unlocks list (List<String>)
/// is non-empty iff the candidate proves at least one capability gate.
/// Single-pass: `is_some` already checked at the call site, so the
/// inner match is exhaustive over the Some branch.

fn suggestion_unlocks_nonempty(opt) with Pure = match opt {
  None    => false,
  Some(s) => {
    let AnnotationSuggestion(_kind, _ann, unlocks, _reason) = s
    unlocks.len > 0
  }
}

/// join_capability_labels — fold List<String> into a comma-joined
/// String for FCapability rendering. Tail-recursive; allocation
/// bounded by total label length. The capabilities_for_annotation
/// substrate produces lists of size ≤ 3 today, so a flat fold is
/// honest.

fn join_capability_labels(labels) with Pure = {
  if labels.len == 0 { "" }
  else {
    let head = list_head(labels)
    let tail = list_tail(labels)
    if tail.len == 0 { head }
    else { head |> str_concat(", ") |> str_concat(join_capability_labels(tail)) }
  }
}

/// suggestion_site_from_reason — extract the source Span from an
/// AnnotationSuggestion's Reason. Per Hμ.cursor §3.5 + mentl.mn
/// `suggestion_reason`: the outer wrapper IS Located(span, _),
/// so the span is one peel away. Falls back to span_zero on
/// non-Located reasons (theoretical; suggestion_reason always
/// produces Located).

fn suggestion_site_from_reason(reason) with Pure = match reason {
  Located(sp, _) => sp,
  _              => span_zero()
}

handler mentl_voice_filesystem
  with handles_table       = [],
       next_handle_id      = 1,
       project_root_cache  = Path("./") {

  /// project_root — resolved project root Path. v1 returns
  /// project_root_cache (Path("./") at session start). Refined
  /// resolution via Module-handle synthesis lands as FX.4 peer
  /// sub-handle when surfaces need absolute paths.
  project_root()        => resume(project_root_cache),

  /// tree_list — directory listing as List<TreeEntry>. Stubbed
  /// pending FX.A.dirent (fs_list_dir + dirent parsing) + FX.1
  /// (fs_filestat_is_dir for TreeFile vs TreeDir projection). Per
  /// drift mode 9: gap is named explicitly, not silently absorbed.
  tree_list(_path)      => resume(unimplemented_arm("tree_list")),

  /// open_file — fs_open the path; on success, snapshot text via
  /// fs_read_file, mint fresh FileHandle, append to handles_table.
  /// On open failure, return invalid-handle sentinel FileHandle(0)
  /// (caller distinguishes via fs_exists if needed).
  open_file(path)       => {
    let Path(s) = path
    let fd = perform fs_open(s)
    if fd == 0 {
      resume(FileHandle(0))
    } else {
      let text = perform fs_read_file(s)
      let new_handle = FileHandle(next_handle_id)
      let new_table = [(new_handle, path, text)] ++ handles_table
      resume(new_handle)
        with handles_table  = new_table,
             next_handle_id = next_handle_id + 1
    }
  },

  /// save_file — write the cached text back to the file at the
  /// handle's recorded path. Invalid handle silently absorbs
  /// (idempotent save on stale handle is honest semantics).
  save_file(fh)         => {
    let entry = handles_table_lookup(handles_table, fh)
    match entry {
      None              => resume(),
      Some(triple)      => {
        let (_, path, text) = triple
        let Path(s) = path
        perform fs_write_file(s, text)
        resume()
      }
    }
  },

  /// create_file — write text to path, then open and register a
  /// FileHandle. On open failure, return invalid sentinel.
  create_file(p, text)  => {
    let Path(s) = p
    perform fs_write_file(s, text)
    let fd = perform fs_open(s)
    if fd == 0 {
      resume(FileHandle(0))
    } else {
      let new_handle = FileHandle(next_handle_id)
      let new_table = [(new_handle, p, text)] ++ handles_table
      resume(new_handle)
        with handles_table  = new_table,
             next_handle_id = next_handle_id + 1
    }
  },

  /// rename_path — fs_rename old → new. Returns () regardless of
  /// errno (Bool result absorbed; surface checks fs_exists if
  /// needed). The handles_table is NOT updated to reflect the rename
  /// today — open handles continue to reference old paths via their
  /// recorded Path. Path-update on rename is FX.6 peer sub-handle
  /// when LSP didRename plumbing matters.
  rename_path(old_p, new_p) => {
    let Path(o) = old_p
    let Path(n) = new_p
    perform fs_rename(o, n)
    resume()
  },

  /// delete_path — fs_unlink the path. Result Bool absorbed; surface
  /// checks fs_exists if needed. handles_table not pruned of stale
  /// entries (delete-while-open semantics owned by FX.5 close_file).
  delete_path(p)        => {
    let Path(s) = p
    perform fs_unlink(s)
    resume()
  },

  /// file_text — return the cached text snapshot for an open
  /// FileHandle. Invalid handle returns empty string (honest
  /// fallback; surface distinguishes via fs_exists if needed).
  file_text(fh)         => {
    let entry = handles_table_lookup(handles_table, fh)
    match entry {
      None              => resume(""),
      Some(triple)      => {
        let (_, _, text) = triple
        resume(text)
      }
    }
  },

  edit(fh, patch)       => {
    let entry = handles_table_lookup(handles_table, fh)
    match entry {
      None              =>
        resume(EditRejected("E_InvalidFileHandle", span_zero())),
      Some(triple)      => {
        let (_, path, old_text) = triple
        let Patch(span, replacement) = patch
        let new_text = replace_span_in_text(old_text, span, replacement)
        let Path(s) = path
        perform fs_write_file(s, new_text)
        let new_table = update_file_text(handles_table, fh, path, new_text)
        driver_check(path_to_module_name(s))
        resume(EditAccepted(fh))
          with handles_table = new_table
      }
    }
  }
}

fn replace_span_in_text(ref source, span, ref replacement) with Memory + Alloc = {
  let n = byte_len(source)
  let Span(sl, sc, el, ec) = span
  let start_pos = byte_offset_at(source, sl, sc, 0, 1, 1, n)
  let end_pos = byte_offset_at(source, el, ec, 0, 1, 1, n)
  str_slice(source, 0, start_pos)
    |> str_concat(replacement)
    |> str_concat(str_slice(source, end_pos, n))
}

fn byte_offset_at(ref source, target_l, target_c, idx, line, col, n) with Memory = {
  if line >= target_l && col >= target_c { idx }
  else if idx >= n { n }
  else if byte_at(source, idx) == 10 {
    byte_offset_at(source, target_l, target_c, idx + 1, line + 1, 1, n)
  } else {
    byte_offset_at(source, target_l, target_c, idx + 1, line, col + 1, n)
  }
}

fn update_file_text(ref table, fh, ref path, ref text) with Memory + Alloc = {
  let n = table.len
  let buf = make_list(n)
  update_file_text_loop(table, fh, path, text, 0, n, buf)
}

fn update_file_text_loop(ref table, fh, ref path, ref text, i, n, own buf) with Memory + Alloc = {
  if i >= n { buf }
  else {
    let entry = list_index(table, i)
    let (h, p, t) = entry
    let replacement = if file_handle_eq(h, fh) {
      (h, path, text)
    } else { entry }
    list_set(buf, i, replacement)
    update_file_text_loop(table, fh, path, text, i + 1, n, buf)
  }
}

fn file_handle_eq(a, b) with Pure = {
  let FileHandle(ai) = a
  let FileHandle(bi) = b
  ai == bi
}

fn path_to_module_name(ref s) with Memory + Alloc = {
  let stripped_prefix = if starts_with(s, "src/") {
    str_slice(s, 4, byte_len(s))
  } else if starts_with(s, "lib/") {
    str_slice(s, 5, byte_len(s))
  } else { s }
  if ends_with(stripped_prefix, ".mn") {
    str_slice(stripped_prefix, 0, byte_len(stripped_prefix) - 3)
  } else { stripped_prefix }
}

