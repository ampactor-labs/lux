  ;;                                  return per arm. NO __closure/__ev
  ;;                                  split. LMakeClosure arity-4 fields
  ;;                                  ALL set at construction.
  ;;
  ;; - Drift 6 (primitive-special):  LMakeList/LMakeTuple/LMakeRecord/
