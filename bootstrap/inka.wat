  ;; Lock #8: $lower_expr dispatcher retrofit at walk_call.wat:295-324.
  ;;          This commit retrofits TEN tag arms (87/89/90/91/92/96/97/
  ;;          98/99/100). Per chunk #8 Lock #10 two-file precedent. The
