        (param $h i32) (param $lo_l i32) (param $lo_r i32) (result i32)
    (call $lexpr_make_lhandlewith
      (local.get $h)
      (local.get $lo_l)
      (local.get $lo_r)))

  ;; ─── $lower_pipe_feedback — `<~` arm per Lock #5 ──────────────────
