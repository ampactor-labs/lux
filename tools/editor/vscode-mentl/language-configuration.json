{
  "comments": {
    "lineComment": "//",
    "blockComment": null
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "<", "close": ">", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["<", ">"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "autoCloseBefore": ";:.,=}])> \n\t",
  "folding": {
    "markers": {
      "start": "^\\s*(fn|type|effect|handler|handle|match|if)\\b",
      "end": "^\\s*\\}"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^.*[={]\\s*$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*",
  "onEnterRules": [
    {
      "beforeText": "^\\s*///.*$",
      "action": {
        "indent": "none",
        "appendText": "/// "
      }
    },
    {
      "beforeText": ".*\\{\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}
