/// showcase.mn — Mentl syntax showcase
/// Exercises every syntactic construct from SYNTAX.md for theme validation.
/// This file is NOT meant to compile — it is a visual reference.
///
/// Covers all 8 kernel primitives, all 69 TokenKind variants,
/// and every composite construct specified in SYNTAX.md.
///
/// Primitive: #7 (Teach) — the continuous annotation gradient:
/// this file IS the gradient at maximum verbosity.

// ─── Imports (Primitive #1: Graph + Env) ───────────────────────────
import types
import runtime/strings
import dsp/spectral {fft, ifft, window}

// ─── Algebraic Data Types ──────────────────────────────────────────
type Option<A>
  = Some(A)
  | None

type Tree<A>
  = Leaf
  | Branch(Tree<A>, A, Tree<A>)

type Color
  = Red
  | Green
  | Blue
  | Custom(Int, Int, Int)

// ─── Refinement Types (Primitive #6: Verify) ───────────────────────
type Sample = Float where -1.0 <= self <= 1.0
type NonEmpty<A> = List<A> where len(self) > 0
type Even = Int where self % 2 == 0
type ValidPort = Int where self >= 1024 && self <= 65535

// ─── Records (structural) ─────────────────────────────────────────

/// Record with structural type — no declaration ceremony.
fn make_user(name: String, age: Int) -> {name: String, age: Int} =
  {name, age}

/// Row polymorphism — accepts any record with at least `name`.
fn greet(u: {name: String, ...}) -> String =
  "Hello, " ++ u.name

/// Row polymorphism with bound rest variable `R`.
fn extend(base: {name: String, ...R}, age: Int) -> {name: String, age: Int, ...R} =
  {...base, age: age}

/// Nominal record type.
type Person = {name: String, age: Int}

/// Record update via spread.
fn birthday(p: Person) -> Person =
  Person{...p, age: p.age + 1}

// ─── Effect Declarations (Primitive #2: Handlers) ──────────────────

/// Unparameterized effect with unit-return omission.
effect Console {
  print(msg: String)              @resume=OneShot
  read_line() -> String           @resume=OneShot
}

/// Parameterized effect — `Sample(44100)` and `Sample(48000)` are distinct.
effect Sample(rate: Int) {
  tick() -> Float                 @resume=MultiShot
  current_sample() -> Float       @resume=OneShot
}

/// Generic effect — `State<Int>` and `State<String>` are distinct.
effect State<S> {
  get() -> S                      @resume=Either
  put(s: S)                       @resume=OneShot
}

/// Effect with budget semantics.
effect Budget(limit: Int) {
  spend(amount: Int) -> Bool      @resume=OneShot
}

// ─── Handler Declarations ─────────────────────────────────────────

/// Pure handler — no config, no state.
handler log_to_stderr {
  log(msg) => perform write_stderr(msg); resume(()),
}

/// Handler with config (URL captured at install site).
handler websocket_sink(url: String) {
  emit(ev) => perform ws_send(url, encode(ev)); resume(()),
}

/// Handler with state (counter evolves via `with` on resume).
handler counter with n = 0 {
  inc() => resume(()) with n = n + 1,
  get() => resume(n),
}

/// Handler with both config AND state.
handler bounded_log(prefix: String) with count = 0, max = 100 {
  log(msg) => {
    if count >= max { resume(()) }
    else {
      perform write_stderr(prefix ++ ": " ++ msg)
      resume(()) with count = count + 1
    }
  },
}

/// Handler with negation guard — arms cannot recurse through `consume`.
handler affine_ledger with !Consume {
  consume(name, span) => {
    perform record_consumption(name, span)
    resume(())
  },
}

// ─── Function Declarations ────────────────────────────────────────

/// Single expression body — no braces.
fn double(x) = x * 2

/// With explicit return type and effect clause.
fn add(a: Int, b: Int) -> Int with Pure = a + b

/// Multi-line body requires braces (§ brace discipline).
fn chase_node(ref nodes, handle, depth) with !Mutate = {
  if depth > 100 {
    GNode(NErrorHole(Inferred("depth exceeded")), Fresh(handle))
  } else {
    let GNode(kind, reason) = graph_node_at(nodes, handle)
    match kind {
      NBound(ty) => ty,
      _          => GNode(kind, reason),
    }
  }
}

/// Ownership annotations (Primitive #5: Trace).
fn consume(own data: Buffer) -> Result =
  data |> parse |> validate

fn borrow(ref data: Buffer) -> Summary =
  data |> summarize

/// Generic function with type parameters.
fn map<A, B>(f: A -> B, xs: List<A>) -> List<B> = ?

/// Identity with explicit Pure declaration.
fn identity<A>(x: A) with Pure = x

/// Effect negation — proves ABSENCE of IO and Alloc.
fn safe_divide(a: Int, b: Int) with !IO, !Alloc -> Option<Int> =
  if b == 0 { None }
  else { Some(a / b) }

/// Nested function declarations.
fn check_exhaustive(patterns) = {
  fn covers_all(pats, variants) = {
    // inner helper; visible only inside check_exhaustive
    all_match(variants, (v) => any_match(pats, (p) => matches(v, p)))
  }
  covers_all(patterns, known_variants())
}

/// Default parameter values + labeled call arguments.
fn compress(x: Sample, ratio: Float = 4.0, threshold: Float = -12.0) -> Sample =
  x |> apply_ratio(ratio) |> apply_threshold(threshold)

/// Calling with labeled args — skipping, overriding, fully labeled.
fn demo_labeled() = {
  compress(sample)
  compress(sample, 8.0)
  compress(sample, threshold = -6.0)
  compress(sample, ratio = 2.0, threshold = -18.0)
}

/// Higher-rank parameter — polymorphism that crosses scopes.
fn run_with<E>(f: fn() -> () with E) = f()

/// Parameterized effect in with-clause.
fn audio_loop() with Sample(44100) + IO + !Alloc =
  perform Sample.tick()

// ─── Anonymous Functions / Lambdas ────────────────────────────────
fn demo_lambdas() = {
  // Zero arguments
  let zero_arg = () => 42

  // Single argument
  let single = (x) => x + 1
  let ignored = (_) => 0

  // Multiple arguments
  let multi = (a, b) => a * b
  let both_ignored = (_, _) => 0

  // Destructuring patterns in param position
  let destructure_record = ({name, age}) => greet(name)
  let destructure_tuple = ((a, b)) => a + b
  let destructure_list = ([h, ...t]) => process(h, t)

  // Block body (multi-line — braces required)
  let block_body = (input) => {
    let cleaned = input |> clean
    cleaned |> transform
  }

  // Higher-order usage
  map((x) => x + 1, xs)
  fold(xs, 0, (acc, x) => acc + x)
  filter((x) => x > 0, xs)
  zip_with((a, b) => a * b, xs, ys)

  // Returned closures
  fn compose(f, g) = (x) => g(f(x))

  zero_arg
}

// ─── Pipe Verbs (Primitive #3: Five-Verb Topology) ────────────────

/// |> converge — sequential data flow. LEFT EDGE layout.
fn pipeline_converge(data) =
  data
    |> parse
    |> validate
    |> transform
    |> emit

/// Single-line short chain.
fn short_chain(x) = x |> double |> square

/// <| diverge — one input, multiple branches, tuple output.
/// Input is BORROWED — `own` values cannot flow through <|.
fn pipeline_diverge(input) =
  input
    <| (
      (x) => x |> stage_a1 |> stage_a2,
      (x) => x |> stage_b1,
      extract_c,
    )

/// >< parallel compose — N-ary structural, MANDATORY parenthesized layout.
/// >< sits ALONE on its own line at INDENTED CENTER.
/// Each branch is parenthesized. This is NOT a binary infix operator.
fn pipeline_compose() =
  (audio_left |> compress |> limit)
      ><
  (audio_right |> compress |> limit)
  |> stereo_mix

/// Three-way parallel compose.
fn triple_compose() =
  (audio |> process_audio)
      ><
  (video |> process_video)
      ><
  (ctrl  |> process_ctrl)
  |> mux
  |> encode
  ~> output_handler

/// ~> tee — handler-attach. TWO layout-disambiguated forms:
///
/// Form A (block-scoped): Newline before ~> wraps the WHOLE prior chain.
/// Form B (inline): No newline, scopes to IMMEDIATELY preceding stage only.
fn pipeline_tee_block(source) =
  source
    |> lex
    |> parse
    |> infer
    ~> env_handler          // Form A: wraps (lex |> parse |> infer)
    ~> graph_handler        // Form A: wraps env_handler(...)
    ~> diagnostics_handler  // outermost = sandbox boundary

/// Form B — inline tee (no newline before ~>).
fn pipeline_tee_inline(raw_string) =
  raw_string
    |> parse_json ~> catch_parse_error(default = "{}")
    |> validate ~> log_warnings
    |> save_to_db

/// <~ feedback — cycle closure under iterative context.
/// Requires Sample/Tick/Clock handler installed.
fn pipeline_feedback() = {
  // Inline form
  signal <~ delay(3)
  state  <~ accumulate(0)
  filter <~ filter_spec(N, coeffs)

  // Indented center form
  signal
      <~ delay(3)
}

/// Multi-handler chain (capability stack).
/// Reading top-to-bottom = inner-to-outer trust hierarchy.
fn capability_stack(source) =
  source
    |> stages
    ~> mentl_default
    ~> affine_ledger
    ~> verify_ledger
    ~> diagnostics_handler

// ─── Match Expressions ───────────────────────────────────────────
fn demo_match(opt: Option<Int>, list: List<String>, user, tree) = {
  // Basic ADT match
  let result = match opt {
    Some(v) => v,
    None    => 0,
  }

  // List patterns (PList)
  let desc = match list {
    []              => "empty",
    [single]        => "one element: " ++ show(single),
    [head, ...rest] => "head + " ++ int_to_str(len(rest)),
  }

  // Record patterns (PRecord) with punning and rest
  let greeting = match user {
    {name: "Morgan", ...}  => "found Morgan",
    {name: n, ...rest}     => "user " ++ n,
  }

  // Pattern alternation (PAlt) — multiple patterns, one arm body.
  // No variable bindings inside alternatives.
  let kind = match opt {
    Some(0) | Some(1) => "small",
    Some(_)           => "large",
    None              => "absent",
  }

  // As-patterns (PAs) — bind whole value AND destructure.
  let logged = match opt {
    whole @ Some(v) => process_with_original(whole, v),
    None            => default_value(),
  }

  // Nested constructors (PCon recursive)
  let depth = match tree {
    Leaf                   => 0,
    Branch(Leaf, _, Leaf)  => 1,
    Branch(l, _, r)        => 1 + max(depth(l), depth(r)),
  }

  // Tuple patterns (PTuple)
  let sum = match point {
    (0, 0)   => 0,
    (x, 0)   => x,
    (0, y)   => y,
    (x, y)   => x + y,
  }

  result
}

// ─── If Expressions ──────────────────────────────────────────────

/// If/else chain — expression, not statement.
fn classify(x: Int) -> String =
  if x > 0 {
    "positive"
  } else if x < 0 {
    "negative"
  } else {
    "zero"
  }

/// Unit-returning if (no else) — legal when body type is ().
fn maybe_log(verbose: Bool, msg: String) with Console =
  if verbose {
    perform Console.print(msg)
  }

// ─── Handle Expression ──────────────────────────────────────────

/// Block form: handle { body } with handler.
fn demo_handle_block() = {
  let result = handle {
    perform Console.print("hello")
    let line = perform Console.read_line()
    line ++ " world"
  } with websocket_sink("wss://example.com")

  result
}

/// Pipe form: body ~> handler (equivalent to block form).
fn demo_handle_pipe() = {
  let result = computation() ~> counter
  result
}

/// Handler with config in block form.
fn demo_handle_config() = {
  let log = handle { work() } with bounded_log("INFO")
  log
}

// ─── Let Bindings with Destructuring ─────────────────────────────
fn demo_let() = {
  // PVar — simple binding
  let x = 42

  // PTuple — tuple destructuring
  let (a, b) = point

  // PRecord — record destructuring (punning)
  let {name, age} = user

  // PRecord — record with rename
  let {name: n, age: a} = user

  // PRecord — record with rest
  let {name, ...rest_fields} = user

  // PList — list destructuring with rest
  let [first, second, ...rest] = items

  // PWild — discarding
  let _ = side_effect()

  // PCon — constructor destructuring in let
  let Some(value) = maybe_result

  x + a
}

// ─── Strings ─────────────────────────────────────────────────────
fn demo_strings() = {
  // Double-quoted — interpolation enabled
  let greeting = "Hello, {name}! You are {age} years old."

  // Literal braces in interpolating strings: {{ and }}
  let escaped_braces = "Use {{braces}} for literal {name}"

  // Single-quoted — literal, NO interpolation
  let pattern = 'This {is} literal — no interpolation'
  let regex = 'regex: ^[a-z]+\s*$'

  // Triple double-quoted — multi-line + interpolating
  let html = """
    <div class="user">
      <span>{name}</span>
      <span>{age}</span>
    </div>
  """

  // Triple single-quoted — multi-line + literal
  let raw = '''
    No {interpolation} here.
    Braces are literal characters.
    Useful for format strings, regex, shell commands.
  '''

  // Escape sequences in double-quoted strings
  let escapes = "newline\n\ttab\t\\backslash\"quote\0null\xFF"

  // Escape sequences in single-quoted strings (limited)
  let literal_escapes = 'backslash\\apostrophe\'null\0hex\xFF'

  greeting
}

// ─── Number Literals ─────────────────────────────────────────────
fn demo_numbers() = {
  let decimal     = 42
  let negative    = -17
  let with_sep    = 1_000_000
  let hex         = 0xFF_AA
  let binary      = 0b1010_0011
  let octal       = 0o755
  let float_val   = 3.14
  let float_sep   = 1_000.50
  let boolean_t   = true
  let boolean_f   = false
  decimal
}

// ─── Indexing ────────────────────────────────────────────────────
fn demo_indexing(argv: List<String>, matrix: List<List<Int>>) = {
  let first = argv[0]
  let cell = matrix[1][2]
  let tup = (10, 20, 30)[1]
  first
}

// ─── Effect Clauses and Negation (Primitive #4: Boolean Algebra) ─
fn pure_fn(x: Int) with Pure = x + 1
fn no_io(x: Int) with !IO = x * 2
fn pure_no_alloc(x) with !Alloc + !IO = x
fn multi_effect(x: Int) with Console + State<Int> + !IO =
  perform Console.print(int_to_str(x))

/// Parameterized effects in with-clauses.
fn audio_stage(samples) with Sample(44100) + !Alloc + IO =
  perform Sample.tick()

// ─── Holes (Primitive #8: Productive Under Error) ────────────────

/// Single hole — placeholder for unfinished logic.
fn todo_fn(x: Int) -> String = ?

/// Double-hole socket — Mentl Mono renders ?? as a geometric socket.
/// Visually invites the programmer (and Mentl) to plug something in.
fn unfinished_pipeline(data) =
  data
    |> parse
    |> ??
    |> emit

/// Holes in match arms — productive under error.
fn partial_handler(x: Option<Int>) -> Int =
  match x {
    Some(n) => n * 2,
    None => ??,
  }

// ─── Wildcard ────────────────────────────────────────────────────
fn ignore_second(a, _) = a
fn ignore_all(_, _, _) = 0

// ─── Operator Precedence (all 13 levels) ─────────────────────────
fn demo_operators(a: Int, b: Int, c: Int) = {
  // Level 13: field access + call
  let field = user.name
  let call = f(a, b)

  // Level 12: unary -, unary !
  let neg = -a
  let not = !flag

  // Level 11: *, /, %
  let mult = a * b / c % 2

  // Level 10: + (binary), - (binary)
  let arith = a + b - c

  // Level 9: ++ (right-associative)
  let concat = "hello" ++ " " ++ "world"

  // Level 8: ==, !=, <, >, <=, >= (non-associative)
  let cmp = a == b
  let neq = a != 0
  let lt = a < b
  let gt = a > b
  let lte = a <= b
  let gte = a >= b

  // Level 7: && (logical and)
  let conj = a > 0 && b > 0

  // Level 6: || (logical or)
  let disj = a > 0 || b > 0

  // Level 5: |> (sequential pipe)
  let piped = a |> double |> square

  // Level 4: <|, ><, <~, ~> (inline)
  // (demonstrated in pipe verb section above)

  // Level 2: = in let, => in lambda
  let bound = (x) => x + 1

  arith
}

// ─── Qualified Module Access ─────────────────────────────────────
fn demo_qualified() = {
  let spectrum = dsp.spectral.fft(samples)
  let matrix = lin.spectral.fft(data)
  spectrum
}

// ─── Top-Level Structure ─────────────────────────────────────────
// A .mn file is a sequence of:
//   import, type, effect, handler, fn, let
// A file with fn main() is an EXECUTABLE.
// A file without main is a LIBRARY.
let global_constant = 42
