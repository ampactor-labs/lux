  "tokenColors": [

    {
      "name": "Comments — human-only scaffolding (dim, italic)",
      "scope": [
        "comment.line.double-slash.inka",
        "comment.line.double-slash.content.inka",
        "punctuation.definition.comment.inka"
      ],
      "settings": {
        "foreground": "#7B7168",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments — substrate-visible (brighter, italic)",
      "scope": [
        "comment.line.documentation.inka",
        "comment.line.documentation.content.inka",
        "punctuation.definition.comment.documentation.inka"
      ],
      "settings": {
        "foreground": "#8B7B6E",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Keywords — the sovereign structure (bold, deep blue)",
      "scope": [
        "keyword.control.inka",
        "keyword.declaration.inka",
        "keyword.effect.inka",
        "keyword.declaration.function.inka",
        "keyword.declaration.type.inka",
        "keyword.declaration.effect.inka",
        "keyword.declaration.handler.inka",
        "keyword.control.import.inka",
        "keyword.control.conditional.inka",
        "keyword.control.match.inka",
        "keyword.control.handle.inka",
        "keyword.control.with.inka",
        "keyword.control.where.inka",
        "keyword.control.perform.inka",
        "keyword.control.resume.inka"
      ],
      "settings": {
        "foreground": "#2A8FC2",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Ownership markers — own/ref (Primitive #5, bold, reddish-purple)",
      "scope": [
        "keyword.ownership.inka"
      ],
      "settings": {
        "foreground": "#CC79A7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Pure — effect algebra identity (reddish-purple, bold)",
      "scope": [
        "keyword.effect.pure.inka"
      ],
      "settings": {
        "foreground": "#CC79A7",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Pipe verbs — the five verbs, topology (Primitive #3, bold, sky blue)",
      "scope": [
        "keyword.operator.pipe.forward.inka",
        "keyword.operator.pipe.diverge.inka",
        "keyword.operator.pipe.compose.inka",
        "keyword.operator.pipe.tee.inka",
        "keyword.operator.pipe.feedback.inka"
      ],
      "settings": {
        "foreground": "#56B4E9",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Type names and constructors — golden contracts (orange-gold)",
      "scope": [
        "entity.name.type.inka",
        "entity.name.type.parameter.inka",
        "entity.name.effect.inka"
      ],
      "settings": {
        "foreground": "#E69F00"
      }
    },

    {
      "name": "Function names — living computation (bluish-green, bold at def)",
      "scope": [
        "entity.name.function.inka"
      ],
      "settings": {
        "foreground": "#009E73",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Handler names — installed capability (bluish-green)",
      "scope": [
        "entity.name.handler.inka"
      ],
      "settings": {
        "foreground": "#009E73"
      }
    },

    {
      "name": "Module paths — imported substrate (warm white)",
      "scope": [
        "entity.name.module.inka"
      ],
      "settings": {
        "foreground": "#E8DCC8"
      }
    },

    {
      "name": "Strings — organic content (golden wheat)",
      "scope": [
        "string.quoted.double.inka",
        "string.quoted.single.inka",
        "string.quoted.triple.double.inka",
        "string.quoted.triple.single.inka"
      ],
      "settings": {
        "foreground": "#F0C674"
      }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape.inka"
      ],
      "settings": {
        "foreground": "#D55E00"
      }
    },
    {
      "name": "String interpolation braces — flow of data (sky blue)",
      "scope": [
        "punctuation.section.interpolation.begin.inka",
        "punctuation.section.interpolation.end.inka"
      ],
      "settings": {
        "foreground": "#56B4E9"
      }
    },

    {
      "name": "Numbers — terracotta literals (vermillion)",
      "scope": [
        "constant.numeric.integer.decimal.inka",
        "constant.numeric.integer.hex.inka",
        "constant.numeric.integer.binary.inka",
        "constant.numeric.integer.octal.inka",
        "constant.numeric.float.inka"
      ],
      "settings": {
        "foreground": "#D55E00"
      }
    },

    {
      "name": "Boolean constants — true/false (vermillion)",
      "scope": [
        "constant.language.boolean.inka"
      ],
      "settings": {
        "foreground": "#D55E00"
      }
    },

    {
      "name": "Self keyword — in refinement predicates (vermillion, bold)",
      "scope": [
        "variable.language.self.inka"
      ],
      "settings": {
        "foreground": "#D55E00",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Wildcard _ — discard pattern (warm gray)",
      "scope": [
        "variable.language.wildcard.inka"
      ],
      "settings": {
        "foreground": "#7B7168"
      }
    },

    {
      "name": "Operators — connective tissue (amber/orange-gold)",
      "scope": [
        "keyword.operator.assignment.inka",
        "keyword.operator.arithmetic.inka",
        "keyword.operator.comparison.inka",
        "keyword.operator.logical.and.inka",
        "keyword.operator.logical.or.inka",
        "keyword.operator.concat.inka",
        "keyword.operator.namespace.inka",
        "keyword.operator.spread.inka",
        "keyword.operator.tilde.inka"
      ],
      "settings": {
        "foreground": "#E69F00"
      }
    },

    {
      "name": "Arrow operators — -> and => (amber, slightly brighter)",
      "scope": [
        "keyword.operator.arrow.inka",
        "keyword.operator.arrow.fat.inka"
      ],
      "settings": {
        "foreground": "#E69F00"
      }
    },

    {
      "name": "Effect negation ! — absence proof (vermillion, bold)",
      "scope": [
        "keyword.operator.negation.inka"
      ],
      "settings": {
        "foreground": "#D55E00",
        "fontStyle": "bold"
      }
    },

    {
      "name": "Hole/placeholder ? — productive under error (vermillion, bold)",
      "scope": [
        "keyword.operator.hole.inka"
      ],
      "settings": {
        "foreground": "#D55E00",
        "fontStyle": "bold"
      }
    },

    {
      "name": "@resume annotations — discipline marker (reddish-purple, italic)",
      "scope": [
        "punctuation.decorator.at.inka",
        "entity.other.attribute-name.resume.inka",
        "constant.language.resume-discipline.inka"
      ],
      "settings": {
        "foreground": "#CC79A7",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Punctuation — structural scaffolding (dim warm)",
      "scope": [
        "punctuation.section.parens.begin.inka",
        "punctuation.section.parens.end.inka",
        "punctuation.section.braces.begin.inka",
        "punctuation.section.braces.end.inka",
        "punctuation.section.brackets.begin.inka",
        "punctuation.section.brackets.end.inka",
        "punctuation.separator.comma.inka",
        "punctuation.accessor.dot.inka",
        "punctuation.separator.colon.inka",
        "punctuation.terminator.semicolon.inka",
        "punctuation.separator.variant.inka",
        "punctuation.decorator.inka",
        "punctuation.definition.generic.begin.inka",
        "punctuation.definition.generic.end.inka",
        "punctuation.definition.string.begin.inka",
        "punctuation.definition.string.end.inka"
      ],
      "settings": {
        "foreground": "#766B60"
      }
    },

    {
      "name": "Variables and parameters — warm parchment (default text)",
      "scope": [
        "variable.other.inka"
      ],
      "settings": {
        "foreground": "#E8DCC8"
      }
    }
  ]
}
