{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Inka",
  "scopeName": "source.inka",
  "fileTypes": ["nx"],
  "patterns": [
    { "include": "#doc-comment" },
    { "include": "#line-comment" },
    { "include": "#function-declaration" },
    { "include": "#type-declaration" },
    { "include": "#effect-declaration" },
    { "include": "#handler-declaration" },
    { "include": "#import-statement" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#pipe-operators" },
    { "include": "#operators" },
    { "include": "#annotations" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {

    "doc-comment": {
      "name": "comment.line.documentation.inka",
      "match": "(///)(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.comment.documentation.inka" },
        "2": { "name": "comment.line.documentation.content.inka" }
      }
    },

    "line-comment": {
      "name": "comment.line.double-slash.inka",
      "match": "(//)(.*)$",
      "captures": {
        "1": { "name": "punctuation.definition.comment.inka" },
        "2": { "name": "comment.line.double-slash.content.inka" }
      }
    },

    "function-declaration": {
      "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*[<(])",
      "captures": {
        "1": { "name": "keyword.declaration.function.inka" },
        "2": { "name": "entity.name.function.inka" }
      }
    },

    "type-declaration": {
      "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)(?:\\s*(<)([^>]*)(>))?",
      "captures": {
        "1": { "name": "keyword.declaration.type.inka" },
        "2": { "name": "entity.name.type.inka" },
        "3": { "name": "punctuation.definition.generic.begin.inka" },
        "4": { "name": "entity.name.type.parameter.inka" },
        "5": { "name": "punctuation.definition.generic.end.inka" }
      }
    },

    "effect-declaration": {
      "match": "\\b(effect)\\s+([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.effect.inka" },
        "2": { "name": "entity.name.effect.inka" }
      }
    },

    "handler-declaration": {
      "match": "\\b(handler)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.handler.inka" },
        "2": { "name": "entity.name.handler.inka" }
      }
    },

    "import-statement": {
      "match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_/]*)",
      "captures": {
        "1": { "name": "keyword.control.import.inka" },
        "2": { "name": "entity.name.module.inka" }
      }
    },

    "strings": {
      "patterns": [
        { "include": "#string-triple-double" },
        { "include": "#string-triple-single" },
        { "include": "#string-double" },
        { "include": "#string-single" }
      ]
    },

    "string-triple-double": {
      "name": "string.quoted.triple.double.inka",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.inka" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.inka" }
      },
      "patterns": [
        { "include": "#string-interpolation" },
        { "include": "#string-escape" }
      ]
    },

    "string-triple-single": {
      "name": "string.quoted.triple.single.inka",
      "begin": "'''",
      "end": "'''",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.inka" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.inka" }
      },
      "patterns": [
        { "include": "#string-escape-literal" }
      ]
    },

    "string-double": {
      "name": "string.quoted.double.inka",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.inka" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.inka" }
      },
      "patterns": [
        { "include": "#string-interpolation" },
        { "include": "#string-escape" }
      ]
    },

    "string-single": {
      "name": "string.quoted.single.inka",
      "begin": "'",
      "end": "'",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.inka" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.inka" }
      },
      "patterns": [
        { "include": "#string-escape-literal" }
      ]
    },

    "string-interpolation": {
      "comment": "Brace interpolation {expr} inside double-quoted strings. {{ is escaped literal.",
      "name": "meta.interpolation.inka",
      "begin": "(?<!\\{)(\\{)(?!\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.interpolation.begin.inka" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.interpolation.end.inka" }
      },
      "contentName": "meta.embedded.expression.inka",
      "patterns": [
        { "include": "source.inka" }
      ]
    },

    "string-escape": {
      "comment": "Escape sequences in double-quoted strings: \\n \\r \\t \\\\ \\\" \\0 \\xHH",
      "name": "constant.character.escape.inka",
      "match": "\\\\(?:[nrt\\\\\"0]|x[0-9A-Fa-f]{2})"
    },

    "string-escape-literal": {
      "comment": "Escape sequences in single-quoted (literal) strings: \\\\ \\' \\n \\t",
      "name": "constant.character.escape.inka",
      "match": "\\\\(?:[\\\\nt'])"
    },

    "numbers": {
      "patterns": [
        {
          "comment": "Float literal with underscore separators",
          "name": "constant.numeric.float.inka",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "comment": "Hex integer 0x with underscore separators",
          "name": "constant.numeric.integer.hex.inka",
          "match": "\\b0x[0-9A-Fa-f][0-9A-Fa-f_]*\\b"
        },
        {
          "comment": "Binary integer 0b with underscore separators",
          "name": "constant.numeric.integer.binary.inka",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "comment": "Octal integer 0o with underscore separators",
          "name": "constant.numeric.integer.octal.inka",
          "match": "\\b0o[0-7][0-7_]*\\b"
        },
        {
          "comment": "Decimal integer with underscore separators",
          "name": "constant.numeric.integer.decimal.inka",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "comment": "Control flow keywords — TFn, TLet, TIf, TElse, TMatch, TImport, TWhere, THandle",
          "name": "keyword.control.inka",
          "match": "\\b(if|else|match|handle|where)\\b"
        },
        {
          "comment": "Declaration keywords — TFn (standalone), TType, TEffect, THandler, TLet",
          "name": "keyword.declaration.inka",
          "match": "\\b(fn|let|type|effect|handler)\\b"
        },
        {
          "comment": "Effect system keywords — TWith, TPerform, TResume",
          "name": "keyword.effect.inka",
          "match": "\\b(with|perform|resume)\\b"
        },
        {
          "comment": "Ownership markers — TOwn, TRef (Primitive #5: Ownership as effect)",
          "name": "keyword.ownership.inka",
          "match": "\\b(own|ref)\\b"
        },
        {
          "comment": "Pure keyword — TPure (identity element of effect + algebra)",
          "name": "keyword.effect.pure.inka",
          "match": "\\bPure\\b"
        },
        {
          "comment": "Boolean constants — TTrue, TFalse",
          "name": "constant.language.boolean.inka",
          "match": "\\b(true|false)\\b"
        },
        {
          "comment": "Self in refinement predicates (Primitive #6: Refinement types)",
          "name": "variable.language.self.inka",
          "match": "\\bself\\b"
        },
        {
          "comment": "Wildcard pattern PWild — discard",
          "name": "variable.language.wildcard.inka",
          "match": "\\b_\\b"
        }
      ]
    },

    "pipe-operators": {
      "comment": "The five verbs — Primitive #3: Topology. Each pipe verb gets its own sub-scope for potential per-verb theming.",
      "patterns": [
        {
          "comment": "|> — converge (sequential data flow)",
          "name": "keyword.operator.pipe.forward.inka",
          "match": "\\|>"
        },
        {
          "comment": "<| — diverge (fanout, borrows input)",
          "name": "keyword.operator.pipe.diverge.inka",
          "match": "<\\|"
        },
        {
          "comment": ">< — parallel compose (N-ary structural)",
          "name": "keyword.operator.pipe.compose.inka",
          "match": "><"
        },
        {
          "comment": "~> — tee / handler-attach (block or inline form)",
          "name": "keyword.operator.pipe.tee.inka",
          "match": "~>"
        },
        {
          "comment": "<~ — feedback (cycle closure under iterative context)",
          "name": "keyword.operator.pipe.feedback.inka",
          "match": "<~"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "comment": "Fat arrow — match arm separator, lambda body. TFatArrow",
          "name": "keyword.operator.arrow.fat.inka",
          "match": "=>"
        },
        {
          "comment": "Thin arrow — return type, fn type. TArrow",
          "name": "keyword.operator.arrow.inka",
          "match": "->"
        },
        {
          "comment": "Concat — string/list concat. TPlusPlus",
          "name": "keyword.operator.concat.inka",
          "match": "\\+\\+"
        },
        {
          "comment": "Equality/comparison operators. TEqEq, TBangEq, TLtEq, TGtEq",
          "name": "keyword.operator.comparison.inka",
          "match": "==|!=|<=|>="
        },
        {
          "comment": "Logical AND. TAndAnd",
          "name": "keyword.operator.logical.and.inka",
          "match": "&&"
        },
        {
          "comment": "Logical OR. TOrOr",
          "name": "keyword.operator.logical.or.inka",
          "match": "\\|\\|"
        },
        {
          "comment": "Path separator (future). TColonColon",
          "name": "keyword.operator.namespace.inka",
          "match": "::"
        },
        {
          "comment": "Effect negation / logical not. TBang — Primitive #4: Full Boolean effect algebra",
          "name": "keyword.operator.negation.inka",
          "match": "!"
        },
        {
          "comment": "Assignment. TEq",
          "name": "keyword.operator.assignment.inka",
          "match": "="
        },
        {
          "comment": "Arithmetic operators. TPlus, TMinus, TStar, TSlash, TPercent",
          "name": "keyword.operator.arithmetic.inka",
          "match": "[+\\-*/%]"
        },
        {
          "comment": "Comparison (single char). TLt, TGt",
          "name": "keyword.operator.comparison.inka",
          "match": "[<>]"
        },
        {
          "comment": "Spread/rest in patterns and records",
          "name": "keyword.operator.spread.inka",
          "match": "\\.\\.\\."
        },
        {
          "comment": "Hole/placeholder. TQuestion",
          "name": "keyword.operator.hole.inka",
          "match": "\\?"
        }
      ]
    },

    "annotations": {
      "comment": "@resume=OneShot|MultiShot|Either — resume discipline on effect ops (Primitive #2)",
      "match": "(@)(resume)(=)(OneShot|MultiShot|Either)\\b",
      "captures": {
        "1": { "name": "punctuation.decorator.at.inka" },
        "2": { "name": "entity.other.attribute-name.resume.inka" },
        "3": { "name": "keyword.operator.assignment.inka" },
        "4": { "name": "constant.language.resume-discipline.inka" }
      }
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.parens.begin.inka",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.inka",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.braces.begin.inka",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.inka",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.inka",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.inka",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.inka",
          "match": ","
        },
        {
          "name": "punctuation.accessor.dot.inka",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.colon.inka",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.semicolon.inka",
          "match": ";"
        },
        {
          "comment": "Variant separator in type declarations. TPipe",
          "name": "punctuation.separator.variant.inka",
          "match": "\\|"
        },
        {
          "comment": "Annotation marker / as-pattern. TAt",
          "name": "punctuation.decorator.inka",
          "match": "@"
        },
        {
          "comment": "Reserved. TTilde",
          "name": "keyword.operator.tilde.inka",
          "match": "~"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "comment": "Uppercase-initial identifiers are type names or constructors (e.g. Some, None, TInt, EfPure, Person, List)",
          "name": "entity.name.type.inka",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "comment": "Lowercase-initial identifiers are variables, parameters, function names",
          "name": "variable.other.inka",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
