// mentl.ka — the teaching substrate · the oracle (spec 09)
//
// Not a feature. The thesis made flesh. Eight tentacles on the
// shared inference substrate, each a handler reading through
// SubstGraphRead + EnvRead. Distributed cognition over one graph;
// the mascot is an octopus because the architecture IS octopus
// neurology — local reasoning, shared nervous system.
//
// The oracle loop (DESIGN.md Ch 8 · spec 09):
//   graph_push_checkpoint()
//     → apply tentative annotation via graph_bind / graph_bind_row
//     → run inference, run Verify
//     → graph_rollback(checkpoint)
//     → return a PROVEN candidate patch (not a guess)
//
// Synth is peer-handler fall-through: enumerative / SMT / LLM / user,
// each a ~> stage. The compiler verifies; proposers merely propose.
// AI obsolescence is mechanism, not rhetoric: proposers are handlers
// on an effect the compiler exposes.

import compiler/types
import compiler/graph
import compiler/effects

// ═══ Mentl-owned ADTs ══════════════════════════════════════════════

type Annotation
  = APure
  | ANotAlloc
  | ANotIO
  | ANotNetwork
  | ARefined(String, Predicate)
  | AOwn(String)
  | ARef(String)

type Capability
  = CMemoize
  | CParallelize
  | CCompileTimeEval
  | CRealTime
  | CSandbox
  | CEliminateBoundsCheck
  | CZeroCopy
  | CDeterministicDrop

type Patch
  = Patch(Span, String)     // span to replace, new text

type Explanation
  = Explanation(
      String,     // code: E_MissingVariable, V_Pending, W_Suggestion, …
      String,     // canonical_md: docs/errors/<code>.md
      String,     // summary: one-line human-readable
      Option,     // fix: Option(Patch) when MachineApplicable
      Reason      // reason_chain: the Why chain
    )

type Context
  = Context(List, List)   // scope bindings, active effects

type Candidate
  = Candidate(Node, Reason)  // AST fragment + why it was proposed

// ═══ Teach effect — the five tentacles ═════════════════════════════
// DESIGN.md Ch 8: each op is a tentacle entry point. The mentl_default
// handler projects the substrate for the developer — hover, gradient,
// why-chain, error catalog, unlock preview.

effect Teach {
  teach_here(String, Span, Ty) -> ()                @resume=OneShot
  teach_gradient(Int) -> Option                     @resume=OneShot
  teach_why(Int) -> Reason                          @resume=OneShot
  teach_error(String, Span, Reason) -> Explanation  @resume=OneShot
  teach_unlock(Annotation) -> Capability            @resume=OneShot
}

// ═══ Synth effect — proposers as handlers ══════════════════════════
// Three ops: propose (main), verify_candidate (Mentl-internal),
// enumerate_inhabitants (multi-shot raw). Any proposer — enumerative,
// SMT, LLM, user — plugs in as a handler. The compiler verifies.

effect Synth {
  propose(Ty, EffRow, Context) -> List               @resume=OneShot
  verify_candidate(Node) -> Bool                     @resume=OneShot
  enumerate_inhabitants(Ty, EffRow, Context) -> List @resume=MultiShot
}

// ═══ mentl_default — the substrate's self-projection ═══════════════
// Reads the graph through SubstGraphRead. Accumulates teach_here
// entries so the driver can render them as hover info. Gradient and
// why use the speculative oracle and reason DAG respectively.

handler mentl_default with annotations = [] {

  teach_here(name, span, ty) =>
    resume(())
      with annotations = [(name, span, ty)] ++ annotations,

  teach_gradient(handle) =>
    resume(gradient_next(handle)),

  teach_why(handle) =>
    resume(why_from_handle(handle)),

  teach_error(code, span, reason) =>
    resume(Explanation(
      code,
      "docs/errors/" |> str_concat(code) |> str_concat(".md"),
      catalog_summary(code),
      None,
      reason
    )),

  teach_unlock(annotation) =>
    resume(unlock_capability(annotation))
}

// ═══ The speculative oracle — gradient_next ════════════════════════
// For each candidate annotation:
//   checkpoint → tentative apply → run unification → record → rollback
// Only PROVEN annotations reach the user. The trail (graph.ka) makes
// this O(M) where M = mutations recorded. The developer gets
// certainty, not guesses.

fn gradient_next(handle) = {
  let node = perform graph_chase(handle)
  let GNode(kind, _) = node
  match kind {
    NBound(ty) => match ty {
      TFun(params, ret, row) => {
        let base_candidates = [APure, ANotAlloc, ANotIO, ANotNetwork]
        let param_candidates = ownership_candidates(params)
        let all = base_candidates ++ param_candidates
        let proven = try_each_annotation(handle, all, ty)
        pick_highest_leverage(proven)
      },
      _ => None
    },
    _ => None
  }
}

// Try each candidate; checkpoint + tentative apply + verify + rollback.
// Returns [(Annotation, Capability)] for annotations that passed.

fn try_each_annotation(handle, candidates, base_ty) =
  let n = len(candidates)
  let buf = make_list(n)
  let proven_len = try_each_annotation_loop(handle, candidates, base_ty, 0, n, buf, 0)
  let trimmed = make_list(proven_len)
  list_copy_into(buf, trimmed, 0, proven_len)

fn try_each_annotation_loop(handle, candidates, base_ty, i, n, buf, buf_len) =
  if i >= n { buf_len }
  else {
    let ann = list_index(candidates, i)
    let cp = perform graph_push_checkpoint()
    apply_annotation_tentatively(handle, ann, base_ty)
    let ok = verify_after_apply(handle)
    perform graph_rollback(cp)
    if ok {
      let new_buf = list_set(buf, buf_len, (ann, unlock_capability(ann)))
      try_each_annotation_loop(handle, candidates, base_ty, i + 1, n, new_buf, buf_len + 1)
    } else {
      try_each_annotation_loop(handle, candidates, base_ty, i + 1, n, buf, buf_len)
    }
  }

// Speculative apply: compute the narrowed type/row and graph_bind it.
// graph_bind is one-write; within a checkpoint, the narrowed bind is
// recorded in the trail and reverted on rollback.

fn apply_annotation_tentatively(handle, ann, base_ty) = match ann {
  APure => narrow_row(handle, base_ty, EfPure),
  ANotAlloc => narrow_row(handle, base_ty, EfNeg(EfClosed(["Alloc"]))),
  ANotIO => narrow_row(handle, base_ty, EfNeg(EfClosed(["IO"]))),
  ANotNetwork => narrow_row(handle, base_ty, EfNeg(EfClosed(["Network"]))),
  ARefined(_, pred) => {
    // Narrowing the type via refinement — perform verify against the
    // narrowed predicate. Ledger captures; rollback removes.
    perform verify(span_zero(), pred, Refinement(pred, PTrue))
  },
  AOwn(_)  => (),     // parameter-level marker; type narrowing at call sites
  ARef(_)  => ()
}

fn narrow_row(handle, base_ty, narrow) = match base_ty {
  TFun(params, ret, _) => {
    let narrowed = TFun(params, ret, narrow)
    // Speculative apply; the trail reverts this bind on rollback.
    // Span is span_zero() because the annotation originates inside
    // the oracle, not at a user source site. When Annotation values
    // eventually carry the proposed source span (oracle return path
    // for Patch), thread it here.
    perform graph_bind(handle, narrowed,
      Located(span_zero(), Inferred("mentl speculative narrow")))
  },
  _ => ()
}

// Verify after tentative apply: read the target handle's state.
// A candidate is "proven" if the post-apply handle is NBound (the
// tentative narrowing stuck cleanly). Failure modes:
//   NErrorHole — occurs check or a structural conflict caused
//                inference to record failure on the handle.
//   NFree     — the apply didn't bind (shouldn't happen for a
//                well-formed apply_annotation_tentatively).
//   row-kind  — handle was a row variable; not a narrow target.
// The trail-based rollback restores whatever state the handle held
// before the tentative apply, so this check is non-destructive.

fn verify_after_apply(handle) = {
  let GNode(kind, _) = perform graph_chase(handle)
  match kind {
    NBound(_)     => true,
    NErrorHole(_) => false,
    NFree(_)      => false,
    NRowBound(_)  => false,
    NRowFree(_)   => false
  }
}

fn ownership_candidates(params) =
  let flat = list_to_flat(params)
  let n = len(flat)
  // Each Inferred param yields 2 candidates (AOwn + ARef); size the
  // buffer for the maximum (2n), then trim to the actual count.
  let buf = make_list(n * 2)
  let filled = ownership_candidates_loop(flat, 0, n, buf, 0)
  let trimmed = make_list(filled)
  list_copy_into(buf, trimmed, 0, filled)

fn ownership_candidates_loop(params, i, n, buf, buf_len) =
  if i >= n { buf_len }
  else {
    let TParam(name, _, own) = list_index(params, i)
    match own {
      Inferred => {
        let after_own = list_set(buf, buf_len, AOwn(name))
        let after_ref = list_set(after_own, buf_len + 1, ARef(name))
        ownership_candidates_loop(params, i + 1, n, after_ref, buf_len + 2)
      },
      _ => ownership_candidates_loop(params, i + 1, n, buf, buf_len)
    }
  }

fn pick_highest_leverage(proven) =
  if len(proven) == 0 { None }
  else {
    let best = find_by_priority(proven, [ANotAlloc, ANotIO, ANotNetwork, APure])
    match best {
      Some(_) => best,
      None    => Some(list_index(proven, 0))
    }
  }

fn find_by_priority(proven, priorities) =
  find_by_priority_loop(proven, priorities, 0, len(priorities))

fn find_by_priority_loop(proven, priorities, i, n) =
  if i >= n { None }
  else {
    let target = list_index(priorities, i)
    match find_annotation(proven, target) {
      Some(pair) => Some(pair),
      None       => find_by_priority_loop(proven, priorities, i + 1, n)
    }
  }

fn find_annotation(proven, target) =
  find_annotation_loop(proven, target, 0, len(proven))

fn find_annotation_loop(proven, target, i, n) =
  if i >= n { None }
  else {
    let (ann, cap) = list_index(proven, i)
    if annotation_eq(ann, target) { Some((ann, cap)) }
    else { find_annotation_loop(proven, target, i + 1, n) }
  }

fn annotation_eq(a, b) = match a {
  APure       => match b { APure       => true, _ => false },
  ANotAlloc   => match b { ANotAlloc   => true, _ => false },
  ANotIO      => match b { ANotIO      => true, _ => false },
  ANotNetwork => match b { ANotNetwork => true, _ => false },
  _           => false
}

// ═══ The Why Engine — walk the reason DAG ══════════════════════════
// Every unification, instantiation, subsumption wrote a Reason edge
// into the graph. teach_why recurses through the chain, chasing
// handle-valued reasons, until leaf reasons (Declared, Inferred,
// MissingVar) terminate. Depth-limited to tolerate any residual cycle.

fn why_from_handle(handle) = {
  let GNode(_, reason) = perform graph_chase(handle)
  why_expand(reason, 0)
}

fn why_expand(reason, depth) =
  if depth > 20 { reason }
  else match reason {
    Located(span, inner) =>
      Located(span, why_expand(inner, depth + 1)),
    Unified(a, b) =>
      Unified(why_expand(a, depth + 1), why_expand(b, depth + 1)),
    OpConstraint(op, l, r) =>
      OpConstraint(op, why_expand(l, depth + 1), why_expand(r, depth + 1)),
    VarLookup(name, inner) =>
      VarLookup(name, why_expand(inner, depth + 1)),
    FnReturn(name, inner) =>
      FnReturn(name, why_expand(inner, depth + 1)),
    FnParam(name, idx, inner) =>
      FnParam(name, idx, why_expand(inner, depth + 1)),
    MatchBranch(a, b) =>
      MatchBranch(why_expand(a, depth + 1), why_expand(b, depth + 1)),
    ListElement(inner) =>
      ListElement(why_expand(inner, depth + 1)),
    IfBranch(inner) =>
      IfBranch(why_expand(inner, depth + 1)),
    LetBinding(name, inner) =>
      LetBinding(name, why_expand(inner, depth + 1)),
    Instantiation(name, inner) =>
      Instantiation(name, why_expand(inner, depth + 1)),
    Fresh(id) => {
      let GNode(_, resolved) = perform graph_chase(id)
      match resolved {
        Fresh(_) => reason,
        _        => why_expand(resolved, depth + 1)
      }
    },
    _ => reason
  }

// ═══ synth_enumerative — the default proposer ══════════════════════
// Enumerates candidates; verifies each via checkpoint/rollback.
// Handler fall-through: a caller can install ~> synth_llm inside
// ~> synth_enumerative for LLM candidates to come first.

handler synth_enumerative {

  propose(target_ty, allowed_effects, context) => {
    let raw = perform enumerate_inhabitants(target_ty, allowed_effects, context)
    let verified = verify_each(raw)
    resume(verified)
  },

  verify_candidate(candidate) => {
    // A candidate's node was typed when it was proposed; its handle
    // sits in the graph in some state. The candidate is valid iff
    // chasing the handle lands on NBound — i.e., the type it carries
    // holds in the current graph without conflict. No injection is
    // needed because the candidate's type is already materialized;
    // we just confirm the graph still accepts it.
    let Candidate(node, _) = candidate
    let N(_, _, h) = node
    let GNode(kind, _) = perform graph_chase(h)
    match kind {
      NBound(_)     => resume(true),
      NErrorHole(_) => resume(false),
      _             => resume(false)
    }
  },

  // Phase 1 default enumerator: the surface is here and callable, but
  // empty until Arc F.1 plugs in real search (enumerative / SMT / LLM
  // proposers as peer handlers in front of this one). Returning an
  // empty list means propose's verify_each immediately yields [], and
  // teach_synthesize returns None — the compiler says "no proven
  // candidate" rather than hallucinating.
  enumerate_inhabitants(_ty, _eff, _ctx) => resume([])
}

fn verify_each(candidates) =
  let n = len(candidates)
  let buf = make_list(n)
  let kept = verify_each_loop(candidates, 0, n, buf, 0)
  let trimmed = make_list(kept)
  list_copy_into(buf, trimmed, 0, kept)

fn verify_each_loop(candidates, i, n, buf, buf_len) =
  if i >= n { buf_len }
  else {
    let c = list_index(candidates, i)
    if perform verify_candidate(c) {
      verify_each_loop(
        candidates, i + 1, n,
        list_set(buf, buf_len, c), buf_len + 1
      )
    } else {
      verify_each_loop(candidates, i + 1, n, buf, buf_len)
    }
  }

// ═══ teach_synthesize — fill a hole with a proven candidate ════════

fn teach_synthesize(hole_handle, context) = {
  let GNode(kind, _) = perform graph_chase(hole_handle)
  match kind {
    NBound(ty) => {
      let row = extract_row(ty)
      let candidates = perform propose(ty, row, context)
      if len(candidates) == 0 { None }
      else { Some(list_index(candidates, 0)) }
    },
    _ => None
  }
}

fn extract_row(ty) = match ty {
  TFun(_, _, row) => row,
  _               => EfPure
}

// ═══ Unlock mapping — the teaching payoff ══════════════════════════
// "Add this annotation — get this capability."

fn unlock_capability(annotation) = match annotation {
  APure             => CMemoize,
  ANotAlloc         => CRealTime,
  ANotIO            => CCompileTimeEval,
  ANotNetwork       => CSandbox,
  ARefined(_, _)    => CEliminateBoundsCheck,
  AOwn(_)           => CDeterministicDrop,
  ARef(_)           => CZeroCopy
}

// ═══ Error catalog — canonical summaries ═══════════════════════════
// Every code has an entry at docs/errors/<code>.md. This surface
// returns the one-line summary; teach_error returns the full
// Explanation including the path into the catalog.

fn catalog_summary(code) = match code {
  "E_MissingVariable"     => "Variable not found in scope",
  "E_TypeMismatch"        => "Type mismatch",
  "E_PatternInexhaustive" => "Match does not cover every variant",
  "E_OwnershipViolation"  => "Double consume or ref escape",
  "E_OccursCheck"         => "Circular type (infinite type)",
  "E_UnresolvedType"      => "Type handle unresolved at codegen",
  "E_RefinementRejected"  => "Refinement obligation rejected by solver",
  "E_PurityViolated"      => "Function performs effects that violate declared purity",
  "E_EffectMismatch"      => "Effect row mismatch",
  "E_FeedbackNoContext"   => "<~ requires an iterative context (Clock, Sample, or Tick handler)",
  "E_ReplayExhausted"     => "Replay trace exhausted — recording too short or divergent run",
  "P_ExpectedToken"       => "Parser expected a specific token",
  "P_UnexpectedToken"     => "Parser hit a token that admits no production",
  "V_Pending"             => "Verification obligation recorded, awaiting solver",
  "W_Suggestion"          => "Probable fix available (did-you-mean, synth)",
  "T_Gradient"            => "Annotation would unlock a capability",
  "T_ContinuationEscapes" => "Multi-shot continuation captured inside arena",
  _ => "Unknown error code: " |> str_concat(code)
}

// ═══ Display — for driver rendering ════════════════════════════════

fn render_explanation(exp) = {
  let Explanation(code, _md, summary, _fix, reason) = exp
  code
    |> str_concat(": ")
    |> str_concat(summary)
}

fn show_annotation(ann) = match ann {
  APure             => "with Pure",
  ANotAlloc         => "with !Alloc",
  ANotIO            => "with !IO",
  ANotNetwork       => "with !Network",
  ARefined(name, _) => "refined " |> str_concat(name),
  AOwn(name)        => "own " |> str_concat(name),
  ARef(name)        => "ref " |> str_concat(name)
}

fn show_capability(cap) = match cap {
  CMemoize             => "Memoization (pure function caching)",
  CParallelize         => "Automatic parallelization",
  CCompileTimeEval     => "Compile-time evaluation",
  CRealTime            => "Real-time safe (proven zero allocation)",
  CSandbox             => "Sandbox (proven no network access)",
  CEliminateBoundsCheck => "Bounds check elimination",
  CZeroCopy            => "Zero-copy (proven no ownership transfer)",
  CDeterministicDrop   => "Deterministic drop (proven single use)"
}
