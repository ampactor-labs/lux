// Lux Test Framework — Testing IS a Handler Swap
//
// From DESIGN.md: "Testing Without a Framework — Effects make
// traditional testing frameworks obsolete."
//
// check() is an effect. The handler decides what happens.
// Same test code → test handler (pass/fail) → benchmark handler
// (timing) → property handler (random inputs).

// ─── The Test Effect ─────────────────────────────────────────

effect Test {
  check(condition: Bool, msg: String) -> ()
}

// ─── Convenience ─────────────────────────────────────────────

fn expect_eq(actual, expected) =
  check(actual == expected,
    "expected " ++ to_string(expected) ++ " got " ++ to_string(actual))

fn expect_ne(actual, expected) =
  check(actual != expected,
    "expected not " ++ to_string(expected))

fn expect_true(value) =
  check(value, "expected true")

fn expect_false(value) =
  check(!value, "expected false")

// ─── run_tests: compact output ───────────────────────────────

fn run_tests(tests) = {
  let totals = fold(tests, (0, 0), |acc, test| {
    let (name, test_fn) = test
    let (_, (p, f)) = handle {
      test_fn()
    } with counts = (0, 0) {
      check(cond, msg) => {
        let (passed, failed) = counts
        if cond {
          resume(()) with counts = (passed + 1, failed)
        } else {
          println("  FAIL [" ++ name ++ "]: " ++ msg)
          resume(()) with counts = (passed, failed + 1)
        }
      }
    }
    let (tp, tf) = acc
    (tp + p, tf + f)
  })
  let (passed, failed) = totals
  let total = passed + failed
  if failed == 0 {
    println("✓ " ++ to_string(total) ++ " passed")
  } else {
    println("✗ " ++ to_string(passed) ++ "/" ++ to_string(total) ++ " passed")
  }
  totals
}

// ─── run_suite: verbose ✓/✗ per assertion ────────────────────

fn run_suite(tests) = {
  let totals = fold(tests, (0, 0), |acc, test| {
    let (name, test_fn) = test
    println("── " ++ name ++ " ──")
    let (_, (p, f)) = handle {
      test_fn()
    } with counts = (0, 0) {
      check(cond, msg) => {
        let (passed, failed) = counts
        if cond {
          println("  ✓ " ++ msg)
          resume(()) with counts = (passed + 1, failed)
        } else {
          println("  ✗ " ++ msg)
          resume(()) with counts = (passed, failed + 1)
        }
      }
    }
    let (tp, tf) = acc
    (tp + p, tf + f)
  })
  let (passed, failed) = totals
  let total = passed + failed
  if failed == 0 {
    println("✓ " ++ to_string(total) ++ " passed")
  } else {
    println("✗ " ++ to_string(passed) ++ "/" ++ to_string(total) ++ " passed")
  }
  totals
}
